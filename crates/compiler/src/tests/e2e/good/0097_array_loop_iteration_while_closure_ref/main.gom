package main;

fn main() {
    let f: (int32) -> int32 = |x| x * 2;
    let g: (int32) -> int32 = |x| x + 1;
    
    let fns: [(int32) -> int32; 2] = [f, g];
    let i = ref(0);
    while ref_get(i) < 2 {
        let func = array_get(fns, ref_get(i));
        string_println(int32_to_string(func(10)));
        ref_set(i, ref_get(i) + 1);
    };
}
