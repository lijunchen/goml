struct Callback {
    handler: (string) -> string,
}

fn make_callbacks() -> Vec[Callback] {
    let v = Vec::new();
    let v = v.push(Callback { handler: |s| s + " world" });
    let v = v.push(Callback { handler: |s| s + "!" });
    v
}

fn chain(cbs: Vec[Callback], input: string) -> string {
    let result = ref(input);
    let i = ref(0);
    while ref_get(i) < cbs.len() {
        let cb = cbs[ref_get(i)];
        ref_set(result, cb.handler(ref_get(result)));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let cbs = make_callbacks();
    let result = chain(cbs, "hello");
    println(result);
}
