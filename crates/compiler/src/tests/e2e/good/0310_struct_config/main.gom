struct Config {
    width: int32,
    height: int32,
    title: string,
}

fn main() {
    let c1 = Config { width: 800, height: 600, title: "hello" };
    let c2 = Config { width: 1024, height: c1.height, title: c1.title };
    string_println(int32_to_string(c2.width));
    string_println(int32_to_string(c2.height));
    string_println(c2.title);
}
