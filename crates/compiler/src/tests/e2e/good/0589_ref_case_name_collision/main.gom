struct Foo {
    value: int32,
}

struct foo {
    value: int32,
}

fn get_upper(r: Ref[Foo]) -> int32 {
    ref_get(r).value
}

fn get_lower(r: Ref[foo]) -> int32 {
    ref_get(r).value
}

fn main() -> unit {
    let upper = ref(Foo { value: 1i32 });
    let lower = ref(foo { value: 2i32 });
    println(get_upper(upper));
    println(get_lower(lower));
}
