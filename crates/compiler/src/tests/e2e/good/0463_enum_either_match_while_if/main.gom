enum Either[L, R] {
    Left(L),
    Right(R),
}

fn partition[T](arr: [T; 4], pred: (T) -> bool) -> ([Either[T, T]; 4]) {
    let result: [Either[T, T]; 4] = [
        if pred(arr[0]) { Either::Left(arr[0]) } else { Either::Right(arr[0]) },
        if pred(arr[1]) { Either::Left(arr[1]) } else { Either::Right(arr[1]) },
        if pred(arr[2]) { Either::Left(arr[2]) } else { Either::Right(arr[2]) },
        if pred(arr[3]) { Either::Left(arr[3]) } else { Either::Right(arr[3]) },
    ];
    result
}

fn main() {
    let arr = [1, 2, 3, 4];
    let parts = partition(arr, |x| x > 2);
    let i = ref(0i32);
    while ref_get(i) < 4 {
        let item = parts[ref_get(i)];
        match item {
            Either::Left(v) => println("left: " + v.to_string()),
            Either::Right(v) => println("right: " + v.to_string()),
        };
        ref_set(i, ref_get(i) + 1);
    };
}
