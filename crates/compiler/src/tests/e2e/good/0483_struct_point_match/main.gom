struct Point { x: int32, y: int32 }

fn classify(p: Point) -> string {
    match p {
        Point { x: 0, y: 0 } => "origin",
        Point { x: 0, y } => "y-axis at " + y.to_string(),
        Point { x, y: 0 } => "x-axis at " + x.to_string(),
        Point { x, y } => "(" + x.to_string() + ", " + y.to_string() + ")",
    }
}

fn main() {
    println(classify(Point { x: 0, y: 0 }));
    println(classify(Point { x: 0, y: 5 }));
    println(classify(Point { x: 3, y: 0 }));
    println(classify(Point { x: 1, y: 2 }));
}
