fn main() {
    let a = 10;
    let b = 20;
    let c = 30;
    let fns: [(int32) -> int32; 3] = [
        |x| x + a,
        |x| x + b,
        |x| x + c,
    ];
    let i = ref(0i32);
    while ref_get(i) < 3 {
        let f = fns[ref_get(i)];
        println(f(100).to_string());
        ref_set(i, ref_get(i) + 1);
    };
}
