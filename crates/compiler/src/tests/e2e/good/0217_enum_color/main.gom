package main;

#[derive(ToString)]
struct Point {
    x: int32,
    y: int32,
}

#[derive(ToString)]
enum Color {
    Red,
    Green,
    Blue,
    Custom(int32, int32, int32),
}

fn main() {
    let p = Point { x: 1, y: 2 };
    string_println(p.to_string());
    string_println(Color::Red.to_string());
    string_println(Color::Custom(255, 128, 0).to_string());
}
