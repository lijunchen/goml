struct Point { x: float32, y: float32 }

fn main() {
    let points: [Point; 3] = [
        Point { x: 1.0, y: 2.0 },
        Point { x: 3.0, y: 4.0 },
        Point { x: 5.0, y: 6.0 },
    ];
    let p = array_get(points, 1);
    string_println(float32_to_string(p.x));
    string_println(float32_to_string(p.y));
}
