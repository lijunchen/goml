package main;

fn main() {
    let mut total = 0;
    let add = |x: int32| {
        total = total + x;
        total
    };

    let mut i = 0;
    while i < 5 {
        if i < 3 {
            let _ = add(i);
        } else {
            let _ = add(i + 1);
        };
        i = i + 1;
    };

    string_println(int32_to_string(total));
    string_println(int32_to_string(add(3)));
}
