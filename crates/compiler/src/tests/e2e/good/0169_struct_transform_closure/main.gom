struct Transform {
    f: (int32) -> int32,
    name: string,
}

fn apply_transform(t: Transform, x: int32) -> string {
    t.name + "(" + int32_to_string(x) + ") = " + int32_to_string((t.f)(x))
}

fn main() {
    let double = Transform { f: |x: int32| x * 2, name: "double" };
    let inc = Transform { f: |x: int32| x + 1, name: "inc" };
    string_println(apply_transform(double, 5));
    string_println(apply_transform(inc, 5));
}
