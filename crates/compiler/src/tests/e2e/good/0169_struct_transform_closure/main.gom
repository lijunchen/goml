struct Transform {
    f: (int32) -> int32,
    name: string,
}

fn apply_transform(t: Transform, x: int32) -> string {
    t.name + "(" + (x).to_string() + ") = " + ((t.f)(x)).to_string()
}

fn main() {
    let double = Transform { f: |x: int32| x * 2, name: "double" };
    let inc = Transform { f: |x: int32| x + 1, name: "inc" };
    println(apply_transform(double, 5));
    println(apply_transform(inc, 5));
}
