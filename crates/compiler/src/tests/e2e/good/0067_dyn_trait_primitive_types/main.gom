trait Printable {
    fn to_str(Self) -> string;
}

impl Printable for int32 {
    fn to_str(self: int32) -> string { self.to_string() }
}

impl Printable for string {
    fn to_str(self: string) -> string { self }
}

impl Printable for bool {
    fn to_str(self: bool) -> string {
        if self { "true" } else { "false" }
    }
}

fn join_all(items: Vec[dyn Printable], sep: string) -> string {
    let result = ref("");
    let i = ref(0);
    while ref_get(i) < items.len() {
        if ref_get(i) > 0 {
            ref_set(result, ref_get(result) + sep);
        } else { () };
        ref_set(result, ref_get(result) + Printable::to_str(items[ref_get(i)]));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let v: Vec[dyn Printable] = Vec::new();
    let v = v.push(42);
    let v = v.push("hello");
    let v = v.push(true);
    let _ = println(join_all(v, ", "));
}
