struct Pair[A, B] {
    first: A,
    second: B,
}

trait Container {
    fn contents(Self) -> string;
}

impl Container for Pair[int32, string] {
    fn contents(self: Pair[int32, string]) -> string {
        self.second
    }
}

fn show_container(c: dyn Container) -> string {
    Container::contents(c)
}

fn main() {
    let p: Pair[int32, string] = Pair { first: 1, second: "hello" };
    string_println(show_container(p));
}
