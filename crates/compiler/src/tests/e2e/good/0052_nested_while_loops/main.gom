fn test_nested() {
    let i = ref(0);
    while ref_get(i) < 2 {
        let j = ref(0);
        while ref_get(j) < 3 {
            println("inner");
            ref_set(j, ref_get(j) + 1);
        };
        ref_set(i, ref_get(i) + 1);
    };
}

fn main() {
    let i = ref(0);
    while ref_get(i) < 3 {
        let j = ref(0);
        while ref_get(j) < 2 {
            let msg = ref_get(i).to_string() + "," + ref_get(j).to_string();
            println(msg);
            ref_set(j, ref_get(j) + 1);
        };
        ref_set(i, ref_get(i) + 1);
    };
    println("done");
}
