fn make_pair[T](a: T, b: T) -> (T, T) {
    (a, b)
}

fn swap[T](pair: (T, T)) -> (T, T) {
    let (a, b) = pair;
    (b, a)
}

fn main() {
    let p = make_pair(1, 2);
    let (a, b) = swap(p);
    println(a.to_string());
    println(b.to_string());

    let p2 = make_pair("hello", "world");
    let (x, y) = swap(p2);
    println(x);
    println(y);
}
