package main;

fn main() {
    let adders: [(int32) -> int32; 3] = [
        |x| x + 1,
        |x| x + 10,
        |x| x + 100,
    ];
    
    let i = ref(0);
    while ref_get(i) < 3 {
        let f = array_get(adders, ref_get(i));
        string_println(int32_to_string(f(0)));
        ref_set(i, ref_get(i) + 1);
    };
}
