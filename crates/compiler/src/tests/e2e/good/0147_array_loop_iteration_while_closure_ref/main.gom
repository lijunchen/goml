fn apply[A, B](f: (A) -> B, x: A) -> B {
    f(x)
}

fn main() {
    let result: string = apply(|x: int32| (x).to_string(), 42);
    println(result);
    
    let nums: [int32; 3] = [1, 2, 3];
    let doubled: [int32; 3] = [
        apply(|x| x * 2, nums[0]),
        apply(|x| x * 2, nums[1]),
        apply(|x| x * 2, nums[2]),
    ];
    let i = ref(0);
    while ref_get(i) < 3 {
        println((doubled[ref_get(i)]).to_string() + " ");
        ref_set(i, ref_get(i) + 1);
    };
    println("");
}
