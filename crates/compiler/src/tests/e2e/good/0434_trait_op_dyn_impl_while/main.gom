trait Op {
    fn run(Self, int32) -> int32;
}

struct Add { n: int32 }
struct Mul { n: int32 }

impl Op for Add { fn run(self: Add, x: int32) -> int32 { x + self.n } }
impl Op for Mul { fn run(self: Mul, x: int32) -> int32 { x * self.n } }

fn pipeline(ops: [dyn Op; 3], x: int32) -> int32 {
    let result = ref(x);
    let i = ref(0i32);
    while ref_get(i) < 3 {
        ref_set(result, Op::run(ops[ref_get(i)], ref_get(result)));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let ops: [dyn Op; 3] = [Add { n: 5 }, Mul { n: 2 }, Add { n: -3 }];
    println(pipeline(ops, 10).to_string());
}
