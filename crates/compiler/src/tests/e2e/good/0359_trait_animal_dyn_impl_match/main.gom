trait Animal {
    fn sound(Self) -> string;
}

struct Dog {}
struct Cat {}
struct Bird {}

impl Animal for Dog { fn sound(self: Dog) -> string { "woof" } }
impl Animal for Cat { fn sound(self: Cat) -> string { "meow" } }
impl Animal for Bird { fn sound(self: Bird) -> string { "tweet" } }

fn get_animal(kind: int32) -> dyn Animal {
    match kind {
        1 => Dog {},
        2 => Cat {},
        _ => Bird {},
    }
}

fn main() {
    let a1 = get_animal(1);
    let a2 = get_animal(2);
    let a3 = get_animal(3);
    println(Animal::sound(a1));
    println(Animal::sound(a2));
    println(Animal::sound(a3));
}
