fn map_option[A, B](opt: Option[A], f: (A) -> B) -> Option[B] {
    match opt {
        Option::Some(a) => Option::Some(f(a)),
        Option::None => Option::None,
    }
}

fn main() {
    let x: Option[int32] = Option::Some(42);
    let y = map_option(x, |n| n.to_string());
    match y {
        Option::Some(s) => println(s),
        Option::None => println("none"),
    };
}
