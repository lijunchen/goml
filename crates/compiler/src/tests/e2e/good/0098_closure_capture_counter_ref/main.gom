fn main() {
    let counter = ref(0);
    let inc = || {
        ref_set(counter, ref_get(counter) + 1);
        ref_get(counter)
    };
    println(inc().to_string());
    println(inc().to_string());
    println(inc().to_string());
    
    let make_adder = |n: int32| {
        |x: int32| x + n
    };
    let add5 = make_adder(5);
    println(add5(10).to_string());
}
