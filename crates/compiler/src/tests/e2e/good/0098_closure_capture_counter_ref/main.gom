fn main() {
    let counter = ref(0);
    let inc = || {
        ref_set(counter, ref_get(counter) + 1);
        ref_get(counter)
    };
    println(int32_to_string(inc()));
    println(int32_to_string(inc()));
    println(int32_to_string(inc()));
    
    let make_adder = |n: int32| {
        |x: int32| x + n
    };
    let add5 = make_adder(5);
    println(int32_to_string(add5(10)));
}
