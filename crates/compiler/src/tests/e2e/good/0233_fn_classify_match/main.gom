fn classify(x: int8) -> string {
    match x {
        -128 => "min",
        0 => "zero",
        127 => "max",
        _ => "other",
    }
}

fn main() {
    let a: int8 = -128;
    let b: int8 = 0;
    let c: int8 = 127;
    let d: int8 = 42;
    println(classify(a));
    println(classify(b));
    println(classify(c));
    println(classify(d));
}
