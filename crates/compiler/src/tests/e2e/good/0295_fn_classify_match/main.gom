fn classify(p: ((int32, int32), string)) -> string {
    match p {
        ((0, 0), label) => "origin: " + label,
        ((x, 0), label) => "x-axis at " + int32_to_string(x) + ": " + label,
        ((0, y), label) => "y-axis at " + int32_to_string(y) + ": " + label,
        ((x, y), label) => int32_to_string(x) + "," + int32_to_string(y) + ": " + label,
    }
}

fn main() {
    println(classify(((0, 0), "A")));
    println(classify(((3, 0), "B")));
    println(classify(((0, 7), "C")));
    println(classify(((1, 2), "D")));
}
