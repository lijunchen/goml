trait Speak {
    fn speak(Self) -> string;
}

struct Dog {}

impl Speak for Dog {
    fn speak(self: Dog) -> string {
        "woof"
    }
}

struct Cat {}

impl Speak for Cat {
    fn speak(self: Cat) -> string {
        "meow"
    }
}

fn main() {
    let v: Vec[dyn Speak] = Vec::new();
    let v = v.push(Dog {});
    let v = v.push(Cat {});
    let a = v[0];
    println(Speak::speak(a));
}
