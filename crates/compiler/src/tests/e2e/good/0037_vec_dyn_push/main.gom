trait Speak {
    fn speak(Self) -> string;
}

struct Dog {}

impl Speak for Dog {
    fn speak(self: Dog) -> string {
        "woof"
    }
}

struct Cat {}

impl Speak for Cat {
    fn speak(self: Cat) -> string {
        "meow"
    }
}

fn main() {
    let v: Vec[dyn Speak] = vec_new();
    let v = vec_push(v, Dog {});
    let v = vec_push(v, Cat {});
    let a = vec_get(v, 0);
    println(Speak::speak(a));
}
