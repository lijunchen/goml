
enum Option[T] {
    Some(T),
    None,
}

fn main() {
    let x: Option[Option[uint8]] = Option::Some(Option::Some(42));
    match x {
        Option::Some(inner) => {
            match inner {
                Option::Some(v) => string_println(uint8_to_string(v)),
                Option::None => string_println("inner none"),
            }
        },
        Option::None => string_println("outer none"),
    };
}
