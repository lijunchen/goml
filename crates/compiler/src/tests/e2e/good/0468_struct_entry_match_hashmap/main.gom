struct Entry {
    key: string,
    value: int32,
}

fn main() {
    let m = HashMap::new();
    m.set("a", Entry { key: "a", value: 1 });
    m.set("b", Entry { key: "b", value: 2 });
    
    let result = m.get("a");
    match result {
        Option::Some(e) => println(e.value.to_string()),
        Option::None => println("not found"),
    };
    
    let result2 = m.get("c");
    match result2 {
        Option::Some(e) => println(e.value.to_string()),
        Option::None => println("not found"),
    };
}
