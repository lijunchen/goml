fn unwrap_or[T](opt: Option[T], default: T) -> T {
    match opt {
        Option::Some(v) => v,
        Option::None => default,
    }
}

fn map[T, U](opt: Option[T], f: (T) -> U) -> Option[U] {
    match opt {
        Option::Some(v) => Option::Some(f(v)),
        Option::None => Option::None,
    }
}

fn and_then[T, U](opt: Option[T], f: (T) -> Option[U]) -> Option[U] {
    match opt {
        Option::Some(v) => f(v),
        Option::None => Option::None,
    }
}

fn parse_positive(s: string) -> Option[int32] {
    if s == "1" { Option::Some(1) }
    else if s == "2" { Option::Some(2) }
    else if s == "3" { Option::Some(3) }
    else { Option::None }
}

fn main() {
    let input: Option[string] = Option::Some("2");
    let result = and_then(input, |s| parse_positive(s));
    let doubled = map(result, |n| n * 2);
    println(unwrap_or(doubled, 0).to_string());

    let empty: Option[string] = Option::None;
    let result2 = and_then(empty, |s| parse_positive(s));
    println(unwrap_or(result2, -1).to_string());
}
