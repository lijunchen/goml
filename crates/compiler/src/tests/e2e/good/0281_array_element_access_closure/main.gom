fn main() {
    let ops: [(int32, int32) -> int32; 3] = [
        |a: int32, b: int32| a + b,
        |a: int32, b: int32| a - b,
        |a: int32, b: int32| a * b,
    ];
    println(((ops[0])(10, 3)).to_string());
    println(((ops[1])(10, 3)).to_string());
    println(((ops[2])(10, 3)).to_string());
}
