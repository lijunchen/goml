trait Describe {
    fn describe(Self) -> string;
}

struct Point {
    x: int32,
    y: int32,
}

impl Describe for Point {
    fn describe(self: Point) -> string {
        "(" + (self.x).to_string() + ", " + (self.y).to_string() + ")"
    }
}

fn print_desc(s: dyn Describe) {
    println(Describe::describe(s));
}

fn make_points() -> Vec[dyn Describe] {
    let v: Vec[dyn Describe] = Vec::new();
    let v = v.push(Point { x: 1, y: 2 });
    let v = v.push(Point { x: 3, y: 4 });
    v
}

fn main() {
    let points = make_points();
    let i = ref(0);
    while ref_get(i) < points.len() {
        print_desc(points.get(ref_get(i)));
        ref_set(i, ref_get(i) + 1);
    };
}
