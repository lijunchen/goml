struct EventHandler {
    on_click: (int32, int32) -> unit,
    on_key: (char) -> unit,
}

fn make_handler() -> EventHandler {
    let log = ref(Vec::new());
    EventHandler {
        on_click: |x: int32, y: int32| {
            ref_set(log, ref_get(log).push("click:" + (x).to_string() + "," + (y).to_string()));
        },
        on_key: |c: char| {
            ref_set(log, ref_get(log).push("key:" + (c).to_string()));
        },
    }
}

fn main() {
    let h = make_handler();
    let on_click = h.on_click;
    on_click(10, 20);
    let on_key = h.on_key;
    on_key('a');
    println("done");
}
