struct EventHandler {
    on_click: (int32, int32) -> unit,
    on_key: (char) -> unit,
}

fn make_handler() -> EventHandler {
    let log = ref(vec_new());
    EventHandler {
        on_click: |x: int32, y: int32| {
            ref_set(log, vec_push(ref_get(log), "click:" + int32_to_string(x) + "," + int32_to_string(y)));
        },
        on_key: |c: char| {
            ref_set(log, vec_push(ref_get(log), "key:" + char_to_string(c)));
        },
    }
}

fn main() {
    let h = make_handler();
    let on_click = h.on_click;
    on_click(10, 20);
    let on_key = h.on_key;
    on_key('a');
    println("done");
}
