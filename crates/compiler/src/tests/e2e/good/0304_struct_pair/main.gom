
struct Pair[A, B] {
    first: A,
    second: B,
}

fn swap[A, B](p: Pair[A, B]) -> Pair[B, A] {
    Pair { first: p.second, second: p.first }
}

fn main() {
    let p = Pair { first: 1, second: "hello" };
    let s = swap(p);
    string_println(s.first);
    string_println(int32_to_string(s.second));
}
