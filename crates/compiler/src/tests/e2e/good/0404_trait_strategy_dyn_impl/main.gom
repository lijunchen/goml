trait Strategy {
    fn execute(Self, int32) -> int32;
}

struct Aggressive {}
struct Defensive {}

impl Strategy for Aggressive {
    fn execute(self: Aggressive, x: int32) -> int32 { x * 2 }
}

impl Strategy for Defensive {
    fn execute(self: Defensive, x: int32) -> int32 { x + 1 }
}

struct Player {
    name: string,
    strategy: dyn Strategy,
    health: int32,
}

fn player_turn(p: Player) -> string {
    let damage = Strategy::execute(p.strategy, p.health);
    p.name + " deals " + damage.to_string()
}

fn main() {
    let p1 = Player { name: "Warrior", strategy: Aggressive {}, health: 10 };
    let p2 = Player { name: "Healer", strategy: Defensive {}, health: 10 };
    println(player_turn(p1));
    println(player_turn(p2));
}
