
trait Handler {
    fn handle(Self, string) -> string;
}

struct Upper {}
struct Lower {}

impl Handler for Upper {
    fn handle(self: Upper, s: string) -> string { "UPPER:" + s }
}
impl Handler for Lower {
    fn handle(self: Lower, s: string) -> string { "lower:" + s }
}

struct Pipeline {
    handler: dyn Handler,
}

fn run(p: Pipeline, input: string) -> string {
    Handler::handle(p.handler, input)
}

fn main() {
    let p1 = Pipeline { handler: Upper {} };
    let p2 = Pipeline { handler: Lower {} };
    string_println(run(p1, "test"));
    string_println(run(p2, "test"));
}
