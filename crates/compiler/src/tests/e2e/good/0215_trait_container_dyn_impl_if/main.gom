trait Container {
    fn size(Self) -> int32;
    fn is_empty(Self) -> bool;
}

struct MyList {
    len: int32,
}

impl Container for MyList {
    fn size(self: MyList) -> int32 { self.len }
    fn is_empty(self: MyList) -> bool { self.len == 0 }
}

fn print_info(c: dyn Container) {
    println(int32_to_string(Container::size(c)));
    if Container::is_empty(c) {
        println("empty")
    } else {
        println("not empty")
    };
}

fn main() {
    print_info(MyList { len: 5 });
    print_info(MyList { len: 0 });
}
