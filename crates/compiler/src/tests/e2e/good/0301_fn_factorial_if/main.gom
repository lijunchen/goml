fn factorial(n: int32) -> int32 {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fib(n: int32) -> int32 {
    if n <= 1 { n } else { fib(n - 1) + fib(n - 2) }
}

fn main() {
    string_println(int32_to_string(factorial(5)));
    string_println(int32_to_string(fib(10)));
}
