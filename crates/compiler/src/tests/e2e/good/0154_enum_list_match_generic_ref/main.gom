enum List[T] {
    Cons(T, Ref[List[T]]),
    Nil,
}

fn len[T](list: List[T]) -> int32 {
    match list {
        List::Cons(_, rest) => 1 + len(ref_get(rest)),
        List::Nil => 0,
    }
}

fn main() {
    let list: List[int32] = List::Cons(1, ref(List::Cons(2, ref(List::Cons(3, ref(List::Nil))))));
    println((len(list)).to_string());
}
