fn main() {
    let x = 1;
    let x = x + 1;
    let x = x * 3;
    println(x.to_string());
    
    let y = "hello";
    let y = y + " world";
    println(y);
    
    let z = (1, "a");
    let (a, b) = z;
    let z = (a + 1, b + "b");
    let (a, b) = z;
    println(a.to_string());
    println(b);
}
