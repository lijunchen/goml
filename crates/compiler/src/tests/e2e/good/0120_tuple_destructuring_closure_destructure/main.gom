package main;

fn main() {
    let x: (int32, string, bool) = (42, "hello", true);
    let (a, _, c) = x;
    string_println(int32_to_string(a));
    string_println(bool_to_string(c));
    
    let f = |t: (int32, int32)| {
        let (a, b) = t;
        a + b
    };
    string_println(int32_to_string(f((10, 20))));
}
