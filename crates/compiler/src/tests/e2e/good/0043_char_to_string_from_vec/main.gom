fn main() {
    let chars = Vec::new();
    let chars = chars.push('H');
    let chars = chars.push('i');
    let ch = chars[0];
    println(ch.to_string());
    let i = ref(0);
    while ref_get(i) < chars.len() {
        let c = chars[ref_get(i)];
        println(c.to_string());
        ref_set(i, ref_get(i) + 1);
    };
    println("");
}
