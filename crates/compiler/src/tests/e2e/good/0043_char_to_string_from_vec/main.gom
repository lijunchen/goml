
fn main() {
    let chars = vec_new();
    let chars = vec_push(chars, 'H');
    let chars = vec_push(chars, 'i');
    let ch = vec_get(chars, 0);
    string_println(ch.to_string());
    let i = ref(0);
    while ref_get(i) < vec_len(chars) {
        let c = vec_get(chars, ref_get(i));
        string_print(c.to_string());
        ref_set(i, ref_get(i) + 1);
    };
    string_println("");
}
