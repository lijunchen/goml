struct Point { x: int32, y: int32 }
struct Line { start: Point, end: Point }

fn describe_line(line: Line) -> string {
    match line {
        Line { start: Point { x: sx, y: sy }, end: Point { x: ex, y: ey } } => {
            "(" + sx.to_string() + "," + sy.to_string() + ")->(" + ex.to_string() + "," + ey.to_string() + ")"
        },
    }
}

fn main() {
    let l = Line { start: Point { x: 0, y: 0 }, end: Point { x: 10, y: 20 } };
    println(describe_line(l));
}
