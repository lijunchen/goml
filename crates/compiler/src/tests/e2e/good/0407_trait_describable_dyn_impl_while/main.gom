trait Describable {
    fn describe(Self) -> string;
}

struct Named {
    name: string,
}

struct Numbered {
    id: int32,
}

impl Describable for Named {
    fn describe(self: Named) -> string {
        "name: " + self.name
    }
}

impl Describable for Numbered {
    fn describe(self: Numbered) -> string {
        "id: " + self.id.to_string()
    }
}

fn describe_all(items: [dyn Describable; 3]) -> string {
    let result = ref("");
    let i = ref(0);
    while ref_get(i) < 3 {
        let item = items[ref_get(i)];
        let sep = if ref_get(i) > 0 { ", " } else { "" };
        ref_set(result, ref_get(result) + sep + Describable::describe(item));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let items: [dyn Describable; 3] = [
        Named { name: "Alice" },
        Numbered { id: 42 },
        Named { name: "Bob" },
    ];
    println(describe_all(items));
}
