
enum Fruit {
    Apple,
    Orange,
}

enum Color {
    Red,
    Orange,
}

fn main() {
    let f = Fruit::Orange;
    let c = Color::Orange;
    match f {
        Fruit::Apple => string_println("apple"),
        Fruit::Orange => string_println("orange fruit"),
    };
    match c {
        Color::Red => string_println("red"),
        Color::Orange => string_println("orange color"),
    };
}
