enum Fruit {
    Apple,
    Orange,
}

enum Color {
    Red,
    Orange,
}

fn main() {
    let f = Fruit::Orange;
    let c = Color::Orange;
    match f {
        Fruit::Apple => println("apple"),
        Fruit::Orange => println("orange fruit"),
    };
    match c {
        Color::Red => println("red"),
        Color::Orange => println("orange color"),
    };
}
