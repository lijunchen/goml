
fn make_counter(seed: int32) -> () -> int32 {
    let mut n = seed;
    || {
        n = n + 1;
        n
    }
}

fn main() {
    let c1 = make_counter(0);
    let c2 = make_counter(10);

    string_println(int32_to_string(c1()));
    string_println(int32_to_string(c1()));
    string_println(int32_to_string(c2()));
    string_println(int32_to_string(c1()));
    string_println(int32_to_string(c2()));
}
