trait Transform {
    fn apply(Self, int32) -> int32;
}

struct Adder { amount: int32 }
struct Multiplier { factor: int32 }

impl Transform for Adder {
    fn apply(self: Adder, x: int32) -> int32 { x + self.amount }
}

impl Transform for Multiplier {
    fn apply(self: Multiplier, x: int32) -> int32 { x * self.factor }
}

fn apply_all(transforms: Vec[dyn Transform], x: int32) -> int32 {
    let result = ref(x);
    let i = ref(0i32);
    while ref_get(i) < vec_len(transforms) {
        let t = vec_get(transforms, ref_get(i));
        ref_set(result, Transform::apply(t, ref_get(result)));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let transforms: Vec[dyn Transform] = vec_new();
    vec_push(transforms, Adder { amount: 5 });
    vec_push(transforms, Multiplier { factor: 3 });
    vec_push(transforms, Adder { amount: -2 });
    let result = apply_all(transforms, 10);
    println(result.to_string());
}
