fn fib(n: int32) -> int32 {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

fn main() {
    let i = ref(0);
    while ref_get(i) < 10 {
        println(int32_to_string(fib(ref_get(i))));
        println(" ");
        ref_set(i, ref_get(i) + 1);
    };
    println("");
}
