fn first[T](items: Vec[T]) -> Option[T] {
    if items.len() > 0 {
        Option::Some(items[0])
    } else {
        Option::None
    }
}

fn main() {
    let v = Vec::new();
    let v = v.push(42);
    let r = first(v);
    match r {
        Option::Some(x) => println(x.to_string()),
        Option::None => println("none"),
    };
}
