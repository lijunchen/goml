trait Printable {
    fn print(Self) -> string;
}

struct Wrapped[T] { inner: T }

impl Printable for Wrapped[int32] {
    fn print(self: Wrapped[int32]) -> string { "int:" + (self.inner).to_string() }
}

impl Printable for Wrapped[string] {
    fn print(self: Wrapped[string]) -> string { "str:" + self.inner }
}

fn wrap[T](x: T) -> Wrapped[T] {
    Wrapped { inner: x }
}

fn main() {
    let items: Vec[dyn Printable] = Vec::new();
    let items = items.push(wrap(42));
    let items = items.push(wrap("hello"));
    let i = ref(0);
    while ref_get(i) < items.len() {
        println(Printable::print(items[ref_get(i)]));
        ref_set(i, ref_get(i) + 1);
    };
}
