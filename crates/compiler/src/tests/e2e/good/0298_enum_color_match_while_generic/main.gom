enum Color {
    Red,
    Green,
    Blue,
    Custom(int32, int32, int32),
}

fn describe(c: Color) -> string {
    match c {
        Color::Red => "red",
        Color::Green => "green",
        Color::Blue => "blue",
        Color::Custom(r, g, b) => r.to_string() + "," + g.to_string() + "," + b.to_string(),
    }
}

fn main() {
    let colors: Vec[Color] = Vec::new();
    let colors = colors.push(Color::Red);
    let colors = colors.push(Color::Custom(255, 128, 0));
    let colors = colors.push(Color::Blue);
    
    let i = ref(0);
    while ref_get(i) < colors.len() {
        println(describe(colors[ref_get(i)]));
        ref_set(i, ref_get(i) + 1);
    };
}
