enum Shape {
    Circle(float64),
    Rect(float64, float64),
}

fn area(s: Shape) -> float64 {
    match s {
        Shape::Circle(r) => 3.14159 * r * r,
        Shape::Rect(w, h) => w * h,
    }
}

fn main() {
    println((area(Shape::Circle(1.0))).to_string());
    println((area(Shape::Rect(3.0, 4.0))).to_string());
}
