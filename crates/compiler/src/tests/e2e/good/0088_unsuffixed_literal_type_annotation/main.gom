
fn take_u8(x: uint8) -> uint8 {
    x
}

fn take_f32(x: float32) -> float32 {
    x
}

fn main() {
    let a: uint8 = 1;
    let b: int8 = 2;
    let c: int16 = 3;
    let d: uint16 = 4;
    let e: uint32 = 5;
    let f: int64 = 6;
    let g: uint64 = 7;
    let h: float32 = 1.0;

    string_println(uint8_to_string(a));
    string_println(int8_to_string(b));
    string_println(int16_to_string(c));
    string_println(uint16_to_string(d));
    string_println(uint32_to_string(e));
    string_println(int64_to_string(f));
    string_println(uint64_to_string(g));
    string_println(float32_to_string(h));

    string_println(uint8_to_string(take_u8(10)));
    string_println(float32_to_string(take_f32(2.5)));
}
