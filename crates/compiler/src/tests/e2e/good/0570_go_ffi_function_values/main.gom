#[go_value]
extern "go" "io" "EOF" eof() -> GoError

extern "go" "net/url" "*URL" type URL

#[go_error_last]
extern "go" "net/url" "Parse" parse_url(text: string) -> Result[URL, GoError]

#[go_field_get("Host")]
extern "go" "net/url" url_host(url: URL) -> string

#[go_field_set("Path")]
extern "go" "net/url" url_set_path(url: URL, path: string) -> unit

extern "go" "net/url" "(*URL).String" url_string(url: URL) -> string

fn render_error(make: () -> GoError) -> string {
    make().to_string()
}

fn read_host(getter: (URL) -> string, url: URL) -> string {
    getter(url)
}

fn write_path(setter: (URL, string) -> unit, url: URL, path: string) -> string {
    setter(url, path);
    url_string(url)
}

fn run(text: string) -> Result[string, GoError] {
    let url = parse_url(text)?;
    let err = render_error(eof);
    let host = read_host(url_host, url);
    let rewritten = write_path(url_set_path, url, "/new");
    Result::Ok(err + "|" + host + "|" + rewritten)
}

fn show(res: Result[string, GoError]) -> string {
    match res {
        Result::Ok(value) => value,
        Result::Err(err) => err.to_string(),
    }
}

fn main() -> unit {
    println(show(run("https://example.com/old")));
}
