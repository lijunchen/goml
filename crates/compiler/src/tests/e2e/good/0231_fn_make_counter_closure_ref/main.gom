fn make_counter() -> () -> int32 {
    let count = ref(0);
    || {
        let c = ref_get(count);
        ref_set(count, c + 1);
        c
    }
}

fn main() {
    let counter = make_counter();
    println((counter()).to_string());
    println((counter()).to_string());
    println((counter()).to_string());
}
