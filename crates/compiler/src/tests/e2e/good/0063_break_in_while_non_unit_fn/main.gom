fn find_first(v: Vec[int32], pred: (int32) -> bool) -> Option[int32] {
    let i = ref(0);
    let result: Ref[Option[int32]] = ref(Option::None);
    while ref_get(i) < v.len() {
        let item = v[ref_get(i)];
        if pred(item) {
            ref_set(result, Option::Some(item));
            break
        } else { () };
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(result)
}

fn main() {
    let v = Vec::new();
    let v = v.push(10);
    let v = v.push(20);
    let v = v.push(30);
    let result = find_first(v, |x| x > 15);
    match result {
        Option::Some(n) => println("found: " + n.to_string()),
        Option::None => println("not found"),
    };
}
