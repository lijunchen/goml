fn main() {
    let a: int8 = 42i8;
    let b: int16 = 1000i16;
    let c: int32 = 100000i32;
    let d: int64 = 10000000i64;
    let e: uint8 = 200u8;
    let f: uint16 = 50000u16;
    let g: uint32 = 3000000u32;
    let h: uint64 = 9000000000u64;
    println(a.to_string());
    println(b.to_string());
    println(c.to_string());
    println(d.to_string());
    println(e.to_string());
    println(f.to_string());
    println(g.to_string());
    println(h.to_string());
}
