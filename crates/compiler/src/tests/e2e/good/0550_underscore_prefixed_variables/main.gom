fn add_one(_x: int32) -> int32 {
    _x + 1
}

fn main() {
    let _value = 41;
    let add = |_: int32, _n: int32| _n + 1;
    let out1 = add_one(_value);
    let out2 = add(0, 41);
    match (1, 2, 3) {
        (a, b, _c) => {
            println((a + b).to_string());
        }
    };
    println(out1.to_string());
    println(out2.to_string());
}
