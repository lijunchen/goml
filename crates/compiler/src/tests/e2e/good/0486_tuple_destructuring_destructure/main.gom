fn swap[A, B](t: (A, B)) -> (B, A) {
    let (a, b) = t;
    (b, a)
}

fn main() {
    let t = (1, "hello");
    let (s, n) = swap(t);
    println(s);
    println(n.to_string());
    
    let t2 = ((1, 2), (3, 4));
    let (a, b) = t2;
    let (a1, a2) = a;
    let (b1, b2) = b;
    println((a1 + b1).to_string());
    println((a2 + b2).to_string());
}
