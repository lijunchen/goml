enum Option[T] {
    Some(T),
    None,
}

fn main() {
    let (a, (b, c)) = (1, (2, 3));
    string_println(int32_to_string(a + b + c));
    
    let (x, y, z) = (10, "hello", true);
    string_println(int32_to_string(x));
    string_println(y);
    if z { string_println("true") } else { string_println("false") };
}
