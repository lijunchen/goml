trait Container {
    fn size(Self) -> int32;
    fn is_empty(Self) -> bool;
}

impl Container for Vec[int32] {
    fn size(self: Vec[int32]) -> int32 { self.len() }
    fn is_empty(self: Vec[int32]) -> bool { self.len() == 0 }
}

fn main() {
    let v = Vec::new();
    let v = v.push(1);
    let v = v.push(2);
    let _ = println(v.is_empty());
    let _ = println(v.size());
    let _ = println(Container::size(v));
}
