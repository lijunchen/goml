fn main() {
    let m = hashmap_new();
    hashmap_set(m, 1, "one");
    hashmap_set(m, 2, "two");
    hashmap_set(m, 3, "three");
    
    match hashmap_get(m, 2) {
        Option::Some(v) => println(v),
        Option::None => println("not found"),
    };
    
    println(int32_to_string(hashmap_len(m)));
    
    if hashmap_contains(m, 1) {
        println("contains 1")
    } else {
        println("missing 1")
    };
}
