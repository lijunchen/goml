fn main() {
    let m = HashMap::new();
    m.set(1, "one");
    m.set(2, "two");
    m.set(3, "three");
    
    match m.get(2) {
        Option::Some(v) => println(v),
        Option::None => println("not found"),
    };
    
    println(int32_to_string(m.len()));
    
    if m.contains(1) {
        println("contains 1")
    } else {
        println("missing 1")
    };
}
