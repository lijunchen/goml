trait Show {
    fn show(Self) -> string;
}

struct A {}
struct B {}

impl Show for A { fn show(self: A) -> string { "A" } }
impl Show for B { fn show(self: B) -> string { "B" } }

fn display(x: dyn Show) {
    println(Show::show(x));
}

fn main() {
    let flag = true;
    display(if flag { A {} } else { A {} });
}
