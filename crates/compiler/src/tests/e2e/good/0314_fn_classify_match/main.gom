fn classify(p: (int32, int32)) -> string {
    match p {
        (0, 0) => "origin",
        (0, _) => "y-axis",
        (_, 0) => "x-axis",
        (x, y) => "(" + int32_to_string(x) + "," + int32_to_string(y) + ")",
    }
}

fn main() {
    println(classify((0, 0)));
    println(classify((0, 5)));
    println(classify((3, 0)));
    println(classify((1, 2)));
}
