fn classify_char(c: char) -> string {
    match c {
        'a' => "lowercase a",
        'A' => "uppercase A",
        '0' => "digit zero",
        ' ' => "space",
        '\n' => "newline",
        _ => "other",
    }
}

fn main() {
    println(classify_char('a'));
    println(classify_char('A'));
    println(classify_char('0'));
    println(classify_char(' '));
    println(classify_char('\n'));
    println(classify_char('z'));
}
