enum Color {
    Red,
    Green,
    Blue,
    Custom(uint8, uint8, uint8),
}

fn to_hex(c: Color) -> string {
    match c {
        Color::Red => "#FF0000",
        Color::Green => "#00FF00",
        Color::Blue => "#0000FF",
        Color::Custom(r, g, b) => "#" + r.to_string() + g.to_string() + b.to_string(),
    }
}

fn main() {
    println(to_hex(Color::Red));
    println(to_hex(Color::Green));
    println(to_hex(Color::Custom(128u8, 64u8, 32u8)));
}
