fn main() {
    let x: uint8 = 10;
    let y: uint8 = 20;
    let z: uint8 = x + y;
    println((z).to_string());
    
    let a: int64 = 1000000;
    let b: int64 = 2000000;
    let c: int64 = a + b;
    println((c).to_string());
    
    let d: float32 = 1.5;
    let e: float32 = 2.5;
    let f: float32 = d + e;
    println((f).to_string());
}
