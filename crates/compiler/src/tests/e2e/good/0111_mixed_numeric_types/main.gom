package main;

fn main() {
    let x: uint8 = 10;
    let y: uint8 = 20;
    let z: uint8 = x + y;
    string_println(uint8_to_string(z));
    
    let a: int64 = 1000000;
    let b: int64 = 2000000;
    let c: int64 = a + b;
    string_println(int64_to_string(c));
    
    let d: float32 = 1.5;
    let e: float32 = 2.5;
    let f: float32 = d + e;
    string_println(float32_to_string(f));
}
