package main;

trait Greet {
    fn hello(Self) -> string;
}

struct Person {
    name: string,
}

impl Person {
    fn hello(self: Person) -> string {
        "Hi, I'm " + self.name
    }
}

impl Greet for Person {
    fn hello(self: Person) -> string {
        "Hello from " + self.name
    }
}

fn main() {
    let p = Person { name: "Alice" };
    string_println(p.hello());
    string_println(Greet::hello(p));
}
