
fn main() {
    let t = (1, "hello", true);
    let (a, b, c) = t;
    string_println(int32_to_string(a));
    string_println(b);
    
    let nested = ((1, 2), (3, 4));
    let ((x1, y1), (x2, y2)) = nested;
    string_println(int32_to_string(x1 + x2));
    string_println(int32_to_string(y1 + y2));
}
