
fn main() {
    let a: uint8 = 10;
    let b: uint8 = 20;
    if a < b {
        string_println("a < b")
    } else {
        string_println("a >= b")
    };
    
    let c: float32 = 1.5;
    let d: float32 = 2.5;
    if c > d {
        string_println("c > d")
    } else {
        string_println("c <= d")
    };
}
