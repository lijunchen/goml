struct Handler[T] {
    name: string,
    process: (T) -> string,
}

fn run_handler[T](h: Handler[T], input: T) -> string {
    h.name + ": " + h.process(input)
}

fn main() {
    let h1 = Handler { name: "int_handler", process: |x: int32| x.to_string() };
    let h2 = Handler { name: "str_handler", process: |x: string| "got: " + x };
    println(run_handler(h1, 42));
    println(run_handler(h2, "hello"));
}
