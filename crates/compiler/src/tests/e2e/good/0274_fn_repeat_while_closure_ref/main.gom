
fn repeat(n: int32, f: () -> unit) {
    let i = ref(0);
    while ref_get(i) < n {
        f();
        ref_set(i, ref_get(i) + 1);
    };
}

fn main() {
    let count = ref(0);
    repeat(5, || {
        ref_set(count, ref_get(count) + 1);
    });
    string_println(int32_to_string(ref_get(count)));
}
