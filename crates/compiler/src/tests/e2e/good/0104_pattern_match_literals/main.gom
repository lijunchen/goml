package main;

fn main() {
    let x = match 42 {
        0 => "zero",
        1 => "one",
        42 => "answer",
        _ => "other",
    };
    string_println(x);
    
    let y = match "hello" {
        "hello" => 1,
        "world" => 2,
        _ => 0,
    };
    string_println(int32_to_string(y));
}
