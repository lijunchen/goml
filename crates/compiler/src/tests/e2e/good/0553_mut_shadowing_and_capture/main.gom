fn main() {
    let mut x = 10;
    let bump_outer = || {
        x = x + 1;
        x
    };

    let run_shadow = || {
        let mut x = 100;
        x = x + 50;
        x
    };

    println(int32_to_string(run_shadow()));
    println(int32_to_string(bump_outer()));
    println(int32_to_string(x));
    println(int32_to_string(bump_outer()));
}
