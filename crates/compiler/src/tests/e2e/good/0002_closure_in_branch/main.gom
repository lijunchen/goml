fn main() {
    let cond = true;
    let f: (int32) -> int32 = if cond { |x: int32| x + 1 } else { |x: int32| x * 2 };
    println(f(10).to_string());

    let x: int32 = 1;
    let g: (int32) -> int32 = match x {
        1 => |n: int32| n + 10,
        2 => |n: int32| n * 10,
        _ => |n: int32| n,
    };
    println(g(5).to_string());
}
