enum Option[T] {
    Some(T),
    None,
}

struct Point {
    x: int32,
    y: int32,
}

fn main() {
    let opt = Option::Some(Point { x: 1, y: 2 });
    match opt {
        Option::Some(Point { x, y }) => {
            println((x + y).to_string());
        },
        Option::None => println("none"),
    };
}
