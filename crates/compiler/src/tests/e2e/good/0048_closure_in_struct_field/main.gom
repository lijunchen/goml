package main;

struct Mapper {
    transform: (int32) -> int32,
}

fn use_mapper(m: Mapper, x: int32) -> int32 {
    let f = m.transform;
    f(x)
}

fn double(x: int32) -> int32 { x * 2 }

fn main() {
    let m1 = Mapper { transform: double };
    string_println(use_mapper(m1, 21).to_string());
    let m2 = Mapper { transform: |x| x + 1 };
    string_println(use_mapper(m2, 41).to_string());
}
