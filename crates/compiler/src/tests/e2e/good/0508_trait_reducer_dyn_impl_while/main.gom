trait Reducer {
    fn reduce(Self, int32, int32) -> int32;
}

struct SumReducer {}
struct MaxReducer {}

impl Reducer for SumReducer {
    fn reduce(self: SumReducer, acc: int32, x: int32) -> int32 { acc + x }
}

impl Reducer for MaxReducer {
    fn reduce(self: MaxReducer, acc: int32, x: int32) -> int32 {
        if x > acc { x } else { acc }
    }
}

fn fold_array(r: dyn Reducer, items: [int32; 5], init: int32) -> int32 {
    let acc = ref(init);
    let i = ref(0);
    while ref_get(i) < 5 {
        ref_set(acc, Reducer::reduce(r, ref_get(acc), array_get(items, ref_get(i))));
        ref_set(i, ref_get(i) + 1);
    };
    ref_get(acc)
}

fn main() {
    let data = [3, 1, 4, 1, 5];
    
    let sum_r: dyn Reducer = SumReducer {};
    println(fold_array(sum_r, data, 0).to_string());
    
    let max_r: dyn Reducer = MaxReducer {};
    println(fold_array(max_r, data, 0).to_string());
}
