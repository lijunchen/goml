struct Box[T] { value: T }

trait Describe {
    fn describe(Self) -> string;
}

impl Describe for Box[int32] {
    fn describe(self: Box[int32]) -> string {
        "Box(" + self.value.to_string() + ")"
    }
}

impl Describe for Box[string] {
    fn describe(self: Box[string]) -> string {
        "Box(\"" + self.value + "\")"
    }
}

fn main() {
    let b = Box { value: 42 };
    string_println(b.describe());
    let s = Box { value: "hello" };
    string_println(s.describe());
}
