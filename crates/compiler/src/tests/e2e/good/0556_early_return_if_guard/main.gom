fn classify(x: int32) -> string {
    if x < 0i32 {
        return "neg"
    } else {
        ()
    };
    if x == 0i32 {
        return "zero"
    } else {
        ()
    };
    "pos"
}

fn main() {
    string_println(classify(-1i32));
    string_println(classify(0i32));
    string_println(classify(2i32));
}
