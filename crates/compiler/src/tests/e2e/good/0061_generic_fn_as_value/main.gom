fn identity[T](x: T) -> T { x }

fn apply[T, U](f: (T) -> U, x: T) -> U { f(x) }

fn pipe[A, B, C](f: (A) -> B, g: (B) -> C, x: A) -> C {
    g(f(x))
}

fn double(x: int32) -> int32 { x * 2 }

fn main() {
    let result = apply(identity, 42);
    println((result).to_string());

    let result2 = apply(double, 21);
    println((result2).to_string());

    let result3 = pipe(identity, double, 10);
    println((result3).to_string());

    let f = identity;
    println((f(99)).to_string());
}
