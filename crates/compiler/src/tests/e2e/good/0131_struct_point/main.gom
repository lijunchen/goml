struct Point { x: int32, y: int32 }

fn main() {
    let p = Point { x: 1, y: 2 };
    let Point { x, y } = p;
    println((x).to_string());
    println((y).to_string());
    
    let q = Point { x: 10, y: 20 };
    let Point { x: a, y: b } = q;
    println((a).to_string());
    println((b).to_string());
}
