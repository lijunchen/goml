struct Point { x: int32, y: int32 }

fn main() {
    let p = Point { x: 1, y: 2 };
    let Point { x, y } = p;
    string_println(int32_to_string(x));
    string_println(int32_to_string(y));
    
    let q = Point { x: 10, y: 20 };
    let Point { x: a, y: b } = q;
    string_println(int32_to_string(a));
    string_println(int32_to_string(b));
}
