fn print_uint8(x: uint8) {
    println(x.to_string());
}

fn print_int8(x: int8) {
    println(x.to_string());
}

fn print_int16(x: int16) {
    println(x.to_string());
}

fn print_uint16(x: uint16) {
    println(x.to_string());
}

fn print_uint32(x: uint32) {
    println(x.to_string());
}

fn print_int64(x: int64) {
    println(x.to_string());
}

fn print_uint64(x: uint64) {
    println(x.to_string());
}

fn print_float32(x: float32) {
    println(x.to_string());
}

fn main() {
    let a: uint8 = 255;
    print_uint8(a);

    let b: int8 = -1;
    print_int8(b);

    let c: int16 = 1000;
    print_int16(c);

    let d: uint16 = 50000;
    print_uint16(d);

    let e: uint32 = 100000;
    print_uint32(e);

    let f: int64 = 9999999;
    print_int64(f);

    let g: uint64 = 42;
    print_uint64(g);

    let h: float32 = 3.14;
    print_float32(h);

    print_uint8(10);
    print_int64(99);
    print_float32(2.5);
}
