
trait Show {
    fn show(Self) -> string;
}

impl Show for int32 {
    fn show(self: int32) -> string {
        int32_to_string(self)
    }
}

impl Show for string {
    fn show(self: string) -> string {
        self
    }
}

fn print_it[T: Show](x: T) {
    string_println(Show::show(x));
}

fn main() {
    print_it(42);
    print_it("hello");
}
