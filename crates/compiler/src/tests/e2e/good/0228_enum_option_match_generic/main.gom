enum Option[T] {
    Some(T),
    None,
}

fn main() {
    let x: Option[uint8] = Option::Some(10);
    let y: Option[float32] = Option::None;
    match x {
        Option::Some(v) => println((v).to_string()),
        Option::None => println("none"),
    };
    match y {
        Option::Some(v) => println((v).to_string()),
        Option::None => println("none"),
    };
}
