enum Option[T] {
    Some(T),
    None,
}

fn main() {
    let x: Option[uint8] = Option::Some(10);
    let y: Option[float32] = Option::None;
    match x {
        Option::Some(v) => string_println(uint8_to_string(v)),
        Option::None => string_println("none"),
    };
    match y {
        Option::Some(v) => string_println(float32_to_string(v)),
        Option::None => string_println("none"),
    };
}
