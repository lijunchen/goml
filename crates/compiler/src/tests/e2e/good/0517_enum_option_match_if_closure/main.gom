enum Option[T] {
    Some(T),
    None,
}

fn map_option[A, B](opt: Option[A], f: (A) -> B) -> Option[B] {
    match opt {
        Option::Some(v) => Option::Some(f(v)),
        Option::None => Option::None,
    }
}

fn flat_map[A, B](opt: Option[A], f: (A) -> Option[B]) -> Option[B] {
    match opt {
        Option::Some(v) => f(v),
        Option::None => Option::None,
    }
}

fn main() {
    let x: Option[int32] = Option::Some(42);
    let y = map_option(x, |v| v + 1);
    let z = flat_map(y, |v| {
        if v > 40 {
            Option::Some(v * 2)
        } else {
            Option::None
        }
    });
    match z {
        Option::Some(v) => println(v.to_string()),
        Option::None => println("none"),
    };
}
