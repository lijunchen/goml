package main;

fn main() {
    let a: uint8 = 10 + 20;
    string_println(uint8_to_string(a));
    
    let b: float32 = 1.5 * 2.0;
    string_println(float32_to_string(b));
    
    let c: int64 = 100 - 50;
    string_println(int64_to_string(c));
    
    let d: uint16 = 1000 / 10;
    string_println(uint16_to_string(d));
}
