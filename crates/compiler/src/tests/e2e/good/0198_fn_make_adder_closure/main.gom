fn make_adder(x: int32) -> (int32) -> int32 {
    |y| x + y
}

fn compose[A, B, C](f: (B) -> C, g: (A) -> B) -> (A) -> C {
    |x| f(g(x))
}

fn main() {
    let add5 = make_adder(5);
    println(int32_to_string(add5(10)));
    
    let add10 = compose(make_adder(3), make_adder(7));
    println(int32_to_string(add10(0)));
}
