trait Action {
    fn execute(Self) -> string;
}

struct SimpleAction {
    label: string,
}

impl Action for SimpleAction {
    fn execute(self: SimpleAction) -> string {
        self.label
    }
}

fn make_simple(label: string) -> SimpleAction {
    SimpleAction { label: label }
}

fn main() {
    let actions: Vec[dyn Action] = vec_new();
    let actions = vec_push(actions, make_simple("hello"));
    let actions = vec_push(actions, make_simple("world"));
    println(Action::execute(vec_get(actions, 0)));
    println(Action::execute(vec_get(actions, 1)));
}
