trait Action {
    fn execute(Self) -> string;
}

struct SimpleAction {
    label: string,
}

impl Action for SimpleAction {
    fn execute(self: SimpleAction) -> string {
        self.label
    }
}

fn make_simple(label: string) -> SimpleAction {
    SimpleAction { label: label }
}

fn main() {
    let actions: Vec[dyn Action] = Vec::new();
    let actions = actions.push(make_simple("hello"));
    let actions = actions.push(make_simple("world"));
    println(Action::execute(actions[0]));
    println(Action::execute(actions[1]));
}
