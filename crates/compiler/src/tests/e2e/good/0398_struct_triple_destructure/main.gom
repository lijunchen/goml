struct Triple { a: int32, b: int32, c: int32 }

fn main() {
    let Triple { a, b, c } = Triple { a: 1, b: 2, c: 3 };
    println(a.to_string() + " " + b.to_string() + " " + c.to_string());
    
    let (x, (y, z)) = (10, (20, 30));
    println(x.to_string() + " " + y.to_string() + " " + z.to_string());
}
