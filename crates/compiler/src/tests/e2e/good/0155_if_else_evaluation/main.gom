fn main() {
    let x = if true { 1 } else { 2 };
    let y = if false { "hello" } else { "world" };
    println((x).to_string());
    println(y);
    
    let z = if true {
        if false { 10 } else { 20 }
    } else {
        30
    };
    println((z).to_string());
    
    let a: int64 = if true { 100 } else { 200 };
    println((a).to_string());
}
