
fn main() {
    let x = if true { 1 } else { 2 };
    let y = if false { "hello" } else { "world" };
    string_println(int32_to_string(x));
    string_println(y);
    
    let z = if true {
        if false { 10 } else { 20 }
    } else {
        30
    };
    string_println(int32_to_string(z));
    
    let a: int64 = if true { 100 } else { 200 };
    string_println(int64_to_string(a));
}
