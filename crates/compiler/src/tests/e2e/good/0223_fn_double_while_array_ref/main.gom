fn double(x: int32) -> int32 { x * 2 }
fn triple(x: int32) -> int32 { x * 3 }
fn negate(x: int32) -> int32 { 0 - x }

fn main() {
    let fns: [(int32) -> int32; 3] = [double, triple, negate];
    let i = ref(0);
    while ref_get(i) < 3 {
        let f = array_get(fns, ref_get(i));
        string_println(int32_to_string(f(10)));
        ref_set(i, ref_get(i) + 1);
    };
}
