struct Point { x: int32, y: int32 }

fn main() {
    let origin = Point { x: 0, y: 0 };
    
    let distance = |p: Point| {
        let dx = p.x - origin.x;
        let dy = p.y - origin.y;
        dx * dx + dy * dy
    };
    
    println(distance(Point { x: 3, y: 4 }).to_string());
    println(distance(Point { x: 5, y: 12 }).to_string());
}
