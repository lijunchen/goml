fn swap[T](arr: [T; 3], i: int32, j: int32) -> [T; 3] {
    let tmp = array_get(arr, i);
    let arr = array_set(arr, i, array_get(arr, j));
    array_set(arr, j, tmp)
}

fn main() {
    let arr = [10, 20, 30];
    let arr = array_set(arr, 0, array_get(arr, 2));
    let arr = array_set(arr, 2, 10);
    println(array_get(arr, 0));
    println(array_get(arr, 1));
    println(array_get(arr, 2));

    let arr2 = [100, 200, 300];
    let arr2 = swap(arr2, 0, 2);
    println(array_get(arr2, 0));
    println(array_get(arr2, 1));
    println(array_get(arr2, 2));
}
