fn main() {
    let m: HashMap[string, int32] = HashMap::new();
    m.set("a", 1);
    m.set("b", 2);
    m.set("c", 3);
    
    println(m.len().to_string());
    
    if m.contains("a") {
        println("has a");
    } else {
        println("no a");
    };
    
    if m.contains("d") {
        println("has d");
    } else {
        println("no d");
    };
}
