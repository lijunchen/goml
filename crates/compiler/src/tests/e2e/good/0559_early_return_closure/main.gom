fn apply_twice(f: (int32) -> int32, x: int32) -> int32 {
    f(f(x))
}

fn main() {
    let f = |n: int32| {
        if n > 3i32 {
            return n
        } else {
            ()
        };
        n + 10i32
    };

    println((f(2i32)).to_string());
    println((f(5i32)).to_string());
    println((apply_twice(f, 2i32)).to_string());
}
