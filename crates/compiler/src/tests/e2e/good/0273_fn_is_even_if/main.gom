fn is_even(n: int32) -> bool {
    if n == 0 { true }
    else { is_odd(n - 1) }
}

fn is_odd(n: int32) -> bool {
    if n == 0 { false }
    else { is_even(n - 1) }
}

fn main() {
    println(is_even(10).to_string());
    println(is_odd(10).to_string());
    println(is_even(7).to_string());
    println(is_odd(7).to_string());
}
