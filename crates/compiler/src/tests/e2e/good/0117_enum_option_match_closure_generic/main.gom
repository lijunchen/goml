enum Option[T] {
    Some(T),
    None,
}

fn map[A, B](opt: Option[A], f: (A) -> B) -> Option[B] {
    match opt {
        Option::Some(x) => Option::Some(f(x)),
        Option::None => Option::None,
    }
}

fn unwrap_or[T](opt: Option[T], default: T) -> T {
    match opt {
        Option::Some(x) => x,
        Option::None => default,
    }
}

fn main() {
    let x: Option[int32] = Option::Some(42);
    let y = map(x, |n| n * 2);
    let result = unwrap_or(y, 0);
    string_println(int32_to_string(result));
    
    let z: Option[int32] = Option::None;
    let w = map(z, |n| n + 1);
    let result2 = unwrap_or(w, -1);
    string_println(int32_to_string(result2));
}
