
trait Mappable {
    fn map_val(Self, (int32) -> int32) -> Self;
}

struct Wrapper {
    val: int32,
}

impl Mappable for Wrapper {
    fn map_val(self: Wrapper, f: (int32) -> int32) -> Wrapper {
        Wrapper { val: f(self.val) }
    }
}

fn main() {
    let w = Wrapper { val: 10 };
    let w2 = Mappable::map_val(w, |x: int32| x * 2);
    string_println(int32_to_string(w2.val));
}
