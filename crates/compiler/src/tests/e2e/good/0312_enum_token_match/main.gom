enum Token {
    Plus,
    Minus,
    Num(int32),
    Ident(string),
}

fn token_to_string(t: Token) -> string {
    match t {
        Token::Plus => "+",
        Token::Minus => "-",
        Token::Num(n) => (n).to_string(),
        Token::Ident(s) => s,
    }
}

fn main() {
    println(token_to_string(Token::Plus));
    println(token_to_string(Token::Num(42)));
    println(token_to_string(Token::Ident("foo")));
    println(token_to_string(Token::Minus));
}
