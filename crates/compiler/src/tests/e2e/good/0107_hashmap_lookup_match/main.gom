fn main() {
    let m = HashMap::new();
    m.set("a", 1);
    m.set("b", 2);
    m.set("c", 3);
    
    match m.get("b") {
        Option::Some(v) => println((v).to_string()),
        Option::None => println("not found"),
    };
    
    match m.get("z") {
        Option::Some(v) => println((v).to_string()),
        Option::None => println("not found"),
    };
    
    println((m.len()).to_string());
    println((m.contains("a")).to_string());
    println((m.contains("z")).to_string());
}
