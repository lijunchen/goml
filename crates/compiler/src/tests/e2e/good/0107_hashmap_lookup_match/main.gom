fn main() {
    let m = hashmap_new();
    hashmap_set(m, "a", 1);
    hashmap_set(m, "b", 2);
    hashmap_set(m, "c", 3);
    
    match hashmap_get(m, "b") {
        Option::Some(v) => println(int32_to_string(v)),
        Option::None => println("not found"),
    };
    
    match hashmap_get(m, "z") {
        Option::Some(v) => println(int32_to_string(v)),
        Option::None => println("not found"),
    };
    
    println(int32_to_string(hashmap_len(m)));
    println(bool_to_string(hashmap_contains(m, "a")));
    println(bool_to_string(hashmap_contains(m, "z")));
}
