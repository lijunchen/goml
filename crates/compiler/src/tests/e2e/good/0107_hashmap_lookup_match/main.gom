fn main() {
    let m = HashMap::new();
    m.set("a", 1);
    m.set("b", 2);
    m.set("c", 3);
    
    match m.get("b") {
        Option::Some(v) => println(int32_to_string(v)),
        Option::None => println("not found"),
    };
    
    match m.get("z") {
        Option::Some(v) => println(int32_to_string(v)),
        Option::None => println("not found"),
    };
    
    println(int32_to_string(m.len()));
    println(bool_to_string(m.contains("a")));
    println(bool_to_string(m.contains("z")));
}
