fn curry_add(a: int32) -> (int32) -> int32 {
    |b| a + b
}

fn apply_twice(f: (int32) -> int32, x: int32) -> int32 {
    f(f(x))
}

fn main() {
    let add5 = curry_add(5);
    println(add5(3).to_string());
    println(apply_twice(add5, 10).to_string());
    println(apply_twice(curry_add(100), 0).to_string());
}
