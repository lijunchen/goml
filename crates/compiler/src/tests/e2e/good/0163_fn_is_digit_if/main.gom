package main;

fn is_digit(c: char) -> bool {
    c >= '0' && c <= '9'
}

fn main() {
    let a = 'A';
    let z = '0';
    string_println(a.to_string());
    string_println(z.to_string());
    if is_digit('5') {
        string_println("5 is digit");
    } else {
        string_println("5 is not digit");
    };
    if is_digit('x') {
        string_println("x is digit");
    } else {
        string_println("x is not digit");
    };
}
