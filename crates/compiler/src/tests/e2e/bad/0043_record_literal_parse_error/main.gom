package main;

struct Pair[A, B] {
    first: A,
    second: B,
}

fn main() {
    let p: Pair[uint8, uint8] = Pair {
        first: {
            let x: uint8 = 10;
            let y: uint8 = 20;
            x + y
        },
        second: 5,
    };
    string_println(uint8_to_string(p.first));
    string_println(uint8_to_string(p.second));
}
