pub struct Cmd {
    raw: RawCmd,
}

pub fn look_path(file: string) -> Result[string, GoError] {
    raw_look_path(file)
}

pub fn has_path(file: string) -> Result[bool, GoError] {
    let path = look_path(file)?;
    Result::Ok(path != "")
}

pub fn command(name: string, args: Vec[string]) -> Cmd {
    Cmd {
        raw: raw_command(name, slice(args, 0, vec_len(args))),
    }
}

pub fn command_context(name: string, args: Vec[string]) -> Cmd {
    Cmd {
        raw: raw_command_context(raw_background(), name, slice(args, 0, vec_len(args))),
    }
}

pub fn path(cmd: Cmd) -> string {
    raw_cmd_path(cmd.raw)
}

pub fn set_path(cmd: Cmd, path: string) -> unit {
    raw_cmd_set_path(cmd.raw, path)
}

pub fn args(cmd: Cmd) -> Vec[string] {
    raw_cmd_args(cmd.raw)
}

pub fn set_args(cmd: Cmd, args: Vec[string]) -> unit {
    raw_cmd_set_args(cmd.raw, args)
}

pub fn dir(cmd: Cmd) -> string {
    raw_cmd_dir(cmd.raw)
}

pub fn set_dir(cmd: Cmd, dir: string) -> unit {
    raw_cmd_set_dir(cmd.raw, dir)
}

pub fn env(cmd: Cmd) -> Vec[string] {
    raw_cmd_env(cmd.raw)
}

pub fn set_env(cmd: Cmd, env: Vec[string]) -> unit {
    raw_cmd_set_env(cmd.raw, env)
}

pub fn environ(cmd: Cmd) -> Vec[string] {
    raw_cmd_environ(cmd.raw)
}

pub fn err(cmd: Cmd) -> GoError {
    raw_cmd_err(cmd.raw)
}

pub fn set_err(cmd: Cmd, err: GoError) -> unit {
    raw_cmd_set_err(cmd.raw, err)
}

pub fn stdin(cmd: Cmd) -> RawReader {
    raw_cmd_stdin(cmd.raw)
}

pub fn stdout(cmd: Cmd) -> RawWriter {
    raw_cmd_stdout(cmd.raw)
}

pub fn stderr(cmd: Cmd) -> RawWriter {
    raw_cmd_stderr(cmd.raw)
}

pub fn extra_files(cmd: Cmd) -> Vec[RawFile] {
    raw_cmd_extra_files(cmd.raw)
}

pub fn set_extra_files(cmd: Cmd, files: Vec[RawFile]) -> unit {
    raw_cmd_set_extra_files(cmd.raw, files)
}

pub fn sys_proc_attr(cmd: Cmd) -> RawSysProcAttr {
    raw_cmd_sys_proc_attr(cmd.raw)
}

pub fn set_sys_proc_attr(cmd: Cmd, attr: RawSysProcAttr) -> unit {
    raw_cmd_set_sys_proc_attr(cmd.raw, attr)
}

pub fn process(cmd: Cmd) -> RawProcess {
    raw_cmd_process(cmd.raw)
}

pub fn set_process(cmd: Cmd, process: RawProcess) -> unit {
    raw_cmd_set_process(cmd.raw, process)
}

pub fn process_state(cmd: Cmd) -> RawProcessState {
    raw_cmd_process_state(cmd.raw)
}

pub fn set_process_state(cmd: Cmd, state: RawProcessState) -> unit {
    raw_cmd_set_process_state(cmd.raw, state)
}

pub fn cancel(cmd: Cmd) -> RawCancel {
    raw_cmd_cancel(cmd.raw)
}

pub fn set_cancel(cmd: Cmd, cancel: RawCancel) -> unit {
    raw_cmd_set_cancel(cmd.raw, cancel)
}

pub fn wait_delay(cmd: Cmd) -> RawDuration {
    raw_cmd_wait_delay(cmd.raw)
}

pub fn set_wait_delay(cmd: Cmd, delay: RawDuration) -> unit {
    raw_cmd_set_wait_delay(cmd.raw, delay)
}

pub fn command_string(cmd: Cmd) -> string {
    raw_cmd_string(cmd.raw)
}

pub fn set_stdin_text(cmd: Cmd, text: string) -> unit {
    raw_cmd_set_stdin(cmd.raw, raw_string_reader(text))
}

pub fn set_stdout_discard(cmd: Cmd) -> unit {
    raw_cmd_set_stdout(cmd.raw, raw_discard())
}

pub fn set_stderr_discard(cmd: Cmd) -> unit {
    raw_cmd_set_stderr(cmd.raw, raw_discard())
}

pub fn combined_output_text(cmd: Cmd) -> Result[string, GoError] {
    let bytes = raw_cmd_combined_output(cmd.raw)?;
    Result::Ok(crate::common::string_of_bytes(bytes))
}

pub fn output_text(cmd: Cmd) -> Result[string, GoError] {
    let bytes = raw_cmd_output(cmd.raw)?;
    Result::Ok(crate::common::string_of_bytes(bytes))
}

pub fn run(cmd: Cmd) -> Result[unit, GoError] {
    raw_cmd_run(cmd.raw)
}

pub fn start(cmd: Cmd) -> Result[unit, GoError] {
    raw_cmd_start(cmd.raw)
}

pub fn wait(cmd: Cmd) -> Result[unit, GoError] {
    raw_cmd_wait(cmd.raw)
}

pub fn stdout_pipe_text(cmd: Cmd) -> Result[string, GoError] {
    let pipe = raw_cmd_stdout_pipe(cmd.raw)?;
    start(cmd)?;
    let bytes = raw_read_all_closer(pipe)?;
    raw_read_closer_close(pipe)?;
    wait(cmd)?;
    Result::Ok(crate::common::string_of_bytes(bytes))
}

pub fn stderr_pipe_text(cmd: Cmd) -> Result[string, GoError] {
    let pipe = raw_cmd_stderr_pipe(cmd.raw)?;
    start(cmd)?;
    let bytes = raw_read_all_closer(pipe)?;
    raw_read_closer_close(pipe)?;
    wait(cmd)?;
    Result::Ok(crate::common::string_of_bytes(bytes))
}

pub fn cat_stdin_text(text: string) -> Result[string, GoError] {
    let args: Vec[string] = vec_new();
    let args = vec_push(args, "-c");
    let args = vec_push(args, "cat");
    let cmd = command_context("sh", args);
    let stdout = raw_cmd_stdout_pipe(cmd.raw)?;
    let stdin = raw_cmd_stdin_pipe(cmd.raw)?;
    start(cmd)?;
    let _ = raw_write_closer_write_string(stdin, text)?;
    raw_write_closer_close(stdin)?;
    let bytes = raw_read_all_closer(stdout)?;
    raw_read_closer_close(stdout)?;
    wait(cmd)?;
    Result::Ok(crate::common::string_of_bytes(bytes))
}

pub fn exec_error_name(err: RawExecError) -> string {
    raw_exec_error_name(err)
}

pub fn exec_error_err(err: RawExecError) -> GoError {
    raw_exec_error_err(err)
}

pub fn exec_error_text(err: RawExecError) -> string {
    raw_exec_error_text(err)
}

pub fn exec_error_unwrap(err: RawExecError) -> Result[unit, GoError] {
    raw_exec_error_unwrap(err)
}

pub fn exit_error_text(err: RawExitError) -> string {
    raw_exit_error_text(err)
}

pub fn exit_error_stderr(err: RawExitError) -> Vec[uint8] {
    raw_exit_error_stderr(err)
}

pub fn exit_error_process_state(err: RawExitError) -> RawProcessState {
    raw_exit_error_process_state(err)
}
