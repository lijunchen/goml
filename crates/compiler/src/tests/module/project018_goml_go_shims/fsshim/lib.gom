struct FS {
    raw: RawFS,
}

struct File {
    raw: RawFile,
}

struct DirEntry {
    raw: RawDirEntry,
}

struct FileInfo {
    raw: RawFileInfo,
}

fn stop_at_fs_data(path: string, entry: RawDirEntry, err: GoError) -> Result[unit, GoError] {
    let _ = entry;
    let _ = err;
    if path == "fs_data.txt" {
        Result::Err(raw_eof())
    } else {
        Result::Ok(())
    }
}

fn dir_fs(dir: string) -> FS {
    FS { raw: raw_dir_fs(dir) }
}

fn valid_path(name: string) -> bool {
    raw_valid_path(name)
}

fn err_invalid() -> GoError {
    raw_err_invalid()
}

fn skip_all() -> GoError {
    raw_skip_all()
}

fn skip_dir() -> GoError {
    raw_skip_dir()
}

fn mode_dir() -> RawFileMode {
    raw_mode_dir()
}

fn mode_symlink() -> RawFileMode {
    raw_mode_symlink()
}

fn mode_append() -> RawFileMode {
    raw_mode_append()
}

fn mode_exclusive() -> RawFileMode {
    raw_mode_exclusive()
}

fn mode_temporary() -> RawFileMode {
    raw_mode_temporary()
}

fn mode_device() -> RawFileMode {
    raw_mode_device()
}

fn mode_named_pipe() -> RawFileMode {
    raw_mode_named_pipe()
}

fn mode_socket() -> RawFileMode {
    raw_mode_socket()
}

fn mode_setuid() -> RawFileMode {
    raw_mode_setuid()
}

fn mode_setgid() -> RawFileMode {
    raw_mode_setgid()
}

fn mode_char_device() -> RawFileMode {
    raw_mode_char_device()
}

fn mode_sticky() -> RawFileMode {
    raw_mode_sticky()
}

fn mode_irregular() -> RawFileMode {
    raw_mode_irregular()
}

fn mode_type_bits() -> RawFileMode {
    raw_mode_type()
}

fn mode_perm_bits() -> RawFileMode {
    raw_mode_perm()
}

fn mode_bits(mode: RawFileMode) -> uint32 {
    raw_file_mode_bits(mode)
}

fn sub(fs: FS, dir: string) -> Result[FS, GoError] {
    let raw = raw_sub(fs.raw, dir)?;
    let next = FS { raw: raw };
    Result::Ok(next)
}

fn write_text_file(path: string, text: string) -> Result[unit, GoError] {
    raw_write_file(path, common::bytes_of_string(text), raw_file_mode(420u32))
}

fn read_link(fs: FS, name: string) -> Result[string, GoError] {
    raw_read_link(fs.raw, name)
}

fn read_text(fs: FS, name: string) -> Result[string, GoError] {
    let bytes = raw_read_file(fs.raw, name)?;
    Result::Ok(common::string_of_bytes(bytes))
}

fn wrap_file(file: RawFile) -> File {
    File { raw: file }
}

fn wrap_dir_entry(entry: RawDirEntry) -> DirEntry {
    DirEntry { raw: entry }
}

fn wrap_file_info(info: RawFileInfo) -> FileInfo {
    FileInfo { raw: info }
}

fn open(fs: FS, name: string) -> Result[File, GoError] {
    let file = raw_open(fs.raw, name)?;
    Result::Ok(wrap_file(file))
}

fn read_dir(fs: FS, name: string) -> Result[Vec[DirEntry], GoError] {
    let raw_entries = raw_read_dir(fs.raw, name)?;
    let entries = ref(vec_new());
    let index = ref(0);
    while ref_get(index) < vec_len(raw_entries) {
        let entry = vec_get(raw_entries, ref_get(index));
        ref_set(entries, vec_push(ref_get(entries), wrap_dir_entry(entry)));
        ref_set(index, ref_get(index) + 1);
    };
    Result::Ok(ref_get(entries))
}

fn read_dir_names(fs: FS, name: string) -> Result[Vec[string], GoError] {
    let entries = read_dir(fs, name)?;
    let names: Ref[Vec[string]] = ref(vec_new());
    let index = ref(0);
    while ref_get(index) < vec_len(entries) {
        let entry = vec_get(entries, ref_get(index));
        let _ = entry.is_dir();
        ref_set(names, vec_push(ref_get(names), entry.name()));
        ref_set(index, ref_get(index) + 1);
    };
    Result::Ok(ref_get(names))
}

fn glob(fs: FS, pattern: string) -> Result[Vec[string], GoError] {
    raw_glob(fs.raw, pattern)
}

fn stat(fs: FS, name: string) -> Result[FileInfo, GoError] {
    let info = raw_stat(fs.raw, name)?;
    Result::Ok(wrap_file_info(info))
}

fn lstat(fs: FS, name: string) -> Result[FileInfo, GoError] {
    let info = raw_lstat(fs.raw, name)?;
    Result::Ok(wrap_file_info(info))
}

fn format_dir_entry(entry: DirEntry) -> string {
    raw_format_dir_entry(entry.raw)
}

fn dir_entry_name(entry: DirEntry) -> string {
    raw_dir_entry_name(entry.raw)
}

fn dir_entry_is_dir(entry: DirEntry) -> bool {
    raw_dir_entry_is_dir(entry.raw)
}

fn dir_entry_type(entry: DirEntry) -> RawFileMode {
    raw_dir_entry_type(entry.raw)
}

fn dir_entry_info(entry: DirEntry) -> Result[FileInfo, GoError] {
    let info = raw_dir_entry_info(entry.raw)?;
    Result::Ok(wrap_file_info(info))
}

fn file_info_to_dir_entry(info: FileInfo) -> DirEntry {
    wrap_dir_entry(raw_file_info_to_dir_entry(info.raw))
}

fn format_file_info(info: FileInfo) -> string {
    raw_format_file_info(info.raw)
}

fn file_info_name(info: FileInfo) -> string {
    raw_file_info_name(info.raw)
}

fn file_info_size(info: FileInfo) -> int64 {
    raw_file_info_size(info.raw)
}

fn file_info_mode(info: FileInfo) -> RawFileMode {
    raw_file_info_mode(info.raw)
}

fn file_info_is_dir(info: FileInfo) -> bool {
    raw_file_info_is_dir(info.raw)
}

fn file_info_mod_time(info: FileInfo) -> RawTime {
    raw_file_info_mod_time(info.raw)
}

fn file_info_mod_time_string(info: FileInfo) -> string {
    raw_time_string(file_info_mod_time(info))
}

fn file_info_sys(info: FileInfo) -> RawAny {
    raw_file_info_sys(info.raw)
}

fn mode_is_dir(mode: RawFileMode) -> bool {
    raw_file_mode_is_dir(mode)
}

fn mode_is_regular(mode: RawFileMode) -> bool {
    raw_file_mode_is_regular(mode)
}

fn mode_perm(mode: RawFileMode) -> RawFileMode {
    raw_file_mode_perm(mode)
}

fn mode_string(mode: RawFileMode) -> string {
    raw_file_mode_string(mode)
}

fn mode_type(mode: RawFileMode) -> RawFileMode {
    raw_file_mode_type(mode)
}

fn file_stat(file: File) -> Result[FileInfo, GoError] {
    let info = raw_file_stat(file.raw)?;
    Result::Ok(wrap_file_info(info))
}

fn file_read(file: File, buf: Vec[uint8]) -> Result[(Vec[uint8], int32), GoError] {
    let count = raw_file_read(file.raw, buf)?;
    Result::Ok((buf, raw_int32(count)))
}

fn file_close(file: File) -> Result[unit, GoError] {
    raw_file_close(file.raw)
}

fn stat_summary(fs: FS, name: string) -> Result[string, GoError] {
    let info = stat(fs, name)?;
    let mode = mode_bits(info.mode());
    let entry = file_info_to_dir_entry(info);
    let summary = format_dir_entry(entry);
    Result::Ok(summary + "|" + uint32_to_string(mode))
}

fn has_name(fs: FS, name: string) -> Result[bool, GoError] {
    let names: Vec[string] = read_dir_names(fs, ".")?;
    let index = ref(0);
    let found = ref(false);
    while ref_get(index) < vec_len(names) {
        if vec_get(names, ref_get(index)) == name {
            ref_set(found, true);
        } else {
            ()
        };
        ref_set(index, ref_get(index) + 1);
    };
    Result::Ok(ref_get(found))
}

fn walk_has_fs_data(fs: FS) -> Result[bool, GoError] {
    match raw_walk_dir(fs.raw, ".", stop_at_fs_data) {
        Result::Ok(_) => Result::Ok(false),
        Result::Err(err) => {
            if err.to_string() == raw_eof().to_string() {
                Result::Ok(true)
            } else {
                Result::Err(err)
            }
        }
    }
}

impl FS {
    fn open(self: FS, name: string) -> Result[File, GoError] {
        open(self, name)
    }

    fn read_link(self: FS, name: string) -> Result[string, GoError] {
        read_link(self, name)
    }

    fn read_text(self: FS, name: string) -> Result[string, GoError] {
        read_text(self, name)
    }

    fn read_dir(self: FS, name: string) -> Result[Vec[DirEntry], GoError] {
        read_dir(self, name)
    }

    fn sub(self: FS, dir: string) -> Result[FS, GoError] {
        sub(self, dir)
    }

    fn read_dir_names(self: FS, name: string) -> Result[Vec[string], GoError] {
        read_dir_names(self, name)
    }

    fn glob(self: FS, pattern: string) -> Result[Vec[string], GoError] {
        glob(self, pattern)
    }

    fn stat(self: FS, name: string) -> Result[FileInfo, GoError] {
        stat(self, name)
    }

    fn lstat(self: FS, name: string) -> Result[FileInfo, GoError] {
        lstat(self, name)
    }

    fn stat_summary(self: FS, name: string) -> Result[string, GoError] {
        stat_summary(self, name)
    }

    fn has_name(self: FS, name: string) -> Result[bool, GoError] {
        has_name(self, name)
    }

    fn walk_has_fs_data(self: FS) -> Result[bool, GoError] {
        walk_has_fs_data(self)
    }
}

impl File {
    fn stat(self: File) -> Result[FileInfo, GoError] {
        file_stat(self)
    }

    fn read(self: File, buf: Vec[uint8]) -> Result[(Vec[uint8], int32), GoError] {
        file_read(self, buf)
    }

    fn close(self: File) -> Result[unit, GoError] {
        file_close(self)
    }
}

impl DirEntry {
    fn name(self: DirEntry) -> string {
        dir_entry_name(self)
    }

    fn is_dir(self: DirEntry) -> bool {
        dir_entry_is_dir(self)
    }

    fn type_(self: DirEntry) -> RawFileMode {
        dir_entry_type(self)
    }

    fn info(self: DirEntry) -> Result[FileInfo, GoError] {
        dir_entry_info(self)
    }

    fn format(self: DirEntry) -> string {
        format_dir_entry(self)
    }
}

impl FileInfo {
    fn name(self: FileInfo) -> string {
        file_info_name(self)
    }

    fn size(self: FileInfo) -> int64 {
        file_info_size(self)
    }

    fn mode(self: FileInfo) -> RawFileMode {
        file_info_mode(self)
    }

    fn is_dir(self: FileInfo) -> bool {
        file_info_is_dir(self)
    }

    fn format(self: FileInfo) -> string {
        format_file_info(self)
    }

    fn to_dir_entry(self: FileInfo) -> DirEntry {
        file_info_to_dir_entry(self)
    }
}
