package main;
use bufioshim;
use common;
use execshim;
use fsshim;
use ioshim;

fn show(res: Result[string, GoError]) -> string {
    match res {
        Result::Ok(text) => text,
        Result::Err(err) => "err=" + err.to_string(),
    }
}

fn demo_io() -> Result[string, GoError] {
    let copied_buf = ioshim::copy_buffer_to_discard("copy-buffer", common::bytes_of_string("buf"))?;
    let tee = ioshim::tee_read_all_text("tee-ok")?;
    let limited = ioshim::read_limited_text("limit-ok", 5i64)?;
    let (byte_reader, byte_writer) = ioshim::pipe();
    go || {
        match ioshim::pipe_write_bytes(byte_writer, common::bytes_of_string("xy")) {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
        match ioshim::close_pipe_writer_eof(byte_writer) {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
    };
    let byte_text = ioshim::pipe_read_text(byte_reader, 2)?;
    let out = limited;
    let out = out + "|" + int64_to_string(copied_buf);
    let out = out + "|" + tee;
    let out = out + "|" + byte_text;
    Result::Ok(out)
}

fn demo_exec() -> Result[string, GoError] {
    let args: Vec[string] = vec_new();
    let args = vec_push(args, "-c");
    let args = vec_push(args, "printf exec-ok");
    let cmd = execshim::command("sh", args);
    execshim::set_path(cmd, execshim::path(cmd));
    execshim::set_args(cmd, execshim::args(cmd));
    execshim::set_dir(cmd, ".");
    let dir = execshim::dir(cmd);
    let arg_count = int32_to_string(vec_len(execshim::args(cmd)));
    let env = vec_push(execshim::env(cmd), "GOML_SHIM=1");
    execshim::set_env(cmd, env);
    let env_flag = if vec_len(execshim::environ(cmd)) > 0 { "env" } else { "noenv" };
    let desc_flag = if execshim::command_string(cmd) != "" { "desc" } else { "nodesc" };
    let out = execshim::output_text(cmd)?;
    let cat = execshim::cat_stdin_text("stdin-ok")?;
    let result = dir;
    let result = result + "|" + arg_count;
    let result = result + "|" + env_flag;
    let result = result + "|" + desc_flag;
    let result = result + "|" + out;
    let result = result + "|" + cat;
    Result::Ok(result)
}

fn demo_fs() -> Result[string, GoError] {
    fsshim::write_text_file("fs_data.txt", "fs-ok")?;
    let fs = fsshim::dir_fs(".");
    let text = fsshim::read_text(fs, "fs_data.txt")?;
    let file = fsshim::open(fs, "fs_data.txt")?;
    let (buf, read_count) = fsshim::file_read(file, common::bytes_of_string("....."))?;
    let info = fsshim::file_stat(file)?;
    fsshim::file_close(file)?;
    let mode = fsshim::file_info_mode(info);
    let kind = if fsshim::mode_is_regular(mode) {
        "regular"
    } else {
        "other"
    };
    let out = text;
    let out = out + "|" + common::string_of_bytes(buf);
    let out = out + "|" + int32_to_string(read_count);
    let out = out + "|" + fsshim::file_info_name(info);
    let out = out + "|" + kind;
    let out = out + "|" + uint32_to_string(fsshim::mode_bits(fsshim::mode_perm(mode)));
    let out = out + "|" + fsshim::mode_string(fsshim::mode_type(mode));
    Result::Ok(out)
}

fn demo_bufio() -> Result[string, GoError] {
    let reader = bufioshim::from_text("abc");
    let (buf, count) = bufioshim::read(reader, common::bytes_of_string("..."))?;
    let text = common::string_of_bytes(buf);
    let (line, prefix) = bufioshim::read_line(bufioshim::from_text("first\n"))?;
    let state = if prefix { "prefix" } else { "full" };
    let (rune, width) = bufioshim::read_rune(bufioshim::from_text("好呀"))?;
    let words = bufioshim::scan_words_csv("alpha beta")?;
    let read_writer = bufioshim::read_writer_from_text("left/right");
    let prefix_text = bufioshim::read_writer_read_string(read_writer, 47u8)?;
    let _ = bufioshim::read_writer_write_text(read_writer, "!")?;
    bufioshim::read_writer_flush(read_writer)?;
    let rw_text = bufioshim::read_writer_contents(read_writer);
    let out = state + "|" + line;
    let out = out + "|" + text;
    let out = out + "|" + int32_to_string(count);
    let out = out + "|" + rune.to_string();
    let out = out + "|" + int32_to_string(width);
    let out = out + "|" + words;
    let out = out + "|" + prefix_text;
    let out = out + "|" + rw_text;
    Result::Ok(out)
}

fn main() -> unit {
    println(show(demo_io()));
    println(show(demo_exec()));
    println(show(demo_fs()));
    println(show(demo_bufio()));
}
