package main;
use bufioshim;
use execshim;
use fsshim;
use ioshim;

fn show(res: Result[string, GoError]) -> string {
    match res {
        Result::Ok(text) => text,
        Result::Err(err) => "err=" + err.to_string(),
    }
}

fn demo_io() -> Result[string, GoError] {
    let (reader, writer) = ioshim::pipe();
    go || {
        match writer.write_text("pipe-ok") {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
        match writer.close() {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
    };
    match reader.read_all_text() {
        Result::Ok(text) => Result::Ok(text),
        Result::Err(err) => Result::Err(err),
    }
}

fn demo_exec() -> Result[string, GoError] {
    let args: Vec[string] = vec_new();
    let args = vec_push(args, "-c");
    let args = vec_push(args, "printf exec-ok");
    let cmd = execshim::command("sh", args);
    cmd.set_dir(".");
    let dir = cmd.dir();
    let out = cmd.combined_output_text()?;
    Result::Ok(dir + "|" + out)
}

fn demo_fs() -> Result[string, GoError] {
    fsshim::write_text_file("fs_data.txt", "fs-ok")?;
    let fs = fsshim::dir_fs(".");
    let text = fs.read_text("fs_data.txt")?;
    let status = if fsshim::valid_path("fs_data.txt") {
        "valid"
    } else {
        "invalid"
    };
    Result::Ok(status + "|" + text)
}

fn demo_bufio() -> Result[string, GoError] {
    let reader = bufioshim::from_text("first\nsecond\n");
    let (line, prefix) = reader.read_line()?;
    let state = if prefix { "prefix" } else { "full" };
    Result::Ok(state + "|" + line)
}

fn main() -> unit {
    println(show(demo_io()));
    println(show(demo_exec()));
    println(show(demo_fs()));
    println(show(demo_bufio()));
}
