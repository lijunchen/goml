mod bufioshim;
mod common;
mod execshim;
mod fsshim;
mod ioshim;
mod stringsshim;

fn show(res: Result[string, GoError]) -> string {
    match res {
        Result::Ok(text) => text,
        Result::Err(err) => "err=" + err.to_string(),
    }
}

fn demo_io() -> Result[string, GoError] {
    let copied_buf = crate::ioshim::copy_buffer_to_discard("copy-buffer", crate::common::bytes_of_string("buf"))?;
    let tee = crate::ioshim::tee_read_all_text("tee-ok")?;
    let limited = crate::ioshim::read_limited_text("limit-ok", 5i64)?;
    let (byte_reader, byte_writer) = crate::ioshim::pipe();
    go || {
        match crate::ioshim::pipe_write_bytes(byte_writer, crate::common::bytes_of_string("xy")) {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
        match crate::ioshim::close_pipe_writer_eof(byte_writer) {
            Result::Ok(_) => (),
            Result::Err(_) => (),
        };
    };
    let byte_text = crate::ioshim::pipe_read_text(byte_reader, 2)?;
    let out = limited;
    let out = out + "|" + (copied_buf).to_string();
    let out = out + "|" + tee;
    let out = out + "|" + byte_text;
    Result::Ok(out)
}

fn demo_exec() -> Result[string, GoError] {
    let args: Vec[string] = Vec::new();
    let args = args.push("-c");
    let args = args.push("printf exec-ok");
    let cmd = crate::execshim::command("sh", args);
    crate::execshim::set_path(cmd, crate::execshim::path(cmd));
    crate::execshim::set_args(cmd, crate::execshim::args(cmd));
    crate::execshim::set_dir(cmd, ".");
    let dir = crate::execshim::dir(cmd);
    let arg_count = (crate::execshim::args(cmd).len()).to_string();
    let env = crate::execshim::env(cmd).push("GOML_SHIM=1");
    crate::execshim::set_env(cmd, env);
    let env_flag = if crate::execshim::environ(cmd).len() > 0 { "env" } else { "noenv" };
    let desc_flag = if crate::execshim::command_string(cmd) != "" { "desc" } else { "nodesc" };
    let out = crate::execshim::output_text(cmd)?;
    let cat = crate::execshim::cat_stdin_text("stdin-ok")?;
    let result = dir;
    let result = result + "|" + arg_count;
    let result = result + "|" + env_flag;
    let result = result + "|" + desc_flag;
    let result = result + "|" + out;
    let result = result + "|" + cat;
    Result::Ok(result)
}

fn demo_fs() -> Result[string, GoError] {
    crate::fsshim::write_text_file("fs_data.txt", "fs-ok")?;
    let fs = crate::fsshim::dir_fs(".");
    let text = crate::fsshim::read_text(fs, "fs_data.txt")?;
    let file = crate::fsshim::open(fs, "fs_data.txt")?;
    let (buf, read_count) = crate::fsshim::file_read(file, crate::common::bytes_of_string("....."))?;
    let info = crate::fsshim::file_stat(file)?;
    crate::fsshim::file_close(file)?;
    let mode = crate::fsshim::file_info_mode(info);
    let kind = if crate::fsshim::mode_is_regular(mode) {
        "regular"
    } else {
        "other"
    };
    let out = text;
    let out = out + "|" + crate::common::string_of_bytes(buf);
    let out = out + "|" + (read_count).to_string();
    let out = out + "|" + crate::fsshim::file_info_name(info);
    let out = out + "|" + kind;
    let out = out + "|" + (crate::fsshim::mode_bits(crate::fsshim::mode_perm(mode))).to_string();
    let out = out + "|" + crate::fsshim::mode_string(crate::fsshim::mode_type(mode));
    Result::Ok(out)
}

fn demo_bufio() -> Result[string, GoError] {
    let reader = crate::bufioshim::from_text("abc");
    let (buf, count) = crate::bufioshim::read(reader, crate::common::bytes_of_string("..."))?;
    let text = crate::common::string_of_bytes(buf);
    let (line, prefix) = crate::bufioshim::read_line(crate::bufioshim::from_text("first\n"))?;
    let state = if prefix { "prefix" } else { "full" };
    let (rune, width) = crate::bufioshim::read_rune(crate::bufioshim::from_text("好呀"))?;
    let words = crate::bufioshim::scan_words_csv("alpha beta")?;
    let read_writer = crate::bufioshim::read_writer_from_text("left/right");
    let prefix_text = crate::bufioshim::read_writer_read_string(read_writer, 47u8)?;
    let _ = crate::bufioshim::read_writer_write_text(read_writer, "!")?;
    crate::bufioshim::read_writer_flush(read_writer)?;
    let rw_text = crate::bufioshim::read_writer_contents(read_writer);
    let out = state + "|" + line;
    let out = out + "|" + text;
    let out = out + "|" + (count).to_string();
    let out = out + "|" + rune.to_string();
    let out = out + "|" + (width).to_string();
    let out = out + "|" + words;
    let out = out + "|" + prefix_text;
    let out = out + "|" + rw_text;
    Result::Ok(out)
}

fn demo_strings() -> Result[string, GoError] {
    let cmp = (crate::stringsshim::compare("a", "b")).to_string();
    let contains_flag = if crate::stringsshim::contains("goml", "ml") {
        "contains"
    } else {
        "miss"
    };
    let digit_flag = if crate::stringsshim::contains_func("go2", |r| r >= '0' && r <= '9') {
        "digit"
    } else {
        "nodigit"
    };
    let cut_text = match crate::stringsshim::cut("left=right", "=") {
        Option::Some((left, right)) => left + ":" + right,
        Option::None => "none",
    };
    let fields_text = crate::stringsshim::join(crate::stringsshim::fields_func("a1bb22c", |r| r >= '0' && r <= '9'), ",");
    let seq_text = crate::stringsshim::join(crate::stringsshim::collect_seq(crate::stringsshim::split_seq("u|v|w", "|")), ",");
    let split_after_text = crate::stringsshim::join(
        crate::stringsshim::collect_seq(crate::stringsshim::split_after_seq("x/y/z", "/")),
        ",",
    );
    let special_flag = if crate::stringsshim::to_upper_special(crate::stringsshim::turkish_case(), "i")
        != crate::stringsshim::to_upper("i")
    {
        "special"
    } else {
        "plain"
    };
    let builder = crate::stringsshim::new_builder();
    crate::stringsshim::builder_grow(builder, 8);
    let _ = crate::stringsshim::builder_write_string(builder, "go")?;
    let _ = crate::stringsshim::builder_write_rune(builder, '好')?;
    let _ = crate::stringsshim::builder_write_byte(builder, 33u8)?;
    let built = crate::stringsshim::builder_string(builder);
    let built_len = (crate::stringsshim::builder_len(builder)).to_string();
    let reader = crate::stringsshim::new_reader("ab好");
    let (one, _) = crate::stringsshim::reader_read(reader, crate::common::bytes_of_string("."))?;
    let next_byte = crate::stringsshim::reader_read_byte(reader)?;
    let (next_rune, rune_size) = crate::stringsshim::reader_read_rune(reader)?;
    crate::stringsshim::reader_seek(reader, 0i64, 0)?;
    let copy_builder = crate::stringsshim::new_builder();
    let copied = crate::stringsshim::reader_write_to_builder(reader, copy_builder)?;
    let copied_text = crate::stringsshim::builder_string(copy_builder);
    let pairs: Vec[string] = Vec::new();
    let pairs = pairs.push("go");
    let pairs = pairs.push("GO");
    let pairs = pairs.push("ml");
    let pairs = pairs.push("ML");
    let replacer = crate::stringsshim::new_replacer(pairs);
    let replaced = crate::stringsshim::replacer_replace(replacer, "goml");
    let mapped = crate::stringsshim::map_text(
        |r| {
            if r == 'x' {
                -1i32
            } else {
                111i32
            }
        },
        "xay",
    );
    let out = cmp;
    let out = out + "|" + contains_flag;
    let out = out + "|" + digit_flag;
    let out = out + "|" + cut_text;
    let out = out + "|" + fields_text;
    let out = out + "|" + seq_text;
    let out = out + "|" + split_after_text;
    let out = out + "|" + special_flag;
    let out = out + "|" + built;
    let out = out + "|" + built_len;
    let out = out + "|" + crate::common::string_of_bytes(one);
    let out = out + "|" + (next_byte).to_string();
    let out = out + "|" + next_rune.to_string();
    let out = out + "|" + (rune_size).to_string();
    let out = out + "|" + copied_text;
    let out = out + "|" + (copied).to_string();
    let out = out + "|" + replaced;
    let out = out + "|" + mapped;
    Result::Ok(out)
}

fn main() -> unit {
    println(show(demo_io()));
    println(show(demo_exec()));
    println(show(demo_fs()));
    println(show(demo_bufio()));
    println(show(demo_strings()));
}
