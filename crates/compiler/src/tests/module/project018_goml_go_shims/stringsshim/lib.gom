) -> Result[GoInt, GoError]

struct Builder {
    raw: RawBuilder,
}

struct Reader {
    raw: RawReader,
}

struct Replacer {
    raw: RawReplacer,
}

struct SpecialCase {
    raw: RawSpecialCase,
}

fn collect_seq(seq: ((string) -> bool) -> unit) -> Vec[string] {
    let items = ref(vec_new());
    seq(|item| {
        ref_set(items, vec_push(ref_get(items), item));
        true
    });
    ref_get(items)
}

fn new_builder() -> Builder {
    Builder { raw: raw_new_builder() }
}

fn new_reader(text: string) -> Reader {
    Reader { raw: raw_new_reader(text) }
}

fn new_replacer(pairs: Vec[string]) -> Replacer {
    Replacer {
        raw: raw_new_replacer(slice(pairs, 0, vec_len(pairs))),
    }
}

fn turkish_case() -> SpecialCase {
    SpecialCase {
        raw: raw_turkish_case(),
    }
}

fn compare(a: string, b: string) -> int32 {
    raw_int32(raw_compare(a, b))
}

fn contains(text: string, substr: string) -> bool {
    raw_contains(text, substr)
}

fn contains_func(text: string, predicate: (char) -> bool) -> bool {
    raw_contains_func(text, predicate)
}

fn cut(text: string, sep: string) -> Option[(string, string)] {
    raw_cut(text, sep)
}

fn fields_func(text: string, predicate: (char) -> bool) -> Vec[string] {
    raw_fields_func(text, predicate)
}

fn join(parts: Vec[string], sep: string) -> string {
    raw_join(parts, sep)
}

fn map_text(mapping: (char) -> int32, text: string) -> string {
    raw_map(mapping, text)
}

fn split_after_seq(text: string, sep: string) -> ((string) -> bool) -> unit {
    |yield| {
        raw_split_after_seq_each(text, sep, yield)
    }
}

fn split_seq(text: string, sep: string) -> ((string) -> bool) -> unit {
    |yield| {
        raw_split_seq_each(text, sep, yield)
    }
}

fn to_upper(text: string) -> string {
    raw_to_upper(text)
}

fn to_upper_special(case: SpecialCase, text: string) -> string {
    raw_to_upper_special(case.raw, text)
}

fn builder_grow(builder: Builder, n: int32) -> unit {
    raw_builder_grow(builder.raw, raw_go_int(n))
}

fn builder_len(builder: Builder) -> int32 {
    raw_int32(raw_builder_len(builder.raw))
}

fn builder_string(builder: Builder) -> string {
    raw_builder_string(builder.raw)
}

fn builder_write_byte(builder: Builder, value: uint8) -> Result[unit, GoError] {
    raw_builder_write_byte(builder.raw, value)
}

fn builder_write_rune(builder: Builder, value: char) -> Result[int32, GoError] {
    let count = raw_builder_write_rune(builder.raw, value)?;
    Result::Ok(raw_int32(count))
}

fn builder_write_string(builder: Builder, text: string) -> Result[int32, GoError] {
    let count = raw_builder_write_string(builder.raw, text)?;
    Result::Ok(raw_int32(count))
}

fn reader_read(reader: Reader, data: Vec[uint8]) -> Result[(Vec[uint8], int32), GoError] {
    let count = raw_reader_read(reader.raw, data)?;
    Result::Ok((data, raw_int32(count)))
}

fn reader_read_byte(reader: Reader) -> Result[uint8, GoError] {
    raw_reader_read_byte(reader.raw)
}

fn reader_read_rune(reader: Reader) -> Result[(char, int32), GoError] {
    let (value, size) = raw_reader_read_rune(reader.raw)?;
    Result::Ok((value, raw_int32(size)))
}

fn reader_seek(reader: Reader, offset: int64, whence: int32) -> Result[int64, GoError] {
    raw_reader_seek(reader.raw, offset, raw_go_int(whence))
}

fn reader_write_to_builder(reader: Reader, builder: Builder) -> Result[int64, GoError] {
    raw_reader_write_to_builder(reader.raw, builder.raw)
}

fn replacer_replace(replacer: Replacer, text: string) -> string {
    raw_replacer_replace(replacer.raw, text)
}
