extern "go" "" "func(text string, predicate func(rune) bool, yield func(string) bool) { for part := range strings.FieldsFuncSeq(text, predicate) { if !yield(part) { return } } }" raw_fields_func_seq_each(
    text: string,
    predicate: (char) -> bool,
    yield: (string) -> bool,
