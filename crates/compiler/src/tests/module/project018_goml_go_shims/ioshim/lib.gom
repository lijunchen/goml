package ioshim;
use common;

extern "go" "io" "Reader" type RawReader
extern "go" "io" "Writer" type RawWriter
extern "go" "io" "ReadCloser" type RawReadCloser
extern "go" "io" "WriteCloser" type RawWriteCloser
extern "go" "io" "*PipeReader" type RawPipeReader
extern "go" "io" "*PipeWriter" type RawPipeWriter
extern "go" "" "int" type GoInt

extern "go" "strings" "NewReader" raw_string_reader(text: string) -> RawReader
extern "go" "" "int" raw_int32_to_go_int(value: int32) -> GoInt
extern "go" "" "int32" raw_go_int_to_int32(value: GoInt) -> int32

#[go_value]
extern "go" "io" "Discard" raw_discard() -> RawWriter
#[go_value]
extern "go" "io" "EOF" raw_eof() -> GoError
#[go_value]
extern "go" "io" "ErrClosedPipe" raw_err_closed_pipe() -> GoError
#[go_value]
extern "go" "io" "ErrNoProgress" raw_err_no_progress() -> GoError
#[go_value]
