extern "go" "io" "LimitReader" raw_limit_reader(reader: RawReader, n: int64) -> RawReader
extern "go" "io" "TeeReader" raw_tee_reader(reader: RawReader, writer: RawWriter) -> RawReader
extern "go" "io" "NopCloser" raw_nop_closer(reader: RawReader) -> RawReadCloser

#[go_variadic_last]
extern "go" "io" "MultiReader" raw_multi_reader(readers: Slice[RawReader]) -> RawReader

#[go_variadic_last]
extern "go" "io" "MultiWriter" raw_multi_writer(writers: Slice[RawWriter]) -> RawWriter

#[go_error_last]
extern "go" "io" "Copy" raw_copy(dst: RawWriter, src: RawReader) -> Result[int64, GoError]

#[go_error_last]
extern "go" "io" "CopyN" raw_copy_n(dst: RawWriter, src: RawReader, n: int64) -> Result[int64, GoError]

