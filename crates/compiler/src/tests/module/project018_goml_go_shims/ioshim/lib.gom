extern "go" "io" "ReadAll" raw_read_all(reader: RawReader) -> Result[Vec[uint8], GoError]

#[go_error_last]
extern "go" "io" "ReadAll" raw_pipe_read_all(reader: RawPipeReader) -> Result[Vec[uint8], GoError]

#[go_error_last]
extern "go" "io" "ReadAll" raw_read_all_closer(reader: RawReadCloser) -> Result[Vec[uint8], GoError]

#[go_error_last]
extern "go" "io" "ReadFull" raw_read_full(reader: RawReader, buf: Vec[uint8]) -> Result[GoInt, GoError]

#[go_error_last]
extern "go" "io" "ReadAtLeast" raw_read_at_least(
    reader: RawReader,
    buf: Vec[uint8],
    min: GoInt,
) -> Result[GoInt, GoError]

#[go_error_last]
extern "go" "io" "WriteString" raw_pipe_write_string(writer: RawPipeWriter, text: string) -> Result[GoInt, GoError]

#[go_error_last]
extern "go" "io" "WriteString" raw_write_string(writer: RawWriter, text: string) -> Result[GoInt, GoError]

#[go_error_last]
extern "go" "io" "WriteString" raw_write_closer_write_string(writer: RawWriteCloser, text: string) -> Result[GoInt, GoError]

#[go_error]
extern "go" "io" "(*PipeWriter).Close" raw_pipe_writer_close(writer: RawPipeWriter) -> Result[unit, GoError]

#[go_error]
extern "go" "io" "(*PipeReader).Close" raw_pipe_reader_close(reader: RawPipeReader) -> Result[unit, GoError]

#[go_error_last]
extern "go" "io" "(*PipeWriter).Write" raw_pipe_writer_write(
    writer: RawPipeWriter,
    data: Vec[uint8],
) -> Result[GoInt, GoError]

#[go_error_last]
extern "go" "io" "(*PipeReader).Read" raw_pipe_reader_read(
    reader: RawPipeReader,
    data: Vec[uint8],
) -> Result[GoInt, GoError]

#[go_error]
extern "go" "io" "(*PipeWriter).CloseWithError" raw_pipe_writer_close_with_error(
    writer: RawPipeWriter,
    err: GoError,
) -> Result[unit, GoError]

#[go_error]
extern "go" "io" "(*PipeReader).CloseWithError" raw_pipe_reader_close_with_error(
    reader: RawPipeReader,
    err: GoError,
) -> Result[unit, GoError]

#[go_error]
extern "go" "io" "ReadCloser.Close" raw_read_closer_close(reader: RawReadCloser) -> Result[unit, GoError]

#[go_error]
extern "go" "io" "WriteCloser.Close" raw_write_closer_close(writer: RawWriteCloser) -> Result[unit, GoError]

struct Reader {
    raw: RawReader,
}

struct Writer {
    raw: RawWriter,
}

struct PipeReader {
    raw: RawPipeReader,
}

struct PipeWriter {
    raw: RawPipeWriter,
}

fn zero_bytes(n: int32) -> Vec[uint8] {
    let out: Ref[Vec[uint8]] = ref(vec_new());
    let index = ref(0);
    while ref_get(index) < n {
        ref_set(out, vec_push(ref_get(out), 0u8));
        ref_set(index, ref_get(index) + 1);
    };
    ref_get(out)
}

fn from_text(text: string) -> Reader {
    Reader {
        raw: raw_string_reader(text),
    }
}

fn err_no_progress() -> GoError {
    raw_err_no_progress()
}

fn err_short_write() -> GoError {
    raw_err_short_write()
}

fn seek_start() -> int32 {
    raw_go_int_to_int32(raw_seek_start())
}

fn seek_current() -> int32 {
    raw_go_int_to_int32(raw_seek_current())
}

fn seek_end() -> int32 {
    raw_go_int_to_int32(raw_seek_end())
}

fn discard() -> Writer {
    Writer {
        raw: raw_discard(),
    }
}

fn limit(reader: Reader, n: int64) -> Reader {
    Reader {
        raw: raw_limit_reader(reader.raw, n),
    }
}

fn multi_text(parts: Vec[string]) -> Reader {
    let raws: Ref[Vec[RawReader]] = ref(vec_new());
    let index = ref(0);
    while ref_get(index) < vec_len(parts) {
        let text = vec_get(parts, ref_get(index));
        ref_set(raws, vec_push(ref_get(raws), raw_string_reader(text)));
        ref_set(index, ref_get(index) + 1);
    };
    let raw_vec = ref_get(raws);
    Reader {
        raw: raw_multi_reader(slice(raw_vec, 0, vec_len(raw_vec))),
    }
}

fn read_all_text(reader: Reader) -> Result[string, GoError] {
    let bytes = raw_read_all(reader.raw)?;
    Result::Ok(common::string_of_bytes(bytes))
}

fn read_limited_text(text: string, n: int64) -> Result[string, GoError] {
    read_all_text(limit(from_text(text), n))
}

fn copy_to_discard(text: string) -> Result[int64, GoError] {
    raw_copy(discard().raw, from_text(text).raw)
}

fn copy_n_to_discard(text: string, n: int64) -> Result[int64, GoError] {
    raw_copy_n(discard().raw, from_text(text).raw, n)
}

fn copy_buffer_to_discard(text: string, buf: Vec[uint8]) -> Result[int64, GoError] {
    raw_copy_buffer(discard().raw, from_text(text).raw, buf)
}

fn write_text(writer: Writer, text: string) -> Result[unit, GoError] {
    let _ = raw_write_string(writer.raw, text)?;
    Result::Ok(())
}

fn write_to_multi_discard(text: string) -> Result[int32, GoError] {
    let writers0: Vec[RawWriter] = vec_new();
    let writers1 = vec_push(writers0, discard().raw);
    let writers2 = vec_push(writers1, discard().raw);
    let writer = Writer {
        raw: raw_multi_writer(slice(writers2, 0, vec_len(writers2))),
    };
    let written = raw_write_string(writer.raw, text)?;
    Result::Ok(raw_go_int_to_int32(written))
}

fn tee_read_all_text(text: string) -> Result[string, GoError] {
    let raw = raw_tee_reader(from_text(text).raw, discard().raw);
    read_all_text(Reader { raw: raw })
}

fn read_full_text(text: string, n: int32) -> Result[string, GoError] {
    let buf = zero_bytes(n);
    let _ = raw_read_full(from_text(text).raw, buf)?;
    Result::Ok(common::string_of_bytes(buf))
}

fn read_at_least_text(text: string, min: int32) -> Result[string, GoError] {
    let buf = zero_bytes(min);
    let _ = raw_read_at_least(from_text(text).raw, buf, raw_int32_to_go_int(min))?;
    Result::Ok(common::string_of_bytes(buf))
}

fn nop_close_text(text: string) -> Result[string, GoError] {
    let reader = raw_nop_closer(from_text(text).raw);
    let bytes = raw_read_all_closer(reader)?;
    raw_read_closer_close(reader)?;
    Result::Ok(common::string_of_bytes(bytes))
}

fn pipe() -> (PipeReader, PipeWriter) {
    let (reader, writer) = raw_pipe();
    (
        PipeReader { raw: reader },
        PipeWriter { raw: writer },
    )
}

fn pipe_read_all_text(reader: PipeReader) -> Result[string, GoError] {
    let bytes = raw_pipe_read_all(reader.raw)?;
    Result::Ok(common::string_of_bytes(bytes))
}

fn pipe_write_text(writer: PipeWriter, text: string) -> Result[unit, GoError] {
    let _ = raw_pipe_write_string(writer.raw, text)?;
    Result::Ok(())
}

fn pipe_write_bytes(writer: PipeWriter, data: Vec[uint8]) -> Result[int32, GoError] {
    let written = raw_pipe_writer_write(writer.raw, data)?;
    Result::Ok(raw_go_int_to_int32(written))
}

fn pipe_read_text(reader: PipeReader, n: int32) -> Result[string, GoError] {
    let buf = zero_bytes(n);
    let _ = raw_pipe_reader_read(reader.raw, buf)?;
    Result::Ok(common::string_of_bytes(buf))
}

fn close_pipe_writer(writer: PipeWriter) -> Result[unit, GoError] {
    raw_pipe_writer_close(writer.raw)
}

fn close_pipe_reader(reader: PipeReader) -> Result[unit, GoError] {
    raw_pipe_reader_close(reader.raw)
}

fn close_pipe_writer_eof(writer: PipeWriter) -> Result[unit, GoError] {
    raw_pipe_writer_close_with_error(writer.raw, raw_eof())
}

fn close_pipe_reader_closed_pipe(reader: PipeReader) -> Result[unit, GoError] {
    raw_pipe_reader_close_with_error(reader.raw, raw_err_closed_pipe())
}

impl Reader {
    fn limit(self: Reader, n: int64) -> Reader {
        limit(self, n)
    }

    fn read_all_text(self: Reader) -> Result[string, GoError] {
        read_all_text(self)
    }

    fn tee_to_discard(self: Reader) -> Reader {
        Reader {
            raw: raw_tee_reader(self.raw, discard().raw),
        }
    }
}

impl Writer {
    fn write_text(self: Writer, text: string) -> Result[unit, GoError] {
        write_text(self, text)
    }
}

impl PipeWriter {
    fn write_text(self: PipeWriter, text: string) -> Result[unit, GoError] {
        pipe_write_text(self, text)
    }

    fn write_bytes(self: PipeWriter, data: Vec[uint8]) -> Result[int32, GoError] {
        pipe_write_bytes(self, data)
    }

    fn close(self: PipeWriter) -> Result[unit, GoError] {
        close_pipe_writer(self)
    }

    fn close_with_eof(self: PipeWriter) -> Result[unit, GoError] {
        close_pipe_writer_eof(self)
    }
}

impl PipeReader {
    fn read_all_text(self: PipeReader) -> Result[string, GoError] {
        pipe_read_all_text(self)
    }

    fn read_text(self: PipeReader, n: int32) -> Result[string, GoError] {
        pipe_read_text(self, n)
    }

    fn close(self: PipeReader) -> Result[unit, GoError] {
        close_pipe_reader(self)
    }

    fn close_with_closed_pipe(self: PipeReader) -> Result[unit, GoError] {
        close_pipe_reader_closed_pipe(self)
    }
}
