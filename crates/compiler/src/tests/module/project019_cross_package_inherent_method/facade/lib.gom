
struct Item {
    value: string,
}

fn make(value: string) -> Item {
    Item { value: value }
}

impl Item {
    fn touch(self: Item) -> unit {
        ()
    }

    fn text(self: Item) -> string {
        self.value
    }

    fn suffix(self: Item, suffix: string) -> string {
        self.value + suffix
    }
}
