mod util;

fn compute(flag: bool) -> Option[int32] {
    let value = crate::util::maybe_num(flag)?;
    Option::Some(value + 1)
}

fn show(opt: Option[int32]) -> string {
    match opt {
        Option::Some(value) => "some=" + value.to_string(),
        Option::None => "none",
    }
}

fn main() -> unit {
    println(show(compute(true)));
    println(show(compute(false)));
}
