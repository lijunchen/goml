use crate::traitpkg;
pub fn pick_a[T: crate::traitpkg::B + crate::traitpkg::A + crate::traitpkg::A](x: T) -> string {
    crate::traitpkg::A::foo(x)
}

pub fn foo_both[T: crate::traitpkg::A + crate::traitpkg::B](x: T) -> string {
    crate::traitpkg::A::foo(x) + crate::traitpkg::B::foo(x)
}

pub fn bar_it[T: crate::traitpkg::C](x: T) -> string {
    x.bar()
}
