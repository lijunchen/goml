package main
file main.gom
  fn classify(local/1/0: int32) -> string {
        match n/0 {
            -1 => "minus one",
            0 => "zero",
            1 => "one",
            _ => "other",
        }
    }
    
    fn main() {
        println(def/1/0(-1));
        println(def/1/0(0));
        println(def/1/0(1));
        println(def/1/0(42));
    }