fn classify(n/0: int32) -> string {
  join k4(jp5: string) -> string {
    jp5
  } in
  match n/0 {
    -1 => {
      jump k4("minus one")
    },
    0 => {
      jump k4("zero")
    },
    1 => {
      jump k4("one")
    },
    _ => {
      jump k4("other")
    },
  }
}

fn main() -> unit {
  let t6 = classify(-1) in
  let _wild0 = println__T_string(t6) in
  let t7 = classify(0) in
  let _wild1 = println__T_string(t7) in
  let t8 = classify(1) in
  let _wild2 = println__T_string(t8) in
  let t9 = classify(42) in
  let _wild3 = println__T_string(t9) in
  ()
}

fn println__T_string(value/1: string) -> unit {
  let t10 = string_println(value/1) in
  t10
}