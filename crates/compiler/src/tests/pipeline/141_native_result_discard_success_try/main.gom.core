fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn touch(text/0: string) -> Result[string, GoError] {
  let mtmp3 = {
    let mtmp0 = parse_duration(text/0) in
    match mtmp0 {
      Result::Ok(x1) => {
        {
          let x1 = Result::Ok._0(mtmp0) in
          {
            let try_value/4 = x1 in
            try_value/4
          }
        }
      },
      Result::Err(x2) => {
        {
          let x2 = Result::Err._0(mtmp0) in
          {
            let try_residual/4 = x2 in
            return Result::Err(try_residual/4)
          }
        }
      },
    }
  } in
  {
    Result::Ok("ok")
  }
}

fn show(res/1: Result[string, GoError]) -> string {
  match res/1 {
    Result::Ok(x4) => {
      {
        let x4 = Result::Ok._0(res/1) in
        {
          let value/2 = x4 in
          value/2
        }
      }
    },
    Result::Err(x5) => {
      {
        let x5 = Result::Err._0(res/1) in
        {
          let err/3 = x5 in
          ("err=" + trait_call[ToString::to_string](err/3))
        }
      }
    },
  }
}

fn main() -> unit {
  let _wild6 = println(show(touch("2s"))) in
  let _wild7 = println(show(touch("bad"))) in
