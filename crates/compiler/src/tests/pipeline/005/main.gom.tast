fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)));
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)));
}

fn main() -> unit {
    let a/0: (Color, Color) = (Color::Blue, Color::Red);
    match (a/0 : (Color, Color)) {
        (Color::Red, Color::Green) => (print : (int32) -> unit)(0),
        (Color::Red, Color::Red) => (print : (int32) -> unit)(1),
        (Color::Blue, Color::Blue) => (print : (int32) -> unit)(2),
        _ : (Color, Color) => (print : (int32) -> unit)(3),
    };
}