}

fn show(opt/5: Option[int32]) -> string {
  match opt/5 {
    Option::None => {
      "none"
    },
    Option::Some(x4) => {
      {
        let x4 = Option::Some._0(opt/5) in
        {
          let value/6 = x4 in
          ("some=" + trait_call[ToString::to_string](value/6))
        }
      }
    },
  }
}

