package main
file main.gom
  fn classify(local/1/0: float64) -> string {
        match x/0 {
            0.0 => "zero",
            1.0 => "one",
            -1.0 => "minus one",
            3.14 => "pi",
            _ => "other",
        }
    }
    
    fn main() {
        println(def/1/0(0));
        println(def/1/0(1));
        println(def/1/0(-1));
        println(def/1/0(3.14));
        println(def/1/0(42));
    }