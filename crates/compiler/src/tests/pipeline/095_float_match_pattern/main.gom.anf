fn classify(x/0: float64) -> string {
  join k5(jp6: string) -> string {
    jp6
  } in
  match x/0 {
    0 => {
      jump k5("zero")
    },
    1 => {
      jump k5("one")
    },
    -1 => {
      jump k5("minus one")
    },
    3.14 => {
      jump k5("pi")
    },
    _ => {
      jump k5("other")
    },
  }
}

fn main() -> unit {
  let t7 = classify(0) in
  let _wild0 = println__T_string(t7) in
  let t8 = classify(1) in
  let _wild1 = println__T_string(t8) in
  let t9 = (-1) in
  let t10 = classify(t9) in
  let _wild2 = println__T_string(t10) in
  let t11 = classify(3.14) in
  let _wild3 = println__T_string(t11) in
  let t12 = classify(42) in
  let _wild4 = println__T_string(t12) in
  ()
}

fn println__T_string(value/1: string) -> unit {
  let t13 = string_println(value/1) in
  t13
}