fn sum_to(limit/0: int32) -> int32 {
  let acc/1 = ref(0) in
  let i/2 = ref(0) in
  let mtmp3 = while (ref_get(i/2) < limit/0) {
      let current/3 = ref_get(i/2) in
      let mtmp1 = ref_set(acc/1, (ref_get(acc/1) + current/3)) in
      let mtmp2 = ref_set(i/2, (current/3 + 1)) in
      ()
  } in
  ref_get(acc/1)
}

fn sum_even(limit/4: int32) -> int32 {
  let acc/5 = ref(0) in
  let i/6 = ref(0) in
  let is_even/7 = ref(true) in
  let mtmp7 = while (ref_get(i/6) < limit/4) {
      let current/8 = ref_get(i/6) in
      let mtmp5 = ref_set(i/6, (current/8 + 1)) in
      let add_now/9 = ref_get(is_even/7) in
      let mtmp6 = ref_set(is_even/7, (!add_now/9)) in
      if add_now/9 {
          ref_set(acc/5, (ref_get(acc/5) + current/8))
      } else {
          ()
      }
  } in
  ref_get(acc/5)
}

fn main() -> unit {
  let first/10 = sum_to(5) in
  let evens/11 = sum_even(6) in
  let mtmp15 = print__T_string("sum_to(5)=") in
  let mtmp19 = println__T_int32(first/10) in
  let mtmp21 = print__T_string("sum_even(6)=") in
  let mtmp22 = println__T_int32(evens/11) in
  ()
}

fn print__T_string(value/0: string) -> unit {
  string_print(value/0)
}

fn println__T_int32(value/1: int32) -> unit {
  string_println(int32_to_string(value/1))
}