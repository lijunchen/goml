fn sum_to(limit/0: int32) -> int32 {
  join ret10(retv11: int32) -> int32 {
    retv11
  } in
  let acc/1 = ref(0) in
  let i/2 = ref(0) in
  join exit12() -> int32 {
    let mtmp2 = () in
    let t13 = ref_get(acc/1) in
    jump ret10(t13)
  } in
  joinrec {
    join loop14() -> int32 {
      let t15 = ref_get(i/2) in
      let t16 = (t15 < limit/0) in
      if t16 {
        let current/3 = ref_get(i/2) in
        let t17 = ref_get(acc/1) in
        let t18 = (t17 + current/3) in
        let mtmp0 = ref_set(acc/1, t18) in
        let t19 = (current/3 + 1) in
        let mtmp1 = ref_set(i/2, t19) in
        jump loop14()
      } else {
        jump exit12()
      }
    } in
  } in
  jump loop14()
}

fn sum_even(limit/4: int32) -> int32 {
  join ret20(retv21: int32) -> int32 {
    retv21
  } in
  let acc/5 = ref(0) in
  let i/6 = ref(0) in
  let is_even/7 = ref(true) in
  join exit22() -> int32 {
    let mtmp5 = () in
    let t23 = ref_get(acc/5) in
    jump ret20(t23)
  } in
  joinrec {
    join loop24() -> int32 {
      let t25 = ref_get(i/6) in
      let t26 = (t25 < limit/4) in
      if t26 {
        let current/8 = ref_get(i/6) in
        let t27 = (current/8 + 1) in
        let mtmp3 = ref_set(i/6, t27) in
        let add_now/9 = ref_get(is_even/7) in
        let t28 = (!add_now/9) in
        let mtmp4 = ref_set(is_even/7, t28) in
        join k29() -> int32 {
          jump loop24()
        } in
        if add_now/9 {
          let t30 = ref_get(acc/5) in
          let t31 = (t30 + current/8) in
          let t32 = ref_set(acc/5, t31) in
          jump k29()
        } else {
          jump k29()
        }
      } else {
        jump exit22()
      }
    } in
  } in
  jump loop24()
}

fn main() -> unit {
  join ret33() -> unit {
    ()
  } in
  let first/10 = sum_to(5) in
  let evens/11 = sum_even(6) in
  let mtmp6 = print__T_string("sum_to(5)=") in
  let mtmp7 = println__T_int32(first/10) in
  let mtmp8 = print__T_string("sum_even(6)=") in
  let mtmp9 = println__T_int32(evens/11) in
  jump ret33()
}

