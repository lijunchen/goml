}

fn show(res/2: Result[unit, string]) -> string {
  match res/2 {
    Result::Ok(x4) => {
      {
        let x4 = Result::Ok._0(res/2) in
        match x4 {
          () => {
            "ok unit"
          },
        }
      }
    },
    Result::Err(x5) => {
      {
        let x5 = Result::Err._0(res/2) in
        {
          let err/3 = x5 in
          ("err " + err/3)
        }
      }
    },
  }
}

fn main() -> unit {
  let _wild6 = println(show(run(true))) in
  let _wild7 = println(show(run(false))) in
}