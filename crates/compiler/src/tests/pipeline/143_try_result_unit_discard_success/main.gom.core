fn step(ok/0: bool) -> Result[unit, string] {
  if ok/0 {
      {
        Result::Ok(())
      }
  } else {
      {
        Result::Err("step failed")
      }
  }
}

fn run(ok/1: bool) -> Result[unit, string] {
  let mtmp3 = {
    let mtmp0 = step(ok/1) in
    match mtmp0 {
      Result::Ok(x1) => {
        {
          let x1 = Result::Ok._0(mtmp0) in
          {
            let try_value/12 = x1 in
            try_value/12
          }
        }
      },
      Result::Err(x2) => {
        {
          let x2 = Result::Err._0(mtmp0) in
