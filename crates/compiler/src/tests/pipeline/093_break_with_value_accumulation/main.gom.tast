        {
            (ref_set : (Ref[int32], int32) -> unit)((i/1 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) + 1);
            if (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) > 5 {
                {
                    break
                }
            } else {
                {
                    ()
                }
            };
            (ref_set : (Ref[int32], int32) -> unit)((sum/0 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((sum/0 : Ref[int32])) + (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])));
        }
    };
