fn show_int(x/1: Light__int32) -> string {
  match x/1 {
    Light__int32::Red => {
      "ri"
    },
    Light__int32::Green => {
      "gi"
    },
  }
}

fn show_string(x/2: Light__string) -> string {
  match x/2 {
    Light__string::Red => {
      "rs"
    },
    Light__string::Green => {
      "gs"
    },
  }
}

fn main() -> unit {
  let _wild0 = println__T_string(show_int(flip__T_int32(Light__int32::Red))) in
  let _wild1 = println__T_string(show_string(flip__T_string(Light__string::Green))) in
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}

fn flip__T_int32(x/0: Light__int32) -> Light__int32 {
  match x/0 {
    Light__int32::Red => {
      Light__int32::Green
    },
    Light__int32::Green => {
      Light__int32::Red
    },
  }
}

fn flip__T_string(x/0: Light__string) -> Light__string {
  match x/0 {
    Light__string::Red => {
      Light__string::Green
    },
    Light__string::Green => {
      Light__string::Red
    },
  }
}