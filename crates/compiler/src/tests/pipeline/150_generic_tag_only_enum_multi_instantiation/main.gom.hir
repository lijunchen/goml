package main
file main.gom
  enum Light[T] {
        Red,
        Green
    }
    
    fn flip(local/1/0: Light[T]) -> Light[T] {
        match x/0 {
            ctor(def/1/0::v0) => ctor(def/1/0::v1),
            ctor(def/1/0::v1) => ctor(def/1/0::v0),
        }
    }
    
    fn show_int(local/1/1: Light[int32]) -> string {
        match x/1 {
            ctor(def/1/0::v0) => "ri",
            ctor(def/1/0::v1) => "gi",
        }
    }
    
    fn show_string(local/1/2: Light[string]) -> string {
        match x/2 {
            ctor(def/1/0::v0) => "rs",
            ctor(def/1/0::v1) => "gs",
        }
    }
    
    fn main() -> unit {
        println(def/1/2(def/1/1(ctor(def/1/0::v0))));
        println(def/1/3(def/1/1(ctor(def/1/0::v1))));
    }