fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn parse_text(ok/0: bool) -> Result[string, string] {
    if (ok/0 : bool) {
        {
            Result::Ok("ignored")
        }
    } else {
        {
            Result::Err("parse failed")
        }
    }
}

fn check(ok/1: bool) -> Result[string, string] {
    let _ : string = match (parse_text : (bool) -> Result[string, string])((ok/1 : bool)) {
        Result::Ok(try_value/12: string) => (try_value/12 : string),
        Result::Err(try_residual/12: string) => return Result::Err((try_residual/12 : string)),
    };
    Result::Ok("ok")
}

fn show(res/2: Result[string, string]) -> string {
    match (res/2 : Result[string, string]) {
        Result::Ok(value/3: string) => "ok " + (value/3 : string),
        Result::Err(err/4: string) => "err " + (err/4 : string),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, string]) -> string)((check : (bool) -> Result[string, string])(true)));
    (println : (string) -> unit)((show : (Result[string, string]) -> string)((check : (bool) -> Result[string, string])(false)));
}