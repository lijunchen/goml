fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn make_pairer(x/0: T) -> (string) -> string {
    |tag/1: string| => (tag/1 : string) + ":" + (ToString::to_string : (T) -> string)((x/0 : T))
}

fn main() -> unit {
    let int_pairer/2: (string) -> string = (make_pairer : (int32) -> (string) -> string)(7);
    let string_pairer/3: (string) -> string = (make_pairer : (string) -> (string) -> string)("ok");
    (println : (string) -> unit)((int_pairer/2 : (string) -> string)("a"));
    (println : (string) -> unit)((string_pairer/3 : (string) -> string)("b"));
}