fn accumulate(limit/1: int32) -> Option[int32] {
    let sum/2: Ref[int32] = (ref : (int32) -> Ref[int32])(0);
    let i/3: Ref[int32] = (ref : (int32) -> Ref[int32])(0);
    while (ref_get : (Ref[int32]) -> int32)((i/3 : Ref[int32])) < (limit/1 : int32) {
        {
            let cur/4: int32 = (ref_get : (Ref[int32]) -> int32)((i/3 : Ref[int32]));
            (ref_set : (Ref[int32], int32) -> unit)((i/3 : Ref[int32]), (cur/4 : int32) + 1);
            if (cur/4 : int32) == 1 {
                {
                    continue
                }
            } else {
                {
                    ()
                }
            };
            let value/5: int32 = match (step : (int32) -> Option[int32])((cur/4 : int32)) {
                Option::Some(try_value/43: int32) => (try_value/43 : int32),
                Option::None => return Option::None,
            };
            (ref_set : (Ref[int32], int32) -> unit)((sum/2 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((sum/2 : Ref[int32])) + (value/5 : int32));
        }
    };
    Option::Some((ref_get : (Ref[int32]) -> int32)((sum/2 : Ref[int32])))
}

fn show(opt/6: Option[int32]) -> string {
