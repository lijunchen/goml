package main
file main.gom
  enum Expr {
        Zero,
        Succ(Expr),
        Add(Expr, Expr),
        Mul(Expr, Expr)
    }
    
    fn main() {
        let local/1/0 = ctor(def/1/0::v3)(ctor(def/1/0::v2)(ctor(def/1/0::v0), ctor(def/1/0::v0)), ctor(def/1/0::v0));
        match a/0 {
            ctor(def/1/0::v2)(ctor(def/1/0::v0), ctor(def/1/0::v0)) => print(0i32),
            ctor(def/1/0::v3)(ctor(def/1/0::v0), local/1/1) => print(1i32),
            ctor(def/1/0::v2)(ctor(def/1/0::v1)(local/1/2), local/1/3) => print(2i32),
            ctor(def/1/0::v3)(local/1/4, ctor(def/1/0::v0)) => print(3i32),
            ctor(def/1/0::v3)(ctor(def/1/0::v2)(local/1/5, local/1/6), local/1/7) => print(4i32),
            ctor(def/1/0::v2)(local/1/8, ctor(def/1/0::v0)) => print(5i32),
            local/1/9 => print(6i32),
        }
    }