fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn pick(mode/0: Mode, input/1: string) -> Result[string, GoError] {
  let value/4 = match mode/0 {
    Mode::Left => {
      {
        let parsed/2 = {
          let mtmp0 = parse_duration(input/1) in
          match mtmp0 {
            Result::Ok(x1) => {
              {
                let x1 = Result::Ok._0(mtmp0) in
                {
                  let try_value/5 = x1 in
                  try_value/5
                }
              }
            },
            Result::Err(x2) => {
              {
                let x2 = Result::Err._0(mtmp0) in
                {
                  let try_residual/5 = x2 in
                  return Result::Err(try_residual/5)
                }
              }
            },
          }
        } in
        ("left=" + format_duration("%v", parsed/2))
      }
    },
    Mode::Keep => {
      "keep"
    },
    Mode::Right => {
      {
        let parsed/3 = {
          let mtmp3 = parse_duration(input/1) in
          match mtmp3 {
            Result::Ok(x4) => {
              {
                let x4 = Result::Ok._0(mtmp3) in
                {
                  let try_value/17 = x4 in
                  try_value/17
                }
              }
            },
            Result::Err(x5) => {
              {
                let x5 = Result::Err._0(mtmp3) in
                {
                  let try_residual/17 = x5 in
                  return Result::Err(try_residual/17)
                }
              }
            },
          }
        } in
        ("right=" + format_duration("%v", parsed/3))
      }
    },
  } in
  Result::Ok(value/4)
}

fn show(res/5: Result[string, GoError]) -> string {
  match res/5 {
    Result::Ok(x6) => {
      {
        let x6 = Result::Ok._0(res/5) in
        {
          let value/6 = x6 in
          value/6
        }
      }
    },
    Result::Err(x7) => {
      {
        let x7 = Result::Err._0(res/5) in
        {
          let err/7 = x7 in
          ("err=" + trait_call[ToString::to_string](err/7))
        }
      }
    },
  }
}

fn main() -> unit {
  let _wild8 = println(show(pick(Mode::Left, "4s"))) in
  let _wild9 = println(show(pick(Mode::Right, "bad"))) in
  let _wild10 = println(show(pick(Mode::Keep, "ignored"))) in
}