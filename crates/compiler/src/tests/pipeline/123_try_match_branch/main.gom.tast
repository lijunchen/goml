fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

extern "go" "time" "Duration" type Duration

extern "go" "time" parse_duration(s: string) -> Result[Duration, GoError]

extern "go" "fmt" format_duration(format: string, value: Duration) -> string

fn pick(mode/0: Mode, input/1: string) -> Result[string, GoError] {
    let value/4: string = match (mode/0 : Mode) {
        Mode::Left => {
              let parsed/2: Duration = match (parse_duration : (string) -> Result[Duration, GoError])((input/1 : string)) {
                  Result::Ok(try_value/5: Duration) => (try_value/5 : Duration),
                  Result::Err(try_residual/5: GoError) => return Result::Err((try_residual/5 : GoError)),
              };
              "left=" + (format_duration : (string, Duration) -> string)("%v", (parsed/2 : Duration))
          },
        Mode::Keep => "keep",
        Mode::Right => {
              let parsed/3: Duration = match (parse_duration : (string) -> Result[Duration, GoError])((input/1 : string)) {
                  Result::Ok(try_value/17: Duration) => (try_value/17 : Duration),
                  Result::Err(try_residual/17: GoError) => return Result::Err((try_residual/17 : GoError)),
              };
              "right=" + (format_duration : (string, Duration) -> string)("%v", (parsed/3 : Duration))
          },
    };
    Result::Ok((value/4 : string))
}

fn show(res/5: Result[string, GoError]) -> string {
    match (res/5 : Result[string, GoError]) {
        Result::Ok(value/6: string) => (value/6 : string),
        Result::Err(err/7: GoError) => "err=" + (ToString::to_string : (GoError) -> string)((err/7 : GoError)),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((pick : (Mode, string) -> Result[string, GoError])(Mode::Left, "4s")));
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((pick : (Mode, string) -> Result[string, GoError])(Mode::Right, "bad")));
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((pick : (Mode, string) -> Result[string, GoError])(Mode::Keep, "ignored")));
}