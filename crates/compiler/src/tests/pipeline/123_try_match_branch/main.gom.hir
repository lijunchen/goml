package main
file main.gom
  extern "go" "time" "Duration" type Duration
    
    #[go_error_last]
extern "go" "time" "ParseDuration" parse_duration(s: string) -> Result[Duration, GoError]
    
    extern "go" "fmt" "Sprintf" format_duration(format: string, value: Duration) -> string
    
    enum Mode {
        Left,
        Keep,
        Right
    }
    
    fn pick(local/1/0: Mode, local/1/1: string) -> Result[string, GoError] {
        let local/1/4 = match mode/0 {
            ctor(def/1/3::v0) => {
                  let local/1/2 = def/1/1(input/1)?;
                  "left=" + def/1/2("%v", parsed/2)
              },
            ctor(def/1/3::v1) => "keep",
            ctor(def/1/3::v2) => {
                  let local/1/3 = def/1/1(input/1)?;
                  "right=" + def/1/2("%v", parsed/3)
              },
        };
        Result::Ok(value/4)
    }
    
    fn show(local/1/5: Result[string, GoError]) -> string {
        match res/5 {
            Result::Ok(local/1/6) => value/6,
            Result::Err(local/1/7) => "err=" + err/7.to_string(),
        }
    }
    
    fn main() -> unit {
