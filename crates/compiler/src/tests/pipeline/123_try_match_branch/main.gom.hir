        }
    }
    
    fn choose(local/1/2: Choice) -> Result[int32, string] {
        let local/1/6 = match choice/2 {
            ctor(def/1/0::v0)(local/1/3) => def/1/1(ok/3)?,
            ctor(def/1/0::v1)(local/1/4) => def/1/2(ok/4)? + 1,
            ctor(def/1/0::v2)(local/1/5) => value/5,
        };
        Result::Ok(value/6)
    }
    
    fn show(local/1/7: Result[int32, string]) -> string {
        match res/7 {
            Result::Ok(local/1/8) => "ok " + value/8.to_string(),
            Result::Err(local/1/9) => "err " + err/9,
        }
