impl ToString for (int32, int32) {
  fn to_string(self: (int32, int32)) -> string {
    "(?, ?)"
  }
}

fn main() {
    let x = 123;
    let _ = string_println(ToString::to_string(x));

    let x = true;
    let _ = string_println(ToString::to_string(x));

    let x = (3, 4);
    let _ = string_println(ToString::to_string(x));

    ()
}
