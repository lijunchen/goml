fn trait_impl#ToString#(int32,int32)#to_string(self/0: (int32, int32)) -> string {
  "(?, ?)"
}

fn main() -> unit {
  let x/1 = 123 in
  let mtmp3 = string_println(int32_to_string(x/1)) in
  let x/2 = true in
  let mtmp5 = string_println(bool_to_string(x/2)) in
  let x/3 = (3, 4) in
  let mtmp6 = string_println(trait_impl#ToString#(int32,int32)#to_string(x/3)) in
  ()
}