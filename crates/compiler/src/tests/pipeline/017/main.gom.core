fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#ToString#(int32,int32)#to_string(self/0: (int32, int32)) -> string {
  "(?, ?)"
}

fn main() -> unit {
  let x/1 = 123 in
  let mtmp0 = println(trait_call[ToString::to_string](x/1)) in
  {
    let x/2 = true in
    let mtmp1 = println(trait_call[ToString::to_string](x/2)) in
    {
      let x/3 = (3, 4) in
      let mtmp2 = println(trait_call[ToString::to_string](x/3)) in
      {
        ()
      }
    }
  }
}