impl ToString for (int32, int32){
  fn to_string(self/0: (int32, int32)) -> string {
      "(?, ?)";
  }
}

fn main() -> unit {
    let x/1: int32 = 123;
    let _ : unit = (string_println : (string) -> unit)((ToString::to_string : (int32) -> string)((x/1 : int32)));
    let x/2: bool = true;
    let _ : unit = (string_println : (string) -> unit)((ToString::to_string : (bool) -> string)((x/2 : bool)));
    let x/3: (int32, int32) = (3, 4);
    let _ : unit = (string_println : (string) -> unit)((ToString::to_string : ((int32, int32)) -> string)((x/3 : (int32, int32))));
    ();
}