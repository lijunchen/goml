fn trait_impl#ToString#(int32,int32)#to_string(self/0: (int32, int32)) -> string {
  "(?, ?)"
}

fn main() -> unit {
  let x/1 = 123 in
  let t7 = int32_to_string(x/1) in
  let mtmp3 = string_println(t7) in
  let x/2 = true in
  let t8 = bool_to_string(x/2) in
  let mtmp5 = string_println(t8) in
  let x/3 = (3, 4) in
  let t9 = trait_impl#ToString#(int32,int32)#to_string(x/3) in
  let mtmp6 = string_println(t9) in
  ()
}