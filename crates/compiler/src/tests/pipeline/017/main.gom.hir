package main
file main.gom
  impl ToString for (int32, int32) {
      fn to_string(local/1/0: (int32, int32)) -> string {
        "(?, ?)";
      }
    }
    
    fn main() {
      let local/1/1 = 123;
      let _ = string_println(ToString::to_string(x/1));
      let local/1/2 = true;
      let _ = string_println(ToString::to_string(x/2));
      let local/1/3 = (3, 4);
      let _ = string_println(ToString::to_string(x/3));
      ();
    }