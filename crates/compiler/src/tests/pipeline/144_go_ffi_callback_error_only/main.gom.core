fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn stop(path/0: string, entry/1: DirEntry, err/2: GoError) -> Result[unit, GoError] {
  let mtmp0 = path/0 in
  {
    let mtmp1 = entry/1 in
    {
      let mtmp2 = err/2 in
      {
        Result::Err(eof())
      }
    }
  }
}

fn show(res/3: Result[unit, GoError]) -> string {
  match res/3 {
    Result::Ok(x3) => {
      {
        let x3 = Result::Ok._0(res/3) in
        "ok"
      }
    },
    Result::Err(x4) => {
      {
        let x4 = Result::Err._0(res/3) in
        {
          let err/4 = x4 in
          trait_call[ToString::to_string](err/4)
        }
      }
    },
  }
}

fn main() -> unit {
  let _wild5 = println(show(walk_dir(dir_fs("."), ".", stop))) in
}