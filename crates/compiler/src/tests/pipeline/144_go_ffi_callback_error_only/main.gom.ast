package main;
extern "go" "io/fs" "FS" type FS

extern "go" "io/fs" "DirEntry" type DirEntry

extern "go" "os" "DirFS" dir_fs(path: string) -> FS

#[go_value]
extern "go" "io" "EOF" eof() -> GoError

#[go_error]
extern "go" "io/fs" "WalkDir" walk_dir(fs: FS, root: string, visit: (string, DirEntry, GoError) -> Result[unit, GoError]) -> Result[unit, GoError]

fn stop(path: string, entry: DirEntry, err: GoError) -> Result[unit, GoError] {
    let _ = path;
    let _ = entry;
    let _ = err;
    Result::Err(eof())
}

fn show(res: Result[unit, GoError]) -> string {
    match res {
        Result::Ok(_) => "ok",
        Result::Err(err) => err.to_string(),
    }
}

fn main() -> unit {
    println(show(walk_dir(dir_fs("."), ".", stop)));
}

