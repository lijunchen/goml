package main
file main.gom
  fn loop_break() -> unit {
        while if true {
            break
        } else {
            continue
        } {
            {
                println("unreachable");
            }
        };
    }
    
    fn loop_return() -> int32 {
        while match 0i32 {
            _ => return 5i32,
        } {
            {
                println("unreachable");
            }
        };
        0i32
    }
    
    fn main() -> unit {
        def/1/0();
        println(def/1/1());
    }