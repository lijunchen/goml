package main
file main.gom
  fn match_string(local/1/0: string) -> int32 {
        match s/0 {
            "hello" => 1,
            "world" => 2,
            _ => 3,
        }
    }
    
    fn wildcard_position(local/1/1: string) -> int32 {
        match s/1 {
            _ => 4,
            "world" => 5,
        }
    }
    
    fn repeated_string(local/1/2: string) -> int32 {
        match s/2 {
            "hello" => 6,
            "hello" => 7,
            _ => 8,
        }
    }
    
    fn main() {
        let _ = println(def/1/0("hello").to_string());
        let _ = println(def/1/0("planet").to_string());
        let _ = println(def/1/1("world").to_string());
        let _ = println(def/1/1("sun").to_string());
        let _ = println(def/1/2("hello").to_string());
        println(def/1/2("mars").to_string())
    }