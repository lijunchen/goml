fn match_string(s/0: string) -> int32 {
  join k5(jp6: int32) -> int32 {
    jp6
  } in
  match s/0 {
    "hello" => {
      jump k5(1)
    },
    "world" => {
      jump k5(2)
    },
    _ => {
      jump k5(3)
    },
  }
}

fn wildcard_position(s/1: string) -> int32 {
  4
}

fn repeated_string(s/2: string) -> int32 {
  join k7(jp8: int32) -> int32 {
    jp8
  } in
  match s/2 {
    "hello" => {
      jump k7(6)
    },
    _ => {
      jump k7(8)
    },
  }
}

fn main() -> unit {
  let t9 = match_string("hello") in
  let t10 = int32_to_string(t9) in
  let mtmp0 = string_println(t10) in
  let t11 = match_string("planet") in
  let t12 = int32_to_string(t11) in
  let mtmp1 = string_println(t12) in
  let t13 = wildcard_position("world") in
  let t14 = int32_to_string(t13) in
  let mtmp2 = string_println(t14) in
  let t15 = wildcard_position("sun") in
  let t16 = int32_to_string(t15) in
  let mtmp3 = string_println(t16) in
  let t17 = repeated_string("hello") in
  let t18 = int32_to_string(t17) in
  let mtmp4 = string_println(t18) in
  let t19 = repeated_string("mars") in
  let t20 = int32_to_string(t19) in
  let t21 = string_println(t20) in
  t21
}