fn match_string(s/0: string) -> int32 {
  match s/0 {
    "hello" => {
      1
    },
    "world" => {
      2
    },
    _ => 3,
  }
}

fn wildcard_position(s/1: string) -> int32 {
  4
}

fn repeated_string(s/2: string) -> int32 {
  match s/2 {
    "hello" => {
      6
    },
    _ => 8,
  }
}

fn main() -> unit {
  let t32 = match_string("hello") in
  let t31 = int32_to_string(t32) in
  let mtmp15 = string_println(t31) in
  let t34 = match_string("planet") in
  let t33 = int32_to_string(t34) in
  let mtmp23 = string_println(t33) in
  let t36 = wildcard_position("world") in
  let t35 = int32_to_string(t36) in
  let mtmp27 = string_println(t35) in
  let t38 = wildcard_position("sun") in
  let t37 = int32_to_string(t38) in
  let mtmp29 = string_println(t37) in
  let t40 = repeated_string("hello") in
  let t39 = int32_to_string(t40) in
  let mtmp30 = string_println(t39) in
  let t42 = repeated_string("mars") in
  let t41 = int32_to_string(t42) in
  string_println(t41)
}