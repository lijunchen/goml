fn match_string(s/0: string) -> int32 {
  join ret5(retv6: int32) -> int32 {
    retv6
  } in
  join k7(jp8: int32) -> int32 {
    jump ret5(jp8)
  } in
  match s/0 {
    "hello" => {
      jump k7(1)
    },
    "world" => {
      jump k7(2)
    },
    _ => {
      jump k7(3)
    },
  }
}

fn wildcard_position(s/1: string) -> int32 {
  join ret9(retv10: int32) -> int32 {
    retv10
  } in
  jump ret9(4)
}

fn repeated_string(s/2: string) -> int32 {
  join ret11(retv12: int32) -> int32 {
    retv12
  } in
  join k13(jp14: int32) -> int32 {
    jump ret11(jp14)
  } in
  match s/2 {
    "hello" => {
      jump k13(6)
    },
    _ => {
      jump k13(8)
    },
  }
}

fn main() -> unit {
  join ret15() -> unit {
    ()
  } in
  let t16 = match_string("hello") in
  let t17 = int32_to_string(t16) in
  let mtmp0 = string_println(t17) in
