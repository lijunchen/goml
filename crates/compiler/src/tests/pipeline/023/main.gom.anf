fn match_mixed_pair(pair/0: (int32, string)) -> int32 {
  join ret18(retv19: int32) -> int32 {
    retv19
  } in
  let x0 = pair/0.0 in
  let x1 = pair/0.1 in
  join k20(jp21: int32) -> int32 {
    jump ret18(jp21)
  } in
  match x1 {
    "zero" => {
      join k22(jp23: int32) -> int32 {
        jump k20(jp23)
      } in
      match x0 {
        0 => {
          jump k22(1)
        },
        _ => {
          jump k22(4)
        },
      }
    },
    "one" => {
      join k24(jp25: int32) -> int32 {
        jump k20(jp25)
      } in
      match x0 {
        0 => {
          jump k24(2)
        },
        1 => {
          jump k24(3)
        },
        _ => {
          jump k24(5)
        },
      }
    },
    _ => {
      join k26(jp27: int32) -> int32 {
        jump k20(jp27)
      } in
      match x0 {
        0 => {
          jump k26(2)
        },
        _ => {
          jump k26(5)
        },
      }
    },
  }
}

fn match_mixed_enum(value/1: Mixed) -> int32 {
  join ret28(retv29: int32) -> int32 {
    retv29
  } in
  join k30(jp31: int32) -> int32 {
    jump ret28(jp31)
  } in
  match value/1 {
    Tag_0 => {
      let x2 = Mixed::OnlyInt._0(value/1) in
      join k32(jp33: int32) -> int32 {
        jump k30(jp33)
      } in
      match x2 {
        0 => {
          jump k32(6)
        },
        _ => {
          jump k32(7)
        },
      }
    },
    Tag_1 => {
      let x3 = Mixed::OnlyStr._0(value/1) in
      join k34(jp35: int32) -> int32 {
        jump k30(jp35)
      } in
      match x3 {
        "zero" => {
          jump k34(8)
        },
        _ => {
          jump k34(9)
        },
      }
    },
    Tag_2 => {
      let x4 = Mixed::Both._0(value/1) in
      let x5 = Mixed::Both._1(value/1) in
      join k36(jp37: int32) -> int32 {
        jump k30(jp37)
      } in
      match x5 {
        "zero" => {
          join k38(jp39: int32) -> int32 {
            jump k36(jp39)
          } in
          match x4 {
            0 => {
              jump k38(10)
            },
            _ => {
              jump k38(12)
            },
          }
        },
        _ => {
          join k40(jp41: int32) -> int32 {
            jump k36(jp41)
          } in
          match x4 {
            0 => {
              jump k40(11)
            },
            _ => {
              jump k40(13)
            },
          }
        },
      }
    },
  }
}

