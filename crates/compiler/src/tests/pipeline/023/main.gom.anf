fn match_mixed_pair(pair/0: (int32, string)) -> int32 {
  let x0 = pair/0.0 in
  let x1 = pair/0.1 in
  join k18(jp19: int32) -> int32 {
    jp19
  } in
  match x1 {
    "zero" => {
      join k20(jp21: int32) -> int32 {
        jump k18(jp21)
      } in
      match x0 {
        0 => {
          jump k20(1)
        },
        _ => {
          jump k20(4)
        },
      }
    },
    "one" => {
      join k22(jp23: int32) -> int32 {
        jump k18(jp23)
      } in
      match x0 {
        0 => {
          jump k22(2)
        },
        1 => {
          jump k22(3)
        },
        _ => {
          jump k22(5)
        },
      }
    },
    _ => {
      join k24(jp25: int32) -> int32 {
        jump k18(jp25)
      } in
      match x0 {
        0 => {
          jump k24(2)
        },
        _ => {
          jump k24(5)
        },
      }
    },
  }
}

fn match_mixed_enum(value/1: Mixed) -> int32 {
  join k26(jp27: int32) -> int32 {
    jp27
  } in
  match value/1 {
    Tag_0 => {
      let x2 = Mixed::OnlyInt._0(value/1) in
      join k28(jp29: int32) -> int32 {
        jump k26(jp29)
      } in
      match x2 {
        0 => {
          jump k28(6)
        },
        _ => {
          jump k28(7)
        },
      }
    },
    Tag_1 => {
      let x3 = Mixed::OnlyStr._0(value/1) in
      join k30(jp31: int32) -> int32 {
        jump k26(jp31)
      } in
      match x3 {
        "zero" => {
          jump k30(8)
        },
        _ => {
          jump k30(9)
        },
      }
    },
    Tag_2 => {
      let x4 = Mixed::Both._0(value/1) in
      let x5 = Mixed::Both._1(value/1) in
      join k32(jp33: int32) -> int32 {
        jump k26(jp33)
      } in
      match x5 {
        "zero" => {
          join k34(jp35: int32) -> int32 {
            jump k32(jp35)
          } in
          match x4 {
            0 => {
              jump k34(10)
            },
            _ => {
              jump k34(12)
            },
          }
        },
        _ => {
          join k36(jp37: int32) -> int32 {
            jump k32(jp37)
          } in
          match x4 {
            0 => {
              jump k36(11)
            },
            _ => {
              jump k36(13)
            },
          }
        },
      }
    },
  }
}

fn main() -> unit {
  let t38 = (0, "zero") in
  let t39 = match_mixed_pair(t38) in
  let t40 = int32_to_string(t39) in
  let mtmp6 = string_println(t40) in
