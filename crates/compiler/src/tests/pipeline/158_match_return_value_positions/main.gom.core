fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn add_after_match(flag/0: bool) -> int32 {
  let value/1 = match flag/0 {
    true => {
      return 5
    },
    false => {
      7
    },
  } in
  (value/1 + 1)
}

fn receiver_after_match(flag/2: bool) -> string {
  trait_call[ToString::to_string](match flag/2 {
    true => {
      return "early"
    },
    false => {
      7
    },
  })
}

fn closure_after_match(flag/3: bool) -> int32 {
  let f/6 = |inner/4: bool| => {
    let value/5 = match inner/4 {
      true => {
        return 2
      },
      false => {
        4
      },
    } in
    (value/5 + 3)
  } in
  f/6(flag/3)
}

fn main() -> unit {
  let _wild0 = println(add_after_match(false)) in
  let _wild1 = println(add_after_match(true)) in
  let _wild2 = println(receiver_after_match(false)) in
  let _wild3 = println(receiver_after_match(true)) in
  let _wild4 = println(closure_after_match(false)) in
  let _wild5 = println(closure_after_match(true)) in
}