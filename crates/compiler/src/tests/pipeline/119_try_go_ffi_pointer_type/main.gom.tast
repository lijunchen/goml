fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

extern "go" "os" "*File" type File

extern "go" "os" open_file(path: string) -> Result[File, GoError]

extern "go" "os" file_name(file: File) -> string

extern "go" "os" close_file(file: File) -> Result[unit, GoError]

fn describe(path/0: string) -> Result[string, GoError] {
    let file/1: File = match (open_file : (string) -> Result[File, GoError])((path/0 : string)) {
        Result::Ok(try_value/4: File) => (try_value/4 : File),
        Result::Err(try_residual/4: GoError) => return Result::Err((try_residual/4 : GoError)),
    };
    let name/2: string = (file_name : (File) -> string)((file/1 : File));
    match (close_file : (File) -> Result[unit, GoError])((file/1 : File)) {
        Result::Ok(try_value/11: unit) => (try_value/11 : unit),
        Result::Err(try_residual/11: GoError) => return Result::Err((try_residual/11 : GoError)),
    };
    Result::Ok("ok=" + (name/2 : string))
}

fn show(res/3: Result[string, GoError]) -> string {
    match (res/3 : Result[string, GoError]) {
        Result::Ok(value/4: string) => (value/4 : string),
        Result::Err(err/5: GoError) => "err=" + (ToString::to_string : (GoError) -> string)((err/5 : GoError)),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((describe : (string) -> Result[string, GoError])("/etc/hosts")));
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((describe : (string) -> Result[string, GoError])("/definitely/missing")));
}