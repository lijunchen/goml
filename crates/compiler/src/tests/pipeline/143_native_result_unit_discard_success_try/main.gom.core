fn show(res/1: Result[unit, GoError]) -> string {
  match res/1 {
    Result::Ok(x4) => {
      {
        let x4 = Result::Ok._0(res/1) in
        match x4 {
          () => {
            "ok"
          },
        }
      }
    },
    Result::Err(x5) => {
      {
        let x5 = Result::Err._0(res/1) in
        {
          let err/2 = x5 in
          ("err=" + trait_call[ToString::to_string](err/2))
        }
      }
    },
  }
}

