fn pair_sum() -> int32 {
  let first/8 = ref(4) in
  let second/9 = ref(6) in
  let t45 = ref_get(first/8) in
  let t46 = ref_get(second/9) in
  let t44 = (t45 + t46) in
  let mtmp4 = ref_set(first/8, t44) in
  let t47 = ref_get(first/8) in
  let t48 = ref_get(second/9) in
  (t47 + t48)
}

fn reassign_nested(nested/10: Ref[Ref[int32]]) -> int32 {
  let inner/11 = ref_get(nested/10) in
  let t50 = ref_get(inner/11) in
  let t49 = (t50 + 7) in
  let mtmp5 = ref_set(inner/11, t49) in
  ref_get(inner/11)
}

