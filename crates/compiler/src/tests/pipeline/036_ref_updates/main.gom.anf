fn bump(cell/0: Ref[int32]) -> int32 {
  let t38 = ref_get(cell/0) in
  let t37 = (t38 + 1) in
  let mtmp0 = ref_set(cell/0, t37) in
  ref_get(cell/0)
}

fn flip(flag/1: Ref[bool]) -> bool {
  let current/2 = ref_get(flag/1) in
  let t39 = (!current/2) in
  let mtmp1 = ref_set(flag/1, t39) in
  ref_get(flag/1)
}

fn nested_total(cell/3: Ref[Ref[int32]]) -> int32 {
  let inner/4 = ref_get(cell/3) in
  let before/5 = ref_get(inner/4) in
  let t40 = (before/5 + 2) in
  let mtmp2 = ref_set(inner/4, t40) in
  let t41 = ref_get(inner/4) in
  (before/5 + t41)
}

fn alias_bump(cell/6: Ref[int32]) -> int32 {
  let alias/7 = cell/6 in
  let t43 = ref_get(alias/7) in
  let t42 = (t43 + 5) in
  let mtmp3 = ref_set(alias/7, t42) in
