fn main() -> unit {
  let a/1 = identity__T_uint8(42) in
  let t3 = uint8_to_string(a/1) in
  let _wild0 = string_println(t3) in
  let b/2 = identity__T_float32(3.14) in
  let t4 = float32_to_string(b/2) in
  let _wild1 = string_println(t4) in
  let c/3 = identity__T_int64(100) in
