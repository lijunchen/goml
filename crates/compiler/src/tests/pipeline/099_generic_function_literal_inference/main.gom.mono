fn main() -> unit {
  let a/1 = identity__T_uint8(42) in
  let _wild0 = println__T_string(uint8_to_string(a/1)) in
  let b/2 = identity__T_float32(3.14) in
  let _wild1 = println__T_string(float32_to_string(b/2)) in
  let c/3 = identity__T_int64(100) in
  let _wild2 = println__T_string(int64_to_string(c/3)) in
}

fn identity__T_uint8(x/0: uint8) -> uint8 {
  x/0
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}

fn identity__T_float32(x/0: float32) -> float32 {
  x/0
}

fn identity__T_int64(x/0: int64) -> int64 {
  x/0
}