package main;

fn identity[T](x: T) -> T {
    x
}

fn main() {
    let a: uint8 = identity(42);
    string_println(uint8_to_string(a));
    
    let b: float32 = identity(3.14);
    string_println(float32_to_string(b));
    
    let c: int64 = identity(100);
    string_println(int64_to_string(c));
}
