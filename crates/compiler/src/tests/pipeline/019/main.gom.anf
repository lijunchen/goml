fn main() -> unit {
  let start/25 = make_point() in
  let t60 = point32_to_string(start/25) in
  let mtmp31 = string_println(t60) in
  let t61 = Point { x: 1, y: 2 } in
  let swapped/26 = flip(t61) in
  let t62 = point32_to_string2(swapped/26) in
  let mtmp35 = string_println(t62) in
  let boxed/27 = wrap_int(3) in
  let point_box/28 = Wrapper__Point { value: swapped/26 } in
  let a/29 = x_add_1(start/25) in
  let t63 = point32_to_string3(a/29) in
  let mtmp37 = string_println(t63) in
  let t64 = x_add_1(start/25) in
  let a/30 = flip(t64) in
