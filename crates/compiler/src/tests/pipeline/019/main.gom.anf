fn make_point() -> Point {
  Point { x: 0, y: 0 }
}

fn flip(point/0: Point) -> Point {
  let mtmp0 = point/0 in
  let x1 = Point.x(mtmp0) in
  let x2 = Point.y(mtmp0) in
  let y/2 = x2 in
  let x/1 = x1 in
  Point { x: y/2, y: x/1 }
}

fn wrap_int(x/3: int32) -> Wrapper__int32 {
  Wrapper__int32 { value: x/3 }
}

fn x_add_1(p/4: Point) -> Point {
  let mtmp3 = p/4 in
  let x4 = Point.x(mtmp3) in
  let x5 = Point.y(mtmp3) in
  let y/6 = x5 in
  let x/5 = x4 in
  let t39 = (x/5 + 1) in
  Point { x: t39, y: y/6 }
}

fn get_x(p/7: Point) -> int32 {
  let mtmp6 = p/7 in
  let x7 = Point.x(mtmp6) in
  let x8 = Point.y(mtmp6) in
  let y/9 = x8 in
  let x/8 = x7 in
  x/8
}

fn get_y(p/10: Point) -> int32 {
  let mtmp9 = p/10 in
  let x10 = Point.x(mtmp9) in
  let x11 = Point.y(mtmp9) in
  let y/12 = x11 in
  let x/11 = x10 in
  y/12
}

fn point32_to_string(p/13: Point) -> string {
  let mtmp12 = p/13 in
  let x13 = Point.x(mtmp12) in
  let x14 = Point.y(mtmp12) in
  let y/15 = x14 in
  let x/14 = x13 in
  let t43 = int32_to_string(x/14) in
  let t42 = ("Point { x: " + t43) in
  let t41 = (t42 + ", y: ") in
  let t44 = int32_to_string(y/15) in
  let t40 = (t41 + t44) in
  (t40 + "}")
}

