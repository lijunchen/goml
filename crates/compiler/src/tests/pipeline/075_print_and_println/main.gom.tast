fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

impl ToString for S{
  fn to_string(self/0: S) -> string {
      "S(" + (int32::to_string : (int32) -> string)((self/0 : S).value) + ")"
  }
}

fn main() -> unit {
    (println : (int32) -> unit)(1);
    (println : (bool) -> unit)(true);
    (println : (string) -> unit)("hi");
    (println : (unit) -> unit)(());
    (println : (string) -> unit)((ToString::to_string : (int32) -> string)(2));
    (println : (string) -> unit)((int32::to_string : (int32) -> string)(2));
    let s/1: S = S { value: 9 };
    (println : (S) -> unit)((s/1 : S));
    let d/2: dyn ToString = to_dyn[ToString]{S}((s/1 : S));
    (println : (dyn ToString) -> unit)((d/2 : dyn ToString));
    let r/3: Ref[int32] = (ref : (int32) -> Ref[int32])(5);
    (println : (Ref[int32]) -> unit)((r/3 : Ref[int32]));
    (print : (string) -> unit)("no-newline");
    (println : (string) -> unit)("!");
}