fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#ToString#S#to_string(self/0: S) -> string {
  (("S(" + int32_to_string(S.value(self/0))) + ")")
}

fn main() -> unit {
  let _wild0 = println(1) in
  let _wild1 = println(true) in
  let _wild2 = println("hi") in
  let _wild3 = println(()) in
