fn trait_impl#ToString#S#to_string(self/0: S) -> string {
  (("S(" + int32_to_string(S.value(self/0))) + ")")
}

fn main() -> unit {
  let _wild0 = string_println(trait_call[ToString::to_string](1)) in
  let _wild1 = string_println(trait_call[ToString::to_string](true)) in
  let _wild2 = string_println(trait_call[ToString::to_string]("hi")) in
  let _wild3 = string_println(trait_call[ToString::to_string](())) in
  let _wild4 = string_println(trait_call[ToString::to_string](trait_call[ToString::to_string](2))) in
  let _wild5 = string_println(trait_call[ToString::to_string](int32_to_string(2))) in
  let s/1 = S { value: 9 } in
  let _wild6 = string_println(trait_call[ToString::to_string](s/1)) in
  let d/2 = to_dyn[ToString]{S}(s/1) in
  let _wild7 = string_println(trait_call[ToString::to_string](d/2)) in
  let r/3 = ref(5) in
  let _wild8 = string_println(trait_call[ToString::to_string](r/3)) in
  let _wild9 = string_print(trait_call[ToString::to_string]("no-newline")) in
  let _wild10 = string_println(trait_call[ToString::to_string]("!")) in
  ()
}