package main
file main.gom
  struct S {
        value: int32,
    }
    
    impl ToString for S {
      fn to_string(local/1/0: S) -> string {
          "S(" + self/0.value.to_string() + ")"
      }
    }
    
    fn main() -> unit {
        println(1i32);
        println(true);
        println("hi");
        println(());
        println(ToString::to_string(2i32));
        println(2i32.to_string());
        let local/1/1 = S {
            value: 9i32
        };
        println(s/1);
        let local/1/2: dyn ToString = s/1;
        println(d/2);
        let local/1/3 = ref(5i32);
        println(r/3);
        print("no-newline");
        println("!");
    }