package main
file main.gom
  trait Size {
      fn size(Self) -> int32;
    }
    
    struct Wrap[T] {
        value: T,
    }
    
    impl[T] Size for Wrap[T] {
      fn size(local/1/0: Wrap[T]) -> int32 {
          1
      }
    }
    
    fn main() {
        let local/1/1 = Wrap {
            value: 1
        };
        let local/1/2 = Wrap {
            value: "x"
        };
        println(int32_to_string(Size::size(a/1)));
        println(int32_to_string(Size::size(b/2)));
    }