fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#Size#Wrap[int32]#size(self/0: Wrap[int32]) -> int32 {
  10
}

fn trait_impl#Size#Wrap[string]#size(self/1: Wrap[string]) -> int32 {
  20
}

fn main() -> unit {
  let a/2 = Wrap { value: 1 } in
  let b/3 = Wrap { value: "x" } in
  let _wild0 = println(int32_to_string(trait_impl#Size#Wrap[int32]#size(a/2))) in
  let _wild1 = println(int32_to_string(trait_impl#Size#Wrap[string]#size(b/3))) in
  ()
}