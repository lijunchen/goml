package main
file main.gom
  trait Display {
      fn show(Self) -> string;
    }
    
    impl Display for int32 {
      fn show(local/1/0: int32) -> string {
          self/0.to_string()
      }
    }
    
    enum Boxed {
        One(dyn Display),
        Pair(dyn Display, dyn Display)
    }
    
    fn render(local/1/1: Boxed) -> string {
        match value/1 {
            ctor(def/1/2::v0)(local/1/2) => Display::show(inner/2),
            ctor(def/1/2::v1)(local/1/3, local/1/4) => Display::show(left/3) + "-" + Display::show(right/4),
        }
    }
    
    fn main() -> unit {
        println(def/1/3(ctor(def/1/2::v0)(42i32)));
        println(def/1/3(ctor(def/1/2::v1)(7i32, 9i32)));
    }