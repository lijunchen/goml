fn classify(x/0: int32) -> string {
  join ret6(retv7: string) -> string {
    retv7
  } in
  let t10 = (x/0 < 0) in
  join k8(jp9: string) -> string {
    jump ret6(jp9)
  } in
  if t10 {
    jump k8("negative")
  } else {
    let t13 = (0 < x/0) in
    join k11(jp12: string) -> string {
      jump k8(jp12)
    } in
    if t13 {
      jump k11("positive")
    } else {
      jump k11("zero")
    }
  }
}

fn triangle_type(a/1: int32, b/2: int32, c/3: int32) -> string {
  join ret14(retv15: string) -> string {
    retv15
  } in
  let t18 = (a/1 < b/2) in
  join k16(jp17: string) -> string {
    jump ret14(jp17)
  } in
  if t18 {
    let t21 = (b/2 < c/3) in
    join k19(jp20: string) -> string {
      jump k16(jp20)
    } in
    if t21 {
      jump k19("ascending")
    } else {
      jump k19("peak")
    }
  } else {
    let t24 = (a/1 < c/3) in
    join k22(jp23: string) -> string {
      jump k16(jp23)
    } in
    if t24 {
      jump k22("valley")
    } else {
      jump k22("flat")
    }
  }
}

