fn classify(x/0: int32) -> string {
  let t63 = (x/0 < 0) in
  if t63 {
    "negative"
  } else {
    let t64 = (0 < x/0) in
    if t64 {
      "positive"
    } else {
      "zero"
    }
  }
}

fn triangle_type(a/1: int32, b/2: int32, c/3: int32) -> string {
  let t65 = (a/1 < b/2) in
  if t65 {
    let t66 = (b/2 < c/3) in
    if t66 {
      "ascending"
    } else {
      "peak"
    }
  } else {
    let t67 = (a/1 < c/3) in
    if t67 {
      "valley"
    } else {
      "flat"
    }
  }
}

fn main() -> unit {
  let t68 = (-42) in
  let first/4 = classify(t68) in
  let second/5 = classify(0) in
  let third/6 = classify(17) in
  let shape1/7 = triangle_type(1, 2, 3) in
  let shape2/8 = triangle_type(3, 2, 1) in
  let shape3/9 = triangle_type(2, 3, 2) in
  let mtmp31 = string_println(first/4) in
  let mtmp47 = string_println(second/5) in
  let mtmp55 = string_println(third/6) in
  let mtmp59 = string_println(shape1/7) in
  let mtmp61 = string_println(shape2/8) in
  let mtmp62 = string_println(shape3/9) in
  ()
}