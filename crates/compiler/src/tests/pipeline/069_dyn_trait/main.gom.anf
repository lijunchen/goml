fn trait_impl#Display#Point#show(self/0: Point) -> string {
  let t7 = Point.x(self/0) in
  let t6 = int32_to_string(t7) in
  let t5 = ("Point(" + t6) in
  let t4 = (t5 + ",") in
  let t9 = Point.y(self/0) in
  let t8 = int32_to_string(t9) in
  let t3 = (t4 + t8) in
  (t3 + ")")
}

fn trait_impl#Display#Flag#show(self/1: Flag) -> string {
  let t10 = Flag.value(self/1) in
  if t10 {
    "Flag(true)"
  } else {
    "Flag(false)"
  }
}

fn main() -> unit {
  let p/2 = Point { x: 1, y: 2 } in
  let t/3 = Flag { value: true } in
  let dp/4 = to_dyn[Display]{Point}(p/2) in
  let dt/5 = to_dyn[Display]{Flag}(t/3) in
  let t11 = dyn_call[Display::show](dp/4) in
  let mtmp1 = string_println(t11) in
  let t12 = dyn_call[Display::show](dt/5) in
  let mtmp2 = string_println(t12) in
  ()
}