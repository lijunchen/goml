fn trait_impl#Display#Point#show(self/0: Point) -> string {
  let t2 = Point.x(self/0) in
  let t3 = int32_to_string(t2) in
  let t4 = ("Point(" + t3) in
  let t5 = (t4 + ",") in
  let t6 = Point.y(self/0) in
  let t7 = int32_to_string(t6) in
  let t8 = (t5 + t7) in
  let t9 = (t8 + ")") in
  t9
}

