  }, 2))
}

fn show(opt/4: Option[int32]) -> string {
  match opt/4 {
    Option::None => {
      "none"
    },
    Option::Some(x2) => {
      {
        let x2 = Option::Some._0(opt/4) in
        {
          let value/5 = x2 in
          ("some=" + trait_call[ToString::to_string](value/5))
        }
      }
    },
  }
}

