  (a/1 + b/2)
}

fn plus_two(flag/3: bool) -> Option[int32] {
  Option::Some(add({
    let mtmp0 = maybe_value(flag/3) in
    match mtmp0 {
      Option::None => {
        return Option::None
      },
      Option::Some(x1) => {
        {
          let x1 = Option::Some._0(mtmp0) in
          {
            let try_value/15 = x1 in
            try_value/15
          }
