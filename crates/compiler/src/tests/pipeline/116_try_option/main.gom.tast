    (a/1 : int32) + (b/2 : int32)
}

fn plus_two(flag/3: bool) -> Option[int32] {
    Option::Some((add : (int32, int32) -> int32)(match (maybe_value : (bool) -> Option[int32])((flag/3 : bool)) {
        Option::Some(try_value/15: int32) => (try_value/15 : int32),
        Option::None => return Option::None,
    }, 2))
}

fn show(opt/4: Option[int32]) -> string {
    match (opt/4 : Option[int32]) {
