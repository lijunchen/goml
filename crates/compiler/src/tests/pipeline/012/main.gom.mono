fn fib(x/0: int32) -> int32 {
  {
    let mtmp0 = (x/0 < 2) in
    match mtmp0 {
      true => {
        1
      },
      false => {
        (fib((x/0 - 1)) + fib((x/0 - 2)))
      },
    }
  }
}

fn main() -> unit {
  let mtmp1 = print__T_int32(fib(10)) in
  {
    ()
  }
}

fn print__T_int32(value/0: int32) -> unit {
  string_print(int32_to_string(value/0))
}