fn fib(x/0: int32) -> int32 {
    match (x/0 : int32) < 2 {
        false => (fib : (int32) -> int32)((x/0 : int32) - 1) + (fib : (int32) -> int32)((x/0 : int32) - 2),
        true => 1,
    };
}

fn main() -> unit {
    let _ : unit = (print : (int32) -> unit)((fib : (int32) -> int32)(10));
    ();
}