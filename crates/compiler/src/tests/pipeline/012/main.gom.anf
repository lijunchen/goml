fn fib(x/0: int32) -> int32 {
  join ret2(retv3: int32) -> int32 {
    retv3
  } in
  let mtmp0 = (x/0 < 2) in
  join k4(jp5: int32) -> int32 {
    jump ret2(jp5)
  } in
  match mtmp0 {
    true => {
      jump k4(1)
    },
    false => {
      let t6 = (x/0 - 1) in
      let t7 = fib(t6) in
      let t8 = (x/0 - 2) in
      let t9 = fib(t8) in
      let t10 = (t7 + t9) in
      jump k4(t10)
    },
  }
}

