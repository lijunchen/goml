extern "go" "net/url" "*URL" type URL

#[go_error_last]
extern "go" "net/url" "Parse" parse_url(text: string) -> Result[URL, GoError]

#[go_field_get("Host")]
extern "go" "net/url" url_host(url: URL) -> string

#[go_field_set("Path")]
extern "go" "net/url" url_set_path(url: URL, path: string) -> unit

extern "go" "net/url" "(*URL).String" url_string(url: URL) -> string

fn update(text: string, path: string) -> Result[string, GoError] {
    let url = parse_url(text)?;
    let host = url_host(url);
    url_set_path(url, path);
    Result::Ok(host + "|" + url_string(url))
}

fn show(res: Result[string, GoError]) -> string {
    match res {
        Result::Ok(text) => text,
        Result::Err(err) => err.to_string(),
    }
}

fn main() {
    println(show(update("https://example.com/old", "/new")));
}

