fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let sum/0: Ref[int32] = (ref : (int32) -> Ref[int32])(0);
    let i/1: Ref[int32] = (ref : (int32) -> Ref[int32])(1);
    while (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) <= 100 {
        {
            if (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) == 50 {
                {
                    break
                }
            } else {
                {
                    ()
                }
            };
            (ref_set : (Ref[int32], int32) -> unit)((sum/0 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((sum/0 : Ref[int32])) + (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])));
            (ref_set : (Ref[int32], int32) -> unit)((i/1 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) + 1);
        }
    };
    let _ : unit = (print : (string) -> unit)("sum up to break: ");
    let _ : unit = (println : (int32) -> unit)((ref_get : (Ref[int32]) -> int32)((sum/0 : Ref[int32])));
    let even_sum/2: Ref[int32] = (ref : (int32) -> Ref[int32])(0);
    let j/3: Ref[int32] = (ref : (int32) -> Ref[int32])(1);
    while (ref_get : (Ref[int32]) -> int32)((j/3 : Ref[int32])) <= 10 {
        {
            let cur/4: int32 = (ref_get : (Ref[int32]) -> int32)((j/3 : Ref[int32]));
            (ref_set : (Ref[int32], int32) -> unit)((j/3 : Ref[int32]), (cur/4 : int32) + 1);
            if (cur/4 : int32) == (cur/4 : int32) / 2 * 2 {
                {
                    (ref_set : (Ref[int32], int32) -> unit)((even_sum/2 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((even_sum/2 : Ref[int32])) + (cur/4 : int32));
                    continue
                }
            } else {
                {
                    ()
                }
            };
        }
    };
    let _ : unit = (print : (string) -> unit)("even sum: ");
    let _ : unit = (println : (int32) -> unit)((ref_get : (Ref[int32]) -> int32)((even_sum/2 : Ref[int32])));
}