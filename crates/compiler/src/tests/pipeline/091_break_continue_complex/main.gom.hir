package main
file main.gom
  fn main() {
        let local/1/0 = ref(0i32);
        let local/1/1 = ref(1i32);
        while ref_get(i/1) <= 100i32 {
            {
                if ref_get(i/1) == 50i32 {
                    break
                } else {
                    ()
                };
                ref_set(sum/0, ref_get(sum/0) + ref_get(i/1));
                ref_set(i/1, ref_get(i/1) + 1i32);
            }
        };
        let _ = print("sum up to break: ");
        let _ = println(ref_get(sum/0));
        let local/1/2 = ref(0i32);
        let local/1/3 = ref(1i32);
        while ref_get(j/3) <= 10i32 {
            {
                let local/1/4 = ref_get(j/3);
                ref_set(j/3, cur/4 + 1i32);
                if cur/4 == cur/4 / 2i32 * 2i32 {
                    ref_set(even_sum/2, ref_get(even_sum/2) + cur/4);
                    continue
                } else {
                    ()
                };
            }
        };
        let _ = print("even sum: ");
        let _ = println(ref_get(even_sum/2));
    }