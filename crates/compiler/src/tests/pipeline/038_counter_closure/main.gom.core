fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn make_counter() -> (() -> int32, () -> unit) {
  let cell/0 = ref(0) in
  let next/2 = || => let next/1 = (ref_get(cell/0) + 1) in
  let mtmp1 = ref_set(cell/0, next/1) in
  next/1 in
  let reset/3 = || => let mtmp0 = ref_set(cell/0, 0) in
  () in
  (next/2, reset/3)
}

fn main() -> unit {
  let counter/4 = make_counter() in
  let mtmp69 = counter/4 in
  let x70 = mtmp69.0 in
  let x71 = mtmp69.1 in
  let reset/6 = x71 in
  let next/5 = x70 in
  let first/7 = next/5() in
  let second/8 = next/5() in
  let mtmp105 = reset/6() in
  let third/9 = next/5() in
  let new_counter/10 = make_counter() in
  let mtmp121 = new_counter/10 in
  let x122 = mtmp121.0 in
  let x123 = mtmp121.1 in
  let new_next/11 = x122 in
  let fourth/12 = new_next/11() in
  let mtmp131 = string_println(int32_to_string(first/7)) in
  let mtmp135 = string_println(int32_to_string(second/8)) in
  let mtmp137 = string_println(int32_to_string(third/9)) in
  let mtmp138 = string_println(int32_to_string(fourth/12)) in
  ()
}