fn make_counter() -> (closure_env_next_0, closure_env_reset_1) {
  let cell/0 = ref(0) in
  let next/2 = closure_env_next_0 { cell_0: cell/0 } in
  let reset/3 = closure_env_reset_1 { cell_0: cell/0 } in
  (next/2, reset/3)
}

fn main() -> unit {
  let counter/4 = make_counter() in
  let mtmp69 = counter/4 in
  let x70 = mtmp69.0 in
  let x71 = mtmp69.1 in
  let reset/6 = x71 in
  let next/5 = x70 in
  let first/7 = inherent#closure_env_next_0#closure_env_next_0#apply(next/5) in
  let second/8 = inherent#closure_env_next_0#closure_env_next_0#apply(next/5) in
  let mtmp105 = inherent#closure_env_reset_1#closure_env_reset_1#apply(reset/6) in
  let third/9 = inherent#closure_env_next_0#closure_env_next_0#apply(next/5) in
  let new_counter/10 = make_counter() in
  let mtmp121 = new_counter/10 in
  let x122 = mtmp121.0 in
  let x123 = mtmp121.1 in
  let new_next/11 = x122 in
  let fourth/12 = inherent#closure_env_next_0#closure_env_next_0#apply(new_next/11) in
  let t141 = int32_to_string(first/7) in
  let mtmp131 = string_println(t141) in
  let t142 = int32_to_string(second/8) in
  let mtmp135 = string_println(t142) in
  let t143 = int32_to_string(third/9) in
  let mtmp137 = string_println(t143) in
  let t144 = int32_to_string(fourth/12) in
  let mtmp138 = string_println(t144) in
  ()
}

fn inherent#closure_env_next_0#closure_env_next_0#apply(env139: closure_env_next_0) -> int32 {
  let cell/0 = closure_env_next_0.cell_0(env139) in
  let t145 = ref_get(cell/0) in
  let next/1 = (t145 + 1) in
  let mtmp1 = ref_set(cell/0, next/1) in
  next/1
}

fn inherent#closure_env_reset_1#closure_env_reset_1#apply(env140: closure_env_reset_1) -> unit {
  let cell/0 = closure_env_reset_1.cell_0(env140) in
  let mtmp0 = ref_set(cell/0, 0) in
  ()
}