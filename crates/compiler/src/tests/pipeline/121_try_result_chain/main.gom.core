fn parse_text(ok/0: bool) -> Result[string, string] {
  if ok/0 {
      {
        Result::Ok("goml")
      }
  } else {
      {
        Result::Err("parse failed")
      }
  }
}

fn normalize_text(ok/1: bool) -> Result[string, string] {
  let text/2 = {
    let mtmp0 = parse_text(ok/1) in
    match mtmp0 {
      Result::Ok(x1) => {
        {
          let x1 = Result::Ok._0(mtmp0) in
          {
            let try_value/12 = x1 in
            try_value/12
          }
        }
      },
      Result::Err(x2) => {
        {
          let x2 = Result::Err._0(mtmp0) in
          {
            let try_residual/12 = x2 in
            return Result::Err(try_residual/12)
          }
        }
      },
    }
  } in
  Result::Ok((text/2 + "!"))
}

fn decorate_text(ok/3: bool) -> Result[string, string] {
  let text/4 = {
    let mtmp3 = normalize_text(ok/3) in
    match mtmp3 {
      Result::Ok(x4) => {
        {
          let x4 = Result::Ok._0(mtmp3) in
          {
            let try_value/20 = x4 in
            try_value/20
          }
        }
      },
      Result::Err(x5) => {
        {
          let x5 = Result::Err._0(mtmp3) in
          {
            let try_residual/20 = x5 in
            return Result::Err(try_residual/20)
          }
        }
      },
    }
  } in
  Result::Ok((("[" + text/4) + "]"))
}

fn show(res/5: Result[string, string]) -> string {
  match res/5 {
    Result::Ok(x6) => {
      {
        let x6 = Result::Ok._0(res/5) in
