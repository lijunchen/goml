fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn parse_text(ok/0: bool) -> Result[string, string] {
    if (ok/0 : bool) {
        {
            Result::Ok("goml")
        }
    } else {
        {
            Result::Err("parse failed")
        }
    }
}

fn normalize_text(ok/1: bool) -> Result[string, string] {
    let text/2: string = match (parse_text : (bool) -> Result[string, string])((ok/1 : bool)) {
        Result::Ok(try_value/12: string) => (try_value/12 : string),
        Result::Err(try_residual/12: string) => return Result::Err((try_residual/12 : string)),
    };
    Result::Ok((text/2 : string) + "!")
}

fn decorate_text(ok/3: bool) -> Result[string, string] {
    let text/4: string = match (normalize_text : (bool) -> Result[string, string])((ok/3 : bool)) {
        Result::Ok(try_value/20: string) => (try_value/20 : string),
        Result::Err(try_residual/20: string) => return Result::Err((try_residual/20 : string)),
    };
    Result::Ok("[" + (text/4 : string) + "]")
}

fn show(res/5: Result[string, string]) -> string {
    match (res/5 : Result[string, string]) {
        Result::Ok(value/6: string) => "ok " + (value/6 : string),
        Result::Err(err/7: string) => "err " + (err/7 : string),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, string]) -> string)((decorate_text : (bool) -> Result[string, string])(true)));
    (println : (string) -> unit)((show : (Result[string, string]) -> string)((decorate_text : (bool) -> Result[string, string])(false)));
}