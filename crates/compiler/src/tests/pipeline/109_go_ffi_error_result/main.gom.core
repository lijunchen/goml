fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn describe_duration(input/0: string) -> string {
  {
    let mtmp0 = parse_duration(input/0) in
    match mtmp0 {
      Result::Ok(x1) => {
        {
          let x1 = Result::Ok._0(mtmp0) in
          {
            let value/1 = x1 in
            format_duration("ok=%v", value/1)
          }
        }
      },
      Result::Err(x2) => {
        {
          let x2 = Result::Err._0(mtmp0) in
          {
            let err/2 = x2 in
            ("err=" + trait_call[ToString::to_string](err/2))
          }
        }
      },
    }
  }
}

fn describe_setenv() -> string {
  {
    let mtmp3 = setenv("GOML_FFI_TEST", "ok") in
    match mtmp3 {
      Result::Ok(x4) => {
        {
          let x4 = Result::Ok._0(mtmp3) in
          match x4 {
            () => {
              "setenv=ok"
            },
          }
        }
      },
      Result::Err(x5) => {
        {
          let x5 = Result::Err._0(mtmp3) in
          {
            let err/3 = x5 in
            ("setenv_err=" + trait_call[ToString::to_string](err/3))
          }
        }
      },
    }
  }
}

fn main() -> unit {
  let _wild6 = println(describe_duration("1.5s")) in
  let _wild7 = println(describe_duration("bad")) in
  let _wild8 = println(describe_setenv()) in
}