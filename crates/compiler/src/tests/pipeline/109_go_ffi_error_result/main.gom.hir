package main
file main.gom
  extern "go" "time" "Duration" type Duration
    
    #[go_error_last]
extern "go" "time" "ParseDuration" parse_duration(s: string) -> Result[Duration, GoError]
    
    #[go_error]
extern "go" "os" "Setenv" setenv(key: string, value: string) -> Result[unit, GoError]
    
    extern "go" "fmt" "Sprintf" format_duration(format: string, value: Duration) -> string
    
    fn describe_duration(local/1/0: string) -> string {
        match def/1/1(input/0) {
            Result::Ok(local/1/1) => def/1/3("ok=%v", value/1),
            Result::Err(local/1/2) => "err=" + err/2.to_string(),
        }
    }
    
    fn describe_setenv() -> string {
        match def/1/2("GOML_FFI_TEST", "ok") {
            Result::Ok(()) => "setenv=ok",
            Result::Err(local/1/3) => "setenv_err=" + err/3.to_string(),
        }
    }
    
    fn main() -> unit {
        println(def/1/4("1.5s"));
        println(def/1/4("bad"));
        println(def/1/5());
    }