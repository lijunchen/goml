fn print_int_list(xs/0: IntList) -> unit {
  join k25() -> unit {
    ()
  } in
  match xs/0 {
    Tag_0 => {
      let t26 = string_print("Nil") in
      jump k25()
    },
    Tag_1 => {
      let x0 = IntList::Cons._0(xs/0) in
      let x1 = IntList::Cons._1(xs/0) in
      let xs/2 = x1 in
      let x/1 = x0 in
      let mtmp2 = string_print("Cons") in
      let mtmp3 = string_print("(") in
      let t27 = int32_to_string(x/1) in
      let mtmp4 = string_print(t27) in
      let mtmp5 = string_print(", ") in
      let mtmp6 = print_int_list(xs/2) in
      let mtmp7 = string_print(")") in
