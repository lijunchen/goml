}

fn int_list_rev_aux(xs/3: IntList, acc/4: IntList) -> IntList {
  join k28(jp29: IntList) -> IntList {
    jp29
  } in
  match xs/3 {
    Tag_0 => {
      jump k28(acc/4)
    },
    Tag_1 => {
      let x8 = IntList::Cons._0(xs/3) in
      let x9 = IntList::Cons._1(xs/3) in
      let tail/6 = x9 in
      let head/5 = x8 in
      let t30 = IntList::Cons(head/5, acc/4) in
      let t31 = int_list_rev_aux(tail/6, t30) in
      jump k28(t31)
    },
  }
}

fn int_list_rev(xs/7: IntList) -> IntList {
  let t32 = int_list_rev_aux(xs/7, Tag_0) in
  t32
}

fn int_list_length(xs/8: IntList) -> int32 {
  join k33(jp34: int32) -> int32 {
    jp34
  } in
  match xs/8 {
    Tag_0 => {
      jump k33(0)
    },
    Tag_1 => {
      let x10 = IntList::Cons._0(xs/8) in
      let x11 = IntList::Cons._1(xs/8) in
      let xs/9 = x11 in
      let t35 = int_list_length(xs/9) in
      let t36 = (1 + t35) in
      jump k33(t36)
    },
  }
}

fn print_int_list_length(xs/10: IntList) -> unit {
  let mtmp12 = string_print("Length: ") in
  let t37 = int_list_length(xs/10) in
  let t38 = int32_to_string(t37) in
  let mtmp13 = string_println(t38) in
  ()
}

fn main() -> unit {
