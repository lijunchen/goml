fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  let a/0 = (true, false) in
  let mtmp2 = {
    let x0 = a/0.0 in
    let x1 = a/0.1 in
    match x0 {
      true => {
        {
          let b/1 = x1 in
          print(b/1)
        }
      },
      false => {
        ()
      },
    }
  } in
  {
    let c/2 = (true, true) in
    {
      let x3 = c/2.0 in
      let x4 = c/2.1 in
      match x3 {
        true => {
          {
            let d/3 = x4 in
            print(d/3)
          }
        },
        false => {
          ()
        },
      }
    }
  }
}