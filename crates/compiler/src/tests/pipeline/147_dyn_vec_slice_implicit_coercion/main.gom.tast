fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

impl Display for int32{
  fn show(self/0: int32) -> string {
      (int32::to_string : (int32) -> string)((self/0 : int32))
  }
}

fn render(x/1: dyn Display) -> string {
    (dyn Display::show : (dyn Display) -> string)((x/1 : dyn Display))
}

fn main() -> unit {
    let v/2: Vec[dyn Display] = (vec_new : () -> Vec[dyn Display])();
    let v/3: Vec[dyn Display] = (vec_push : (Vec[dyn Display], dyn Display) -> Vec[dyn Display])((v/2 : Vec[dyn Display]), to_dyn[Display]{int32}(10));
    let v/4: Vec[dyn Display] = (vec_push : (Vec[dyn Display], dyn Display) -> Vec[dyn Display])((v/3 : Vec[dyn Display]), to_dyn[Display]{int32}(20));
    let s/5: Slice[dyn Display] = (slice : (Vec[dyn Display], int32, int32) -> Slice[dyn Display])((v/4 : Vec[dyn Display]), 0, 2);
    (println : (string) -> unit)((render : (dyn Display) -> string)((slice_get : (Slice[dyn Display], int32) -> dyn Display)((s/5 : Slice[dyn Display]), 0)));
    let t/6: Slice[dyn Display] = (slice_sub : (Slice[dyn Display], int32, int32) -> Slice[dyn Display])((s/5 : Slice[dyn Display]), 1, 2);
    (println : (string) -> unit)((render : (dyn Display) -> string)((slice_get : (Slice[dyn Display], int32) -> dyn Display)((t/6 : Slice[dyn Display]), 0)));
}