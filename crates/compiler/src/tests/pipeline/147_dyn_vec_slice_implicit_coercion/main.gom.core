fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#Display#int32#show(self/0: int32) -> string {
  int32_to_string(self/0)
}

fn render(x/1: dyn Display) -> string {
  dyn_call[Display::show](x/1)
}

fn main() -> unit {
  let v/2 = inherent#Vec#Vec[dynDisplay]#new() in
  let v/3 = inherent#Vec#Vec[dynDisplay]#push(v/2, to_dyn[Display]{int32}(10)) in
  let v/4 = inherent#Vec#Vec[dynDisplay]#push(v/3, to_dyn[Display]{int32}(20)) in
  let s/5 = inherent#Vec#Vec[dynDisplay]#slice(v/4, 0, 2) in
  let _wild0 = println(render(slice_get(s/5, 0))) in
  let t/6 = inherent#Slice#Slice[dynDisplay]#sub(s/5, 1, 2) in
  let _wild1 = println(render(slice_get(t/6, 0))) in
}

fn inherent#Vec#Vec[T]#new() -> Vec[T] {
  vec_new()
}

fn inherent#Vec#Vec[T]#push(self/67: Vec[T], elem/68: T) -> Vec[T] {
  vec_push(self/67, elem/68)
}

fn inherent#Vec#Vec[T]#slice(self/75: Vec[T], start/76: int32, end/77: int32) -> Slice[T] {
  slice(self/75, start/76, end/77)
}

fn inherent#Slice#Slice[T]#sub(self/81: Slice[T], start/82: int32, end/83: int32) -> Slice[T] {
  slice_sub(self/81, start/82, end/83)
}