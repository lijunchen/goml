fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let x/0: int32 = 1;
    let y/1: int8 = 1;
    let _ : unit = (print : (string) -> unit)("int32: ");
    let _ : unit = (println : (int32) -> unit)((x/0 : int32));
    let _ : unit = (print : (string) -> unit)("int8: ");
    let _ : unit = (println : (int8) -> unit)((y/1 : int8));
}