fn main() -> unit {
  let x/0 = 1 in
  let y/1 = 1 in
  let mtmp7 = print__T_string("int32: ") in
  let mtmp11 = println__T_int32(x/0) in
  let mtmp13 = print__T_string("int8: ") in
  let mtmp14 = println__T_int8(y/1) in
  ()
}

fn print__T_string(value/0: string) -> unit {
  string_print(value/0)
}

fn println__T_int32(value/1: int32) -> unit {
  string_println(int32_to_string(value/1))
}

fn println__T_int8(value/1: int8) -> unit {
  string_println(int8_to_string(value/1))
}