fn point_type(p/8: Point) -> string {
  join ret34(retv35: string) -> string {
    retv35
  } in
  let x7 = Point.x(p/8) in
  let x8 = Point.y(p/8) in
  join k36(jp37: string) -> string {
    jump ret34(jp37)
  } in
  match x7 {
    0 => {
      join k38(jp39: string) -> string {
        jump k36(jp39)
      } in
      match x8 {
        0 => {
          jump k38("origin")
        },
        1 => {
          jump k38("up")
        },
        _ => {
          let y/9 = x8 in
          let mtmp9 = (0 < y/9) in
          join k40(jp41: string) -> string {
            jump k38(jp41)
