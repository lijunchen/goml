fn point32_to_string(p/0: Point) -> string {
  let mtmp0 = p/0 in
  let x1 = Point.x(mtmp0) in
  let x2 = Point.y(mtmp0) in
  let y/2 = x2 in
  let x/1 = x1 in
  let t11 = int32_to_string(x/1) in
  let t12 = ("Point { x: " + t11) in
  let t13 = (t12 + ", y: ") in
  let t14 = int32_to_string(y/2) in
  let t15 = (t13 + t14) in
  let t16 = (t15 + " }") in
  t16
}

fn color_to_string(c/3: Color) -> string {
  join k17(jp18: string) -> string {
    jp18
  } in
  match c/3 {
    Tag_0 => {
      jump k17("Red")
    },
    Tag_1 => {
      jump k17("Green")
    },
    Tag_2 => {
      jump k17("Blue")
    },
  }
}

fn line_to_string(l/4: Line) -> string {
  let mtmp3 = l/4 in
  let x4 = Line.from(mtmp3) in
  let x5 = Line.to(mtmp3) in
  let x6 = Line.color(mtmp3) in
  let color/7 = x6 in
  let to/6 = x5 in
  let from/5 = x4 in
  let t19 = point32_to_string(from/5) in
  let t20 = ("Line { from: " + t19) in
  let t21 = (t20 + ", to: ") in
  let t22 = point32_to_string(to/6) in
  let t23 = (t21 + t22) in
  let t24 = (t23 + ", color: ") in
  let t25 = color_to_string(color/7) in
  let t26 = (t24 + t25) in
  let t27 = (t26 + " }") in
  t27
}

fn point_type(p/8: Point) -> string {
  let x7 = Point.x(p/8) in
  let x8 = Point.y(p/8) in
  join k28(jp29: string) -> string {
    jp29
  } in
  match x7 {
    0 => {
      join k30(jp31: string) -> string {
        jump k28(jp31)
      } in
      match x8 {
        0 => {
          jump k30("origin")
        },
        1 => {
          jump k30("up")
        },
        _ => {
          let y/9 = x8 in
          let mtmp9 = (0 < y/9) in
          join k32(jp33: string) -> string {
            jump k30(jp33)
          } in
          match mtmp9 {
            true => {
              jump k32("above")
            },
            false => {
              jump k32("below")
            },
          }
        },
      }
    },
    1 => {
      join k34(jp35: string) -> string {
        jump k28(jp35)
      } in
      match x8 {
        0 => {
          jump k34("right")
        },
        _ => {
          jump k34("unknown")
        },
      }
    },
    _ => {
      jump k28("unknown")
    },
  }
}

fn main() -> unit {
  let p0/10 = Point { x: 0, y: 0 } in
  let t36 = point_type(p0/10) in
  let mtmp10 = println__T_string(t36) in
  let p1/11 = Point { x: 10, y: 10 } in
  let line/12 = Line { from: p0/10, to: p1/11, color: Tag_0 } in
  let t37 = line_to_string(line/12) in
  let t38 = println__T_string(t37) in
  t38
}

fn println__T_string(value/1: string) -> unit {
  let t39 = string_println(value/1) in
  t39
}