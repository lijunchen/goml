package main
file main.gom
  struct S {
        value: int32,
    }
    
    impl ToString for S {
      fn to_string(local/1/0: S) -> string {
        "S(" + int32_to_string(self/0.value) + ")";
      }
    }
    
    fn main() -> unit {
      let local/1/1 = S {
          value: 7
      };
      println(s/1.to_string());
      ();
    }