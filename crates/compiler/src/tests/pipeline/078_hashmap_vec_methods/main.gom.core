fn print_opt_int(x/9: Option[int32]) -> unit {
  match x/9 {
    Option::None => {
      println("none")
    },
    Option::Some(x7) => {
      let x7 = Option::Some._0(x/9) in
      let v/10 = x7 in
      println(v/10)
