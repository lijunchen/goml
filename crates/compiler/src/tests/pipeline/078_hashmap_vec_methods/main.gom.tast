impl Eq for Key{
  fn eq(self/0: Key, other/1: Key) -> bool {
    match ((self/0 : Key), (other/1 : Key)) {
        (Key::A, Key::A) => true,
        (Key::B(__l1_0/2: int32), Key::B(__r1_0/3: int32)) => true && (Eq::eq : (int32, int32) -> bool)((__l1_0/2 : int32), (__r1_0/3 : int32)),
        _ : (Key, Key) => false,
    }
  }
}

impl Hash for Key{
  fn hash(self/4: Key) -> uint64 {
    match (self/4 : Key) {
        Key::A => {
              let h/5: uint64 = 14695981039346656037 + 1;
              (h/5 : uint64);
          },
        Key::B(__field1_0/6: int32) => {
              let h/7: uint64 = 14695981039346656037 + 2;
              let h/8: uint64 = (h/7 : uint64) * 1099511628211 + (Hash::hash : (int32) -> uint64)((__field1_0/6 : int32));
              (h/8 : uint64);
          },
    }
  }
}

fn print_opt_int(x/9: Option[int32]) -> unit {
    match (x/9 : Option[int32]) {
        Option::Some(v/10: int32) => (println : (int32) -> unit)((v/10 : int32)),
        Option::None => (println : (string) -> unit)("none"),
    };
}

fn main() -> unit {
    let v/11: Vec[int32] = (Vec[int32]::new : () -> Vec[int32])();
    let v/12: Vec[int32] = (Vec[int32]::push : (Vec[int32], int32) -> Vec[int32])((v/11 : Vec[int32]), 10);
    let v/13: Vec[int32] = (Vec[int32]::push : (Vec[int32], int32) -> Vec[int32])((v/12 : Vec[int32]), 20);
    let v/14: Vec[int32] = (Vec[int32]::push : (Vec[int32], int32) -> Vec[int32])((v/13 : Vec[int32]), 30);
    (println : (int32) -> unit)((Vec[int32]::get : (Vec[int32], int32) -> int32)((v/14 : Vec[int32]), 0));
    (println : (int32) -> unit)((Vec[int32]::get : (Vec[int32], int32) -> int32)((v/14 : Vec[int32]), 1));
    (println : (int32) -> unit)((Vec[int32]::get : (Vec[int32], int32) -> int32)((v/14 : Vec[int32]), 2));
    (println : (int32) -> unit)((Vec[int32]::len : (Vec[int32]) -> int32)((v/14 : Vec[int32])));
    let m/15: HashMap[Key, int32] = (HashMap[Key, int32]::new : () -> HashMap[Key, int32])();
    (HashMap[Key, int32]::set : (HashMap[Key, int32], Key, int32) -> unit)((m/15 : HashMap[Key, int32]), Key::A, 10);
    (HashMap[Key, int32]::set : (HashMap[Key, int32], Key, int32) -> unit)((m/15 : HashMap[Key, int32]), Key::B(1), 20);
    (println : (int32) -> unit)((HashMap[Key, int32]::len : (HashMap[Key, int32]) -> int32)((m/15 : HashMap[Key, int32])));
    (print_opt_int : (Option[int32]) -> unit)((HashMap[Key, int32]::get : (HashMap[Key, int32], Key) -> Option[int32])((m/15 : HashMap[Key, int32]), Key::A));
    (println : (bool) -> unit)((HashMap[Key, int32]::contains : (HashMap[Key, int32], Key) -> bool)((m/15 : HashMap[Key, int32]), Key::B(1)));
    (HashMap[Key, int32]::remove : (HashMap[Key, int32], Key) -> unit)((m/15 : HashMap[Key, int32]), Key::B(1));
    (println : (bool) -> unit)((HashMap[Key, int32]::contains : (HashMap[Key, int32], Key) -> bool)((m/15 : HashMap[Key, int32]), Key::B(1)));
    (println : (int32) -> unit)((HashMap[Key, int32]::len : (HashMap[Key, int32]) -> int32)((m/15 : HashMap[Key, int32])));
    ();
}