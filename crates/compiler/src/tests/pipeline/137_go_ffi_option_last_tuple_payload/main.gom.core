fn describe(text/0: string) -> string {
  {
    let mtmp0 = cut_pair(text/0, ":") in
    match mtmp0 {
      Option::None => {
        "missing"
      },
      Option::Some(x1) => {
        {
          let x1 = Option::Some._0(mtmp0) in
          {
            let x2 = x1.0 in
            let x3 = x1.1 in
            {
              let after/2 = x3 in
              {
                let before/1 = x2 in
                ((before/1 + "|") + after/2)
              }
            }
          }
        }
      },
    }
  }
}

