package main;
#[go_option_last]
extern "go" "strings" "Cut" cut_pair(text: string, sep: string) -> Option[(string, string)]

fn describe(text: string) -> string {
    match cut_pair(text, ":") {
        Option::Some((before, after)) => before + "|" + after,
        Option::None => "missing",
    }
}

fn main() {
    println(describe("alpha:beta"));
    println(describe("plain"));
}

