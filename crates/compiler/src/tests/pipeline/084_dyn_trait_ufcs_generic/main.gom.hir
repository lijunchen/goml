package main
file main.gom
  trait Display {
      fn show(Self) -> string;
    }
    
    struct Point {
        x: int32,
        y: int32,
    }
    
    impl Display for Point {
      fn show(local/1/0: Point) -> string {
        "P(" + int32_to_string(self/0.x) + "," + int32_to_string(self/0.y) + ")";
      }
    }
    
    fn render(local/1/1: dyn Display) -> string {
      Display::show(x/1);
    }
    
    fn main() {
      let local/1/2 = Point {
          x: 7,
          y: 9
      };
      let local/1/3: dyn Display = p/2;
      println(def/1/3(d/3));
      ();
    }