fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#Display#Point#show(self/0: Point) -> string {
  int32_to_string(Point.value(self/0))
}

fn to_dyn(x/1: T) -> dyn Display {
  to_dyn[Display]{T}(x/1)
}

fn render(x/2: dyn Display) -> string {
  dyn_call[Display::show](x/2)
}

fn main() -> unit {
  let d/3 = to_dyn(Point { value: 7 }) in
  let _wild0 = println(render(d/3)) in
  ()
}