      let t17 = int32_to_string(1) in
      string_print(t17)
    },
    Tag_1 => {
      let x0 = T::B._0(t/0) in
      let x1 = T::B._1(t/0) in
      match x1 {
        true => {
          match x0 {
            true => {
              let t18 = int32_to_string(4) in
