fn test(t/0: T) -> unit {
  join k6() -> unit {
    ()
  } in
  match t/0 {
    Tag_0 => {
      let t7 = int32_to_string(1) in
      let t8 = string_print(t7) in
      jump k6()
    },
    Tag_1 => {
      let x0 = T::B._0(t/0) in
      let x1 = T::B._1(t/0) in
      join k9() -> unit {
        jump k6()
      } in
      match x1 {
        true => {
          join k10() -> unit {
            jump k9()
          } in
          match x0 {
            true => {
              let t11 = int32_to_string(4) in
              let t12 = string_print(t11) in
              jump k10()
            },
            false => {
              let t13 = int32_to_string(3) in
              let t14 = string_print(t13) in
              jump k10()
            },
          }
        },
        false => {
          join k15() -> unit {
            jump k9()
          } in
          match x0 {
            true => {
              let t16 = int32_to_string(4) in
              let t17 = string_print(t16) in
              jump k15()
            },
            false => {
              let t18 = int32_to_string(2) in
              let t19 = string_print(t18) in
              jump k15()
            },
          }
        },
      }
    },
  }
}

fn main() -> unit {
  let t20 = T::B(true, true) in
  let mtmp2 = test(t20) in
  let t21 = T::B(false, true) in
  let mtmp3 = test(t21) in
  let t22 = T::B(false, false) in
  let mtmp4 = test(t22) in
  let mtmp5 = test(Tag_0) in
  ()
}