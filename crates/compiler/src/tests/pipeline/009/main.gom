enum T {
    A,
    B(bool, bool),
}

fn test(t: T) -> unit {
    match t {
        A => println(int32_to_string(1)),
        B(false, false) => println(int32_to_string(2)),
        B(false, true) => println(int32_to_string(3)),
        _ => println(int32_to_string(4)),
    }
}

fn main() {
    let _ = test(B(true, true));
    let _ = test(B(false, true));
    let _ = test(B(false, false));
    let _ = test(A);
    ()
}
