fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn test(t/0: T) -> unit {
  match t/0 {
    T::A => {
      string_print(int32_to_string(1))
    },
    T::B(x0, x1) => {
      {
        let x0 = T::B._0(t/0) in
        let x1 = T::B._1(t/0) in
        match x1 {
          true => {
            match x0 {
              true => {
                string_print(int32_to_string(4))
              },
              false => {
                string_print(int32_to_string(3))
              },
            }
          },
          false => {
            match x0 {
              true => {
                string_print(int32_to_string(4))
              },
              false => {
                string_print(int32_to_string(2))
              },
            }
          },
        }
      }
    },
  }
}

fn main() -> unit {
  let mtmp2 = test(T::B(true, true)) in
  {
    let mtmp3 = test(T::B(false, true)) in
    {
      let mtmp4 = test(T::B(false, false)) in
      {
        let mtmp5 = test(T::A) in
        {
          ()
        }
      }
    }
  }
}