package main
file main.gom
  enum T {
        A,
        B(bool, bool)
    }
    
    fn test(local/1/0: T) -> unit {
        match t/0 {
            ctor(def/1/0::v0) => println(1.to_string()),
            ctor(def/1/0::v1)(false, false) => println(2.to_string()),
            ctor(def/1/0::v1)(false, true) => println(3.to_string()),
            _ => println(4.to_string()),
        }
    }
    
    fn main() {
        let _ = def/1/1(ctor(def/1/0::v1)(true, true));
        let _ = def/1/1(ctor(def/1/0::v1)(false, true));
        let _ = def/1/1(ctor(def/1/0::v1)(false, false));
        let _ = def/1/1(ctor(def/1/0::v0));
        ()
    }