impl A for S{
  fn pick(self/0: S) -> int32 {
      10
  }
}

impl B for S{
  fn pick(self/1: S) -> int32 {
      20
  }
}

fn pick_a(x/2: T) -> int32 {
    (A::pick : (T) -> int32)((x/2 : T))
}

fn pick_b(x/3: T) -> int32 {
    (B::pick : (T) -> int32)((x/3 : T))
}

fn main() -> unit {
    (println : (string) -> unit)((ToString::to_string : (int32) -> string)((pick_a : (S) -> int32)(S {})));
    (println : (string) -> unit)((ToString::to_string : (int32) -> string)((pick_b : (S) -> int32)(S {})));
}