package main;
trait A {
  fn pick(Self) -> int32;
}

trait B {
  fn pick(Self) -> int32;
}

struct S {
}

impl A for S {
  fn pick(self: S) -> int32 {
      10
  }
}

impl B for S {
  fn pick(self: S) -> int32 {
      20
  }
}

fn pick_a(x: T) -> int32 {
    A::pick(x)
}

fn pick_b(x: T) -> int32 {
    B::pick(x)
}

fn main() {
    println(pick_a(S {}).to_string());
    println(pick_b(S {}).to_string());
}

