package main
file main.gom
  trait A {
      fn pick(Self) -> int32;
    }
    
    trait B {
      fn pick(Self) -> int32;
    }
    
    struct S {
    }
    
    impl A for S {
      fn pick(local/1/0: S) -> int32 {
          10
      }
    }
    
    impl B for S {
      fn pick(local/1/1: S) -> int32 {
          20
      }
    }
    
    fn pick_a(local/1/2: T) -> int32 {
        A::pick(x/2)
    }
    
    fn pick_b(local/1/3: T) -> int32 {
        B::pick(x/3)
    }
    
    fn main() {
        println(int32_to_string(def/1/5(S {})));
