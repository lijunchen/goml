fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn trait_impl#A#S#pick(self/0: S) -> int32 {
  10
}

fn trait_impl#B#S#pick(self/1: S) -> int32 {
  20
}

fn pick_a(x/2: T) -> int32 {
  trait_call[A::pick](x/2)
}

fn pick_b(x/3: T) -> int32 {
  trait_call[B::pick](x/3)
}

fn main() -> unit {
  let _wild1 = println(int32_to_string(pick_a(S {}))) in
  let _wild0 = println(int32_to_string(pick_b(S {}))) in
  ()
}