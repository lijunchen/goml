fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn inherent#Boxed#Boxed#format(self/0: Boxed) -> string {
  "inherent"
}

fn trait_impl#Render#Boxed#format(self/1: Boxed) -> string {
  int32_to_string(Boxed.value(self/1))
}

fn main() -> unit {
  let _wild0 = println(inherent#Boxed#Boxed#format(Boxed { value: 9 })) in
  let _wild1 = println(trait_impl#Render#Boxed#format(Boxed { value: 9 })) in
  ()
}