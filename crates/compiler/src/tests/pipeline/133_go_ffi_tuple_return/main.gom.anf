fn describe(input/0: string) -> string {
  join ret6(retv7: string) -> string {
    retv7
  } in
  let mtmp0 = cut(input/0, ":") in
  let x1 = mtmp0.0 in
  let x2 = mtmp0.1 in
  let x3 = mtmp0.2 in
  let found/3 = x3 in
  let after/2 = x2 in
  let before/1 = x1 in
  join k8(jp9: string) -> string {
    jump ret6(jp9)
  } in
  if found/3 {
    let t10 = (before/1 + "|") in
    let t11 = (t10 + after/2) in
    jump k8(t11)
  } else {
    jump k8("missing")
  }
}

