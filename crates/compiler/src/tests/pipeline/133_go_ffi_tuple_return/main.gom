extern "go" "strings" "Cut" cut(s: string, sep: string) -> (string, string, bool)

fn describe(input: string) -> string {
    let (before, after, found) = cut(input, ":");
    if found {
        before + "|" + after
    } else {
        "missing"
    }
}

fn main() {
    println(describe("left:right"));
    println(describe("plain"));
}
