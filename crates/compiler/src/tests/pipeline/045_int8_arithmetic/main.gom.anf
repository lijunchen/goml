fn a_value() -> int8 {
  90
}

fn b_value() -> int8 {
  (-20)
}

fn c_value() -> int8 {
  3
}

fn show_int8(label/0: string, value/1: int8) -> unit {
  let t514 = int8_to_string(value/1) in
  let t513 = (label/0 + t514) in
  let mtmp0 = string_println(t513) in
  ()
}

fn show_bool(label/2: string, value/3: bool) -> unit {
  let t516 = bool_to_string(value/3) in
  let t515 = (label/2 + t516) in
  let mtmp1 = string_println(t515) in
  ()
}

fn main() -> unit {
  let a/4 = a_value() in
  let b/5 = b_value() in
  let c/6 = c_value() in
  let sum/7 = (a/4 + b/5) in
  let diff/8 = (a/4 - c/6) in
  let prod/9 = (b/5 * c/6) in
  let quot/10 = (a/4 / c/6) in
  let neg/11 = (-b/5) in
  let less/12 = (b/5 < a/4) in
  let mtmp257 = show_int8("a=", a/4) in
  let mtmp385 = show_int8("b=", b/5) in
  let mtmp449 = show_int8("c=", c/6) in
  let mtmp481 = show_int8("sum=", sum/7) in
  let mtmp497 = show_int8("diff=", diff/8) in
  let mtmp505 = show_int8("prod=", prod/9) in
  let mtmp509 = show_int8("quot=", quot/10) in
  let mtmp511 = show_int8("neg=", neg/11) in
  let mtmp512 = show_bool("b<a=", less/12) in
  ()
}