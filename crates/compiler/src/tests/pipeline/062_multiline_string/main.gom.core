fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  let poem/0 = "roses are red\nviolets are blue\n\"quotes\" stay quoted\nbackslash \\\\\\\\ stays too" in
  let trailing_blank/1 = "line one\n\nline three" in
  let _wild0 = string_println(poem/0) in
  let _wild1 = string_println(trailing_blank/1) in
}