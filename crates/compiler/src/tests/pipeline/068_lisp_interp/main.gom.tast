                    _ : (Value, Value) => Value::Nil,
                },
              _ : int32 => Value::Nil,
          },
        "/" => if (Vec[Value]::len : (Vec[Value]) -> int32)((args/121 : Vec[Value])) == 2 {
              {
                  match ((args/121 : Vec[Value])[0], (args/121 : Vec[Value])[1]) {
