            },
            Value::Func(x137) => {
              let x137 = Value::Func._0(x134) in
              Value::Nil
            },
            Value::Nil => {
              Value::Nil
            },
          }
        },
        _ => Value::Nil,
      }
    },
    "/" => {
      if (vec_len(args/121) == 2) {
          let mtmp141 = (vec_get(args/121, 0), vec_get(args/121, 1)) in
          let x142 = mtmp141.0 in
          let x143 = mtmp141.1 in
          match x143 {
            Value::Int(x144) => {
