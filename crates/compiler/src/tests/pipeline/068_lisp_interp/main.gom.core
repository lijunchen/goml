                  },
                  SExpr::Bool(x74) => {
                    {
                      let x74 = SExpr::Bool._0(mtmp72) in
                      Value::Nil
                    }
                  },
                  SExpr::Sym(x75) => {
                    {
                      let x75 = SExpr::Sym._0(mtmp72) in
                      {
                        let var/90 = x75 in
                        {
                          let value/91 = eval(vec_get(items/87, 2), local/88, global/89) in
                          let env/92 = ref_get(global/89) in
                          let updated/93 = vec_push(env/92, Binding { name: var/90, value: value/91 }) in
                          let mtmp77 = ref_set(global/89, updated/93) in
                          {
                            value/91
