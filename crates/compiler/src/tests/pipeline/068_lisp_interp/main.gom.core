          ref_set(i/108, (ref_get(i/108) + 1))
        },
        SExpr::List(x98) => {
          let x98 = SExpr::List._0(mtmp94) in
          ref_set(i/108, (ref_get(i/108) + 1))
        },
      }
  } in
  ref_get(params/110)
}

fn eval_args(items/112: Vec[SExpr], start/113: int32, local/114: Vec[Binding], global/115: Ref[Vec[Binding]]) -> Vec[Value] {
  let i/116 = ref(start/113) in
  let acc/117 = vec_new() in
  let args/118 = ref(acc/117) in
  let mtmp102 = while (ref_get(i/116) < vec_len(items/112)) {
      let v/119 = eval(vec_get(items/112, ref_get(i/116)), local/114, global/115) in
      let mtmp101 = ref_set(args/118, vec_push(ref_get(args/118), v/119)) in
      ref_set(i/116, (ref_get(i/116) + 1))
  } in
  ref_get(args/118)
}

fn apply_builtin(name/120: string, args/121: Vec[Value]) -> Value {
  match name/120 {
    "=" => {
      if (vec_len(args/121) == 2) {
          let mtmp103 = (vec_get(args/121, 0), vec_get(args/121, 1)) in
          let x104 = mtmp103.0 in
          let x105 = mtmp103.1 in
          match x105 {
            Value::Int(x106) => {
              let x106 = Value::Int._0(x105) in
              match x104 {
                Value::Int(x109) => {
                  let x109 = Value::Int._0(x104) in
                  let a/122 = x109 in
                  let b/123 = x106 in
                  Value::Bool((a/122 == b/123))
                },
                Value::Bool(x110) => {
                  let x110 = Value::Bool._0(x104) in
                  Value::Bool(false)
                },
                Value::Func(x111) => {
                  let x111 = Value::Func._0(x104) in
                  Value::Bool(false)
                },
                Value::Nil => {
                  Value::Bool(false)
                },
              }
            },
            Value::Bool(x107) => {
              let x107 = Value::Bool._0(x105) in
              match x104 {
                Value::Int(x112) => {
                  let x112 = Value::Int._0(x104) in
                  Value::Bool(false)
                },
                Value::Bool(x113) => {
                  let x113 = Value::Bool._0(x104) in
                  let a/124 = x113 in
                  let b/125 = x107 in
                  Value::Bool((a/124 == b/125))
                },
                Value::Func(x114) => {
                  let x114 = Value::Func._0(x104) in
                  Value::Bool(false)
                },
                Value::Nil => {
                  Value::Bool(false)
                },
              }
            },
            Value::Func(x108) => {
              let x108 = Value::Func._0(x105) in
              Value::Bool(false)
            },
            Value::Nil => {
              Value::Bool(false)
            },
          }
      } else {
          Value::Bool(false)
      }
    },
    "+" => {
      let i/126 = ref(0) in
      let acc/127 = ref(0) in
      let mtmp120 = while (ref_get(i/126) < vec_len(args/121)) {
          let mtmp115 = vec_get(args/121, ref_get(i/126)) in
          match mtmp115 {
            Value::Int(x116) => {
              let x116 = Value::Int._0(mtmp115) in
              let n/128 = x116 in
              let mtmp119 = ref_set(acc/127, (ref_get(acc/127) + n/128)) in
              ref_set(i/126, (ref_get(i/126) + 1))
            },
            Value::Bool(x117) => {
              let x117 = Value::Bool._0(mtmp115) in
              ref_set(i/126, (ref_get(i/126) + 1))
            },
            Value::Func(x118) => {
              let x118 = Value::Func._0(mtmp115) in
              ref_set(i/126, (ref_get(i/126) + 1))
            },
            Value::Nil => {
              ref_set(i/126, (ref_get(i/126) + 1))
