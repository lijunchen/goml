    Value::Bool(x68) => {
      let x68 = Value::Bool._0(value/66) in
      let b/68 = x68 in
      bool_to_string(b/68)
    },
    Value::Func(x69) => {
      let x69 = Value::Func._0(value/66) in
      "<lambda>"
    },
    Value::Nil => {
      "nil"
    },
  }
}

fn truthy(value/69: Value) -> bool {
  match value/69 {
    Value::Int(x70) => {
      let x70 = Value::Int._0(value/69) in
      let n/71 = x70 in
      (n/71 != 0)
    },
    Value::Bool(x71) => {
      let x71 = Value::Bool._0(value/69) in
      let b/70 = x71 in
      b/70
    },
    Value::Func(x72) => {
      let x72 = Value::Func._0(value/69) in
      true
    },
    Value::Nil => {
      false
    },
  }
}

fn eval(expr/72: SExpr, local/73: Vec[Binding], global/74: Ref[Vec[Binding]]) -> Value {
  match expr/72 {
    SExpr::Int(x73) => {
      let x73 = SExpr::Int._0(expr/72) in
      let n/75 = x73 in
      Value::Int(n/75)
    },
    SExpr::Bool(x74) => {
      let x74 = SExpr::Bool._0(expr/72) in
      let b/76 = x74 in
      Value::Bool(b/76)
    },
    SExpr::Sym(x75) => {
      let x75 = SExpr::Sym._0(expr/72) in
      let name/77 = x75 in
      lookup(local/73, ref_get(global/74), name/77)
    },
    SExpr::List(x76) => {
      let x76 = SExpr::List._0(expr/72) in
      let items/78 = x76 in
      eval_list(items/78, local/73, global/74)
    },
  }
}

fn eval_list(items/79: Vec[SExpr], local/80: Vec[Binding], global/81: Ref[Vec[Binding]]) -> Value {
  if (vec_len(items/79) == 0) {
      Value::Nil
  } else {
      let head/82 = vec_get(items/79, 0) in
      match head/82 {
        SExpr::Int(x77) => {
          let x77 = SExpr::Int._0(head/82) in
          let f/84 = eval(head/82, local/80, global/81) in
          let args/85 = eval_args(items/79, 1, local/80, global/81) in
          apply(f/84, args/85, global/81)
        },
        SExpr::Bool(x78) => {
          let x78 = SExpr::Bool._0(head/82) in
          let f/84 = eval(head/82, local/80, global/81) in
          let args/85 = eval_args(items/79, 1, local/80, global/81) in
          apply(f/84, args/85, global/81)
        },
        SExpr::Sym(x79) => {
          let x79 = SExpr::Sym._0(head/82) in
          let name/83 = x79 in
          eval_list_sym(name/83, items/79, local/80, global/81)
        },
        SExpr::List(x80) => {
          let x80 = SExpr::List._0(head/82) in
          let f/84 = eval(head/82, local/80, global/81) in
          let args/85 = eval_args(items/79, 1, local/80, global/81) in
          apply(f/84, args/85, global/81)
        },
      }
  }
}

fn eval_list_sym(name/86: string, items/87: Vec[SExpr], local/88: Vec[Binding], global/89: Ref[Vec[Binding]]) -> Value {
  match name/86 {
    "begin" => {
      eval_begin(items/87, 1, local/88, global/89)
    },
    "define" => {
      if (vec_len(items/87) == 3) {
          let mtmp81 = vec_get(items/87, 1) in
          match mtmp81 {
            SExpr::Int(x82) => {
              let x82 = SExpr::Int._0(mtmp81) in
              Value::Nil
            },
            SExpr::Bool(x83) => {
              let x83 = SExpr::Bool._0(mtmp81) in
              Value::Nil
            },
            SExpr::Sym(x84) => {
              let x84 = SExpr::Sym._0(mtmp81) in
              let var/90 = x84 in
              let value/91 = eval(vec_get(items/87, 2), local/88, global/89) in
              let env/92 = ref_get(global/89) in
              let updated/93 = vec_push(env/92, Binding { name: var/90, value: value/91 }) in
              let mtmp86 = ref_set(global/89, updated/93) in
              value/91
            },
            SExpr::List(x85) => {
              let x85 = SExpr::List._0(mtmp81) in
              Value::Nil
            },
          }
      } else {
          Value::Nil
      }
    },
    "if" => {
      if (vec_len(items/87) == 4) {
          let cond/94 = eval(vec_get(items/87, 1), local/88, global/89) in
          if truthy(cond/94) {
              eval(vec_get(items/87, 2), local/88, global/89)
          } else {
              eval(vec_get(items/87, 3), local/88, global/89)
          }
      } else {
          Value::Nil
      }
    },
    "lambda" => {
      if (vec_len(items/87) == 3) {
          let mtmp87 = vec_get(items/87, 1) in
          match mtmp87 {
            SExpr::Int(x88) => {
              let x88 = SExpr::Int._0(mtmp87) in
              Value::Nil
            },
            SExpr::Bool(x89) => {
              let x89 = SExpr::Bool._0(mtmp87) in
              Value::Nil
            },
            SExpr::Sym(x90) => {
              let x90 = SExpr::Sym._0(mtmp87) in
              Value::Nil
            },
            SExpr::List(x91) => {
              let x91 = SExpr::List._0(mtmp87) in
              let params_exprs/95 = x91 in
              let params/96 = params_from_sexprs(params_exprs/95) in
              let body/97 = vec_get(items/87, 2) in
              Value::Func(Lambda { params: params/96, body: body/97, env: local/88, global: global/89 })
            },
          }
      } else {
          Value::Nil
      }
    },
    "+" => {
      apply_builtin("+", eval_args(items/87, 1, local/88, global/89))
    },
    "-" => {
      apply_builtin("-", eval_args(items/87, 1, local/88, global/89))
    },
    "*" => {
      apply_builtin("*", eval_args(items/87, 1, local/88, global/89))
    },
    "/" => {
      apply_builtin("/", eval_args(items/87, 1, local/88, global/89))
    },
    "=" => {
      apply_builtin("=", eval_args(items/87, 1, local/88, global/89))
    },
    _ => let f/98 = eval(SExpr::Sym(name/86), local/88, global/89) in
    let args/99 = eval_args(items/87, 1, local/88, global/89) in
    apply(f/98, args/99, global/89),
  }
}

fn eval_begin(items/100: Vec[SExpr], start/101: int32, local/102: Vec[Binding], global/103: Ref[Vec[Binding]]) -> Value {
  let i/104 = ref(start/101) in
  let last/105 = ref(Value::Nil) in
  let mtmp93 = while (ref_get(i/104) < vec_len(items/100)) {
      let v/106 = eval(vec_get(items/100, ref_get(i/104)), local/102, global/103) in
      let mtmp92 = ref_set(last/105, v/106) in
      ref_set(i/104, (ref_get(i/104) + 1))
  } in
  ref_get(last/105)
}

fn params_from_sexprs(items/107: Vec[SExpr]) -> Vec[string] {
  let i/108 = ref(0) in
  let acc/109 = vec_new() in
  let params/110 = ref(acc/109) in
  let mtmp100 = while (ref_get(i/108) < vec_len(items/107)) {
      let mtmp94 = vec_get(items/107, ref_get(i/108)) in
      match mtmp94 {
        SExpr::Int(x95) => {
          let x95 = SExpr::Int._0(mtmp94) in
          ref_set(i/108, (ref_get(i/108) + 1))
        },
        SExpr::Bool(x96) => {
          let x96 = SExpr::Bool._0(mtmp94) in
          ref_set(i/108, (ref_get(i/108) + 1))
        },
        SExpr::Sym(x97) => {
          let x97 = SExpr::Sym._0(mtmp94) in
          let name/111 = x97 in
