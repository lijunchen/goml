  } in
  ref_get(exprs/63)
}

fn value_to_string(value/66: Value) -> string {
  match value/66 {
    Value::Int(x67) => {
      let x67 = Value::Int._0(value/66) in
      let n/67 = x67 in
      int32_to_string(n/67)
