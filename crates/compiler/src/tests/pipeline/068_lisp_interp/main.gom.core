    },
    "*" => {
      let i/129 = ref(0) in
      let acc/130 = ref(1) in
      let mtmp126 = while (ref_get(i/129) < vec_len(args/121)) {
          let mtmp121 = vec_get(args/121, ref_get(i/129)) in
          match mtmp121 {
            Value::Int(x122) => {
              let x122 = Value::Int._0(mtmp121) in
              let n/131 = x122 in
              let mtmp125 = ref_set(acc/130, (ref_get(acc/130) * n/131)) in
