fn nested(top/1: bool, mode/2: Mode, inner_flag/3: bool) -> Option[int32] {
    let value/6: int32 = if (top/1 : bool) {
        {
            match (mode/2 : Mode) {
                Mode::Take => {
                      let inner/4: int32 = match (maybe_num : (bool) -> Option[int32])((inner_flag/3 : bool)) {
                          Option::Some(try_value/13: int32) => (try_value/13 : int32),
                          Option::None => return Option::None,
                      };
                      (inner/4 : int32) + 1
                  },
                Mode::Skip => 20,
            }
        }
    } else {
        {
            let inner/5: int32 = match (maybe_num : (bool) -> Option[int32])((inner_flag/3 : bool)) {
                Option::Some(try_value/24: int32) => (try_value/24 : int32),
                Option::None => return Option::None,
            };
            (inner/5 : int32) + 2
