}

fn main() -> unit {
    (println : (string) -> unit)((show : (Option[int32]) -> string)((nested : (bool, Mode, bool) -> Option[int32])(true, Mode::Take, true)));
    (println : (string) -> unit)((show : (Option[int32]) -> string)((nested : (bool, Mode, bool) -> Option[int32])(true, Mode::Skip, false)));
