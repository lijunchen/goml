fn main() -> bool {
    let a/0: (Color, Color) = (Color::Blue, Color::Blue);
    match (a/0 : (Color, Color)) {
        (Color::Red, Color::Green) => true,
        (Color::Red, Color::Red) => true,
        (Color::Blue, Color::Blue) => {
              let _ : unit = (print : (bool) -> unit)(true);
              false;
          },
        _ : (Color, Color) => false,
    };
}