fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

extern "go" "strings" cut_prefix(s: string, prefix: string) -> Option[string]

fn trim_go(input/0: string) -> Option[string] {
    Option::Some(match (cut_prefix : (string, string) -> Option[string])((input/0 : string), "go") {
        Option::Some(try_value/5: string) => (try_value/5 : string),
        Option::None => return Option::None,
    } + "!")
}

fn show(opt/1: Option[string]) -> string {
    match (opt/1 : Option[string]) {
        Option::Some(value/2: string) => "some=" + (value/2 : string),
        Option::None => "none",
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Option[string]) -> string)((trim_go : (string) -> Option[string])("goml")));
    (println : (string) -> unit)((show : (Option[string]) -> string)((trim_go : (string) -> Option[string])("ml")));
}