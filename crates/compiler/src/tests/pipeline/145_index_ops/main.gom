struct Holder {
    data: [int32; 2],
    vecs: Vec[[int32; 2]],
}

fn print_opt_int(x: Option[int32]) -> unit {
    match x {
        Option::Some(v) => println(v),
        Option::None => println("none"),
    }
}

fn main() -> unit {
    println([31, 32][1]);

    let arr = [1, 2, 3];
    println(arr[0]);

    let mut arr2 = [4, 5, 6];
    arr2[1] = 50;
    println(arr2[1]);

    let vec = Vec::new().push(7).push(8).push(9);
    println(vec[2]);

    let mut vec2 = Vec::new().push(10).push(11).push(12);
    vec2[0] = 100;
    println(vec2[0]);

    let s: Slice[int32] = vec2.slice(0, 2);
    println(s[1]);

    let map = HashMap::new();
    map["a"] = 13;
    print_opt_int(map["a"]);
    print_opt_int(map["missing"]);

    let mut matrix: [[int32; 2]; 2] = [[1, 2], [3, 4]];
    matrix[1][0] = 30;
    println(matrix[1][0]);

    let mut pair = ([14, 15], 0);
    pair.0[1] = 150;
    println(pair.0[1]);

    let mut holder = Holder {
        data: [16, 17],
        vecs: Vec::new().push([18, 19]).push([20, 21]),
    };
    holder.data[0] = 160;
    println(holder.data[0]);
    holder.vecs[1][0] = 200;
    println(holder.vecs[1][0]);

    let r: Ref[[int32; 2]] = ref([22, 23]);
    ref_get(r)[1] = 230;
    println(ref_get(r)[1]);
}
