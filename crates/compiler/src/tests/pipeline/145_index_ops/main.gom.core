fn print_opt_int(x/0: Option[int32]) -> unit {
  match x/0 {
    Option::None => {
      println("none")
    },
    Option::Some(x0) => {
      {
        let x0 = Option::Some._0(x/0) in
        {
          let v/1 = x0 in
          println(v/1)
        }
      }
    },
  }
}

