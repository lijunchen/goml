  }
}

fn print_opt_int(x/20: Option[int32]) -> unit {
    match (x/20 : Option[int32]) {
        Option::Some(v/21: int32) => (println : (int32) -> unit)((v/21 : int32)),
        Option::None => (println : (string) -> unit)("none"),
