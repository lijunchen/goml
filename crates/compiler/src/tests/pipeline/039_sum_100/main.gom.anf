fn my_int_equal(x/0: int32, y/1: int32) -> bool {
  join ret0(retv1: bool) -> bool {
    retv1
  } in
  let t2 = (x/0 < y/1) in
  let t3 = (!t2) in
  let t4 = (y/1 < x/0) in
  let t5 = (!t4) in
  let t6 = (t3 && t5) in
  jump ret0(t6)
}

fn sum(n/2: int32) -> int32 {
  join ret7(retv8: int32) -> int32 {
    retv8
  } in
  let t11 = my_int_equal(n/2, 1) in
  join k9(jp10: int32) -> int32 {
    jump ret7(jp10)
  } in
  if t11 {
    jump k9(1)
  } else {
    let t12 = (n/2 - 1) in
    let t13 = sum(t12) in
    let t14 = (n/2 + t13) in
    jump k9(t14)
  }
}

fn main() -> unit {
  join ret15() -> unit {
    ()
  } in
  let t16 = sum(100) in
  let t17 = println__T_int32(t16) in
