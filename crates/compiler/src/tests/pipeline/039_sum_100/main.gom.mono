fn my_int_equal(x/0: int32, y/1: int32) -> bool {
  ((!(x/0 < y/1)) && (!(y/1 < x/0)))
}

fn sum(n/2: int32) -> int32 {
  if my_int_equal(n/2, 1) {
      1
  } else {
      (n/2 + sum((n/2 - 1)))
  }
}

fn main() -> unit {
  println__T_int32(sum(100))
}

fn println__T_int32(value/1: int32) -> unit {
  string_println(int32_to_string(value/1))
}