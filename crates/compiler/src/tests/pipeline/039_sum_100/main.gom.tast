fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn my_int_equal(x/0: int32, y/1: int32) -> bool {
    !(x/0 : int32) < (y/1 : int32) && !(y/1 : int32) < (x/0 : int32)
}

fn sum(n/2: int32) -> int32 {
    if (my_int_equal : (int32, int32) -> bool)((n/2 : int32), 1) {
        {
            1
        }
    } else {
        {
            (n/2 : int32) + (sum : (int32) -> int32)((n/2 : int32) - 1)
        }
    }
}

fn main() -> unit {
    (println : (int32) -> unit)((sum : (int32) -> int32)(100))
}