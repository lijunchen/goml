package main
file main.gom
  enum Option[T] {
        Some(T),
        None
    }
    
    fn main() {
        let local/1/0: Option[uint8] = ctor(def/1/0::v0)(42);
        match x/0 {
            ctor(def/1/0::v0)(local/1/1) => println(uint8_to_string(v/1)),
            ctor(def/1/0::v1) => println("none"),
        };
    }