fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

extern "go" "time" "Duration" type Duration

extern "go" "time" parse_duration(s: string) -> Result[Duration, GoError]

extern "go" "fmt" format_duration(format: string, value: Duration) -> string

fn render_with_prefix(prefix/0: string, text/1: string) -> Result[string, GoError] {
    let run/3: () -> Result[string, GoError] = || => {
        let value/2: Duration = match (parse_duration : (string) -> Result[Duration, GoError])((text/1 : string)) {
            Result::Ok(try_value/4: Duration) => (try_value/4 : Duration),
            Result::Err(try_residual/4: GoError) => return Result::Err((try_residual/4 : GoError)),
        };
        Result::Ok((prefix/0 : string) + (format_duration : (string, Duration) -> string)("%v", (value/2 : Duration)))
    };
    (run/3 : () -> Result[string, GoError])()
}

fn show(res/4: Result[string, GoError]) -> string {
    match (res/4 : Result[string, GoError]) {
        Result::Ok(value/5: string) => (value/5 : string),
        Result::Err(err/6: GoError) => "err=" + (ToString::to_string : (GoError) -> string)((err/6 : GoError)),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((render_with_prefix : (string, string) -> Result[string, GoError])("seen=", "5s")));
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((render_with_prefix : (string, string) -> Result[string, GoError])("seen=", "bad")));
}