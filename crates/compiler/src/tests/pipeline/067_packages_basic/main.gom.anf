fn main() -> unit {
  let t0 = Lib::color_to_int(Tag_0) in
  let t1 = int32_to_string(t0) in
  let t2 = string_println(t1) in
  t2
}

fn Lib::color_to_int(c/0: Lib::Color) -> int32 {
  join k3(jp4: int32) -> int32 {
    jp4
  } in
  match c/0 {
    Tag_0 => {
      jump k3(1)
    },
    Tag_1 => {
      jump k3(2)
    },
  }
}