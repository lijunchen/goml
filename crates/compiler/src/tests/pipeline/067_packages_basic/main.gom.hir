package main
  imports Lib
file main.gom
  fn main() {
        println(Lib::color_to_int(Lib::Color::Red).to_string())
    }

package Lib
file Lib/main.gom
  enum Lib::Color {
        Red,
        Green
    }
    
    fn Lib::color_to_int(local/2/0: Color) -> int32 {
        match c/0 {
            ctor(def/2/0::v0) => 1,
            ctor(def/2/0::v1) => 2,
        }
    }