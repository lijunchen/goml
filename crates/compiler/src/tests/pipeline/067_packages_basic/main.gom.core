fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  string_println(int32_to_string(Lib::color_to_int(Lib::Color::Red)))
}

fn Lib::color_to_int(c/0: Lib::Color) -> int32 {
  match c/0 {
    Lib::Color::Red => {
      1
    },
    Lib::Color::Green => {
      2
    },
  }
}