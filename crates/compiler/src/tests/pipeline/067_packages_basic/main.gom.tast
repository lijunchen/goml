fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    (println : (string) -> unit)((int32_to_string : (int32) -> string)((Lib::color_to_int : (Lib::Color) -> int32)(Lib::Color::Red)))
}

fn Lib::color_to_int(c/0: Lib::Color) -> int32 {
    match (c/0 : Lib::Color) {
        Lib::Color::Red => 1,
        Lib::Color::Green => 2,
    }
}