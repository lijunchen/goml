fn main() -> unit {
    // Test Vec with int32
    let vi: Vec[int32] = Vec::new();
    let vi = vi.push(42);
    let val_i = vi[0];
    let len_i = vi.len();
    
    // Test Vec with string
    let vs: Vec[string] = Vec::new();
    let vs = vs.push("hello");
    let vs = vs.push("world");
    let val_s = vs[1];
    let len_s = vs.len();
    
    // Test Vec with bool
    let vb: Vec[bool] = Vec::new();
    let vb = vb.push(true);
    let vb = vb.push(false);
    let val_b = vb[0];
    let len_b = vb.len();
    
    // Print results
    let _ = println(int32_to_string(val_i));
    let _ = println(int32_to_string(len_i));
    let _ = println(val_s);
    let _ = println(int32_to_string(len_s));
    let _ = println(bool_to_string(val_b));
    let _ = println(int32_to_string(len_b));
    ()
}