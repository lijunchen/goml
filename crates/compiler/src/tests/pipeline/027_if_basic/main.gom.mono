fn choose(flag/0: bool, x/1: int32, y/2: int32) -> int32 {
  if flag/0 {
      {
        x/1
      }
  } else {
      {
        y/2
      }
  }
}

fn main() -> unit {
  let yes/3 = choose(true, 10, 99) in
  let no/4 = choose(false, 10, 99) in
  let mtmp0 = println__T_string(("yes=" + int32_to_string(yes/3))) in
  {
    let mtmp1 = println__T_string(("no=" + int32_to_string(no/4))) in
    {
      ()
    }
  }
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}