fn choose(flag/0: bool, x/1: int32, y/2: int32) -> int32 {
  join ret2(retv3: int32) -> int32 {
    retv3
  } in
  join k4(jp5: int32) -> int32 {
    jump ret2(jp5)
  } in
  if flag/0 {
    jump k4(x/1)
  } else {
    jump k4(y/2)
  }
}

