fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn choose(flag/0: bool, x/1: int32, y/2: int32) -> int32 {
  if flag/0 {
      x/1
  } else {
      y/2
  }
}

fn main() -> unit {
  let yes/3 = choose(true, 10, 99) in
  let no/4 = choose(false, 10, 99) in
  let mtmp1 = string_println(("yes=" + int32_to_string(yes/3))) in
  let mtmp2 = string_println(("no=" + int32_to_string(no/4))) in
  ()
}