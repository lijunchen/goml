fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn choose(flag/0: bool, x/1: int32, y/2: int32) -> int32 {
    if (flag/0 : bool) {
        {
            (x/1 : int32)
        }
    } else {
        {
            (y/2 : int32)
        }
    }
}

fn main() -> unit {
    let yes/3: int32 = (choose : (bool, int32, int32) -> int32)(true, 10, 99);
    let no/4: int32 = (choose : (bool, int32, int32) -> int32)(false, 10, 99);
    let _ : unit = (println : (string) -> unit)("yes=" + (ToString::to_string : (int32) -> string)((yes/3 : int32)));
    let _ : unit = (println : (string) -> unit)("no=" + (ToString::to_string : (int32) -> string)((no/4 : int32)));
    ()
}