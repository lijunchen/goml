package main
file main.gom
  fn main() -> unit {
        let local/1/0 = ref(0i32);
        let local/1/1 = ref(0i32);
        while ref_get(i/0) < 7i32 {
            {
                let local/1/2 = ref_get(i/0);
                ref_set(i/0, cur/2 + 1i32);
                let _ = if cur/2 < 5i32 {
                    match cur/2 {
                        1 => continue,
                        3 => continue,
