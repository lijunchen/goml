fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let _ : unit = ();
    let a/0: (bool, bool, (bool, bool)) = (true, false, (true, false));
    let b/5: bool = match (a/0 : (bool, bool, (bool, bool))) {
        (x/1: bool, y/2: bool, (z/3: bool, w/4: bool)) => (w/4 : bool),
    };
    let _ : unit = (print : (bool) -> unit)((b/5 : bool));
