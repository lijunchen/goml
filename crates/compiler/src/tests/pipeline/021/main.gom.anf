fn match_int(n/0: int32) -> int32 {
  join k7(jp8: int32) -> int32 {
    jp8
  } in
  match n/0 {
    0 => {
      jump k7(10)
    },
    1 => {
      jump k7(20)
    },
    _ => {
      jump k7(30)
    },
  }
}

fn wildcard_first(n/1: int32) -> int32 {
  40
}

fn wildcard_middle(n/2: int32) -> int32 {
  join k9(jp10: int32) -> int32 {
    jp10
  } in
  match n/2 {
    2 => {
      jump k9(90)
    },
    3 => {
      jump k9(100)
    },
    _ => {
      jump k9(100)
    },
  }
}

fn repeated(n/3: int32) -> int32 {
  join k11(jp12: int32) -> int32 {
    jp12
  } in
  match n/3 {
    1 => {
      jump k11(60)
    },
    _ => {
      jump k11(80)
    },
  }
}

fn main() -> unit {
  let t13 = match_int(0) in
  let t14 = int32_to_string(t13) in
  let mtmp0 = string_println(t14) in
  let t15 = match_int(5) in
  let t16 = int32_to_string(t15) in
  let mtmp1 = string_println(t16) in
  let t17 = wildcard_first(0) in
  let t18 = int32_to_string(t17) in
  let mtmp2 = string_println(t18) in
  let t19 = wildcard_first(2) in
  let t20 = int32_to_string(t19) in
  let mtmp3 = string_println(t20) in
  let t21 = wildcard_middle(2) in
  let t22 = int32_to_string(t21) in
  let mtmp4 = string_println(t22) in
  let t23 = wildcard_middle(3) in
  let t24 = int32_to_string(t23) in
  let mtmp5 = string_println(t24) in
  let t25 = repeated(1) in
  let t26 = int32_to_string(t25) in
  let mtmp6 = string_println(t26) in
  let t27 = repeated(3) in
  let t28 = int32_to_string(t27) in
  let t29 = string_println(t28) in
  t29
}