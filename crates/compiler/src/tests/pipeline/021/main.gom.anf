fn match_int(n/0: int32) -> int32 {
  join ret7(retv8: int32) -> int32 {
    retv8
  } in
  join k9(jp10: int32) -> int32 {
    jump ret7(jp10)
  } in
  match n/0 {
    0 => {
      jump k9(10)
    },
    1 => {
      jump k9(20)
    },
    _ => {
      jump k9(30)
    },
  }
}

fn wildcard_first(n/1: int32) -> int32 {
  join ret11(retv12: int32) -> int32 {
    retv12
  } in
  jump ret11(40)
}

fn wildcard_middle(n/2: int32) -> int32 {
  join ret13(retv14: int32) -> int32 {
    retv14
  } in
  join k15(jp16: int32) -> int32 {
    jump ret13(jp16)
  } in
  match n/2 {
    2 => {
      jump k15(90)
    },
    3 => {
      jump k15(100)
    },
    _ => {
      jump k15(100)
    },
  }
}

fn repeated(n/3: int32) -> int32 {
  join ret17(retv18: int32) -> int32 {
    retv18
  } in
  join k19(jp20: int32) -> int32 {
    jump ret17(jp20)
  } in
  match n/3 {
    1 => {
      jump k19(60)
    },
    _ => {
      jump k19(80)
    },
  }
}

fn main() -> unit {
  join ret21() -> unit {
    ()
  } in
  let t22 = match_int(0) in
  let t23 = int32_to_string(t22) in
  let mtmp0 = string_println(t23) in
  let t24 = match_int(5) in
  let t25 = int32_to_string(t24) in
  let mtmp1 = string_println(t25) in
  let t26 = wildcard_first(0) in
  let t27 = int32_to_string(t26) in
  let mtmp2 = string_println(t27) in
  let t28 = wildcard_first(2) in
  let t29 = int32_to_string(t28) in
  let mtmp3 = string_println(t29) in
  let t30 = wildcard_middle(2) in
  let t31 = int32_to_string(t30) in
  let mtmp4 = string_println(t31) in
  let t32 = wildcard_middle(3) in
  let t33 = int32_to_string(t32) in
  let mtmp5 = string_println(t33) in
  let t34 = repeated(1) in
  let t35 = int32_to_string(t34) in
  let mtmp6 = string_println(t35) in
  let t36 = repeated(3) in
  let t37 = int32_to_string(t36) in
  let t38 = string_println(t37) in
  jump ret21()
}