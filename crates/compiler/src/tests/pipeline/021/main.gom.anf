fn match_int(n/0: int32) -> int32 {
  match n/0 {
    0 => {
      10
    },
    1 => {
      20
    },
    _ => 30,
  }
}

fn wildcard_first(n/1: int32) -> int32 {
  40
}

fn wildcard_middle(n/2: int32) -> int32 {
  match n/2 {
    2 => {
      90
    },
    3 => {
      100
    },
    _ => 100,
  }
}

fn repeated(n/3: int32) -> int32 {
  match n/3 {
    1 => {
      60
    },
    _ => 80,
  }
}

fn main() -> unit {
  let t128 = match_int(0) in
  let t127 = int32_to_string(t128) in
  let mtmp63 = string_println(t127) in
  let t130 = match_int(5) in
  let t129 = int32_to_string(t130) in
  let mtmp95 = string_println(t129) in
  let t132 = wildcard_first(0) in
  let t131 = int32_to_string(t132) in
  let mtmp111 = string_println(t131) in
  let t134 = wildcard_first(2) in
  let t133 = int32_to_string(t134) in
  let mtmp119 = string_println(t133) in
  let t136 = wildcard_middle(2) in
  let t135 = int32_to_string(t136) in
  let mtmp123 = string_println(t135) in
  let t138 = wildcard_middle(3) in
  let t137 = int32_to_string(t138) in
  let mtmp125 = string_println(t137) in
  let t140 = repeated(1) in
  let t139 = int32_to_string(t140) in
  let mtmp126 = string_println(t139) in
  let t142 = repeated(3) in
  let t141 = int32_to_string(t142) in
  string_println(t141)
}