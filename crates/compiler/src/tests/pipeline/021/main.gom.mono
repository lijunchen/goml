fn match_int(n/0: int32) -> int32 {
  match n/0 {
    0 => {
      10
    },
    1 => {
      20
    },
    _ => 30,
  }
}

fn wildcard_first(n/1: int32) -> int32 {
  40
}

fn wildcard_middle(n/2: int32) -> int32 {
  match n/2 {
    2 => {
      90
    },
    3 => {
      100
    },
    _ => 100,
  }
}

fn repeated(n/3: int32) -> int32 {
  match n/3 {
    1 => {
      60
    },
    _ => 80,
  }
}

fn main() -> unit {
  let mtmp0 = println__T_string(int32_to_string(match_int(0))) in
  {
    let mtmp1 = println__T_string(int32_to_string(match_int(5))) in
    {
      let mtmp2 = println__T_string(int32_to_string(wildcard_first(0))) in
      {
        let mtmp3 = println__T_string(int32_to_string(wildcard_first(2))) in
        {
          let mtmp4 = println__T_string(int32_to_string(wildcard_middle(2))) in
          {
            let mtmp5 = println__T_string(int32_to_string(wildcard_middle(3))) in
            {
              let mtmp6 = println__T_string(int32_to_string(repeated(1))) in
              {
                println__T_string(int32_to_string(repeated(3)))
              }
            }
          }
        }
      }
    }
  }
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}