fn match_struct(counter/4: Counter) -> bool {
  let x0 = Counter.start(counter/4) in
  let x1 = Counter.end(counter/4) in
  join k11(jp12: bool) -> bool {
    jp12
  } in
  match x1 {
    900000000 => {
      join k13(jp14: bool) -> bool {
        jump k11(jp14)
      } in
      match x0 {
        4000000000 => {
          jump k13(true)
        },
        _ => {
          jump k13(false)
        },
