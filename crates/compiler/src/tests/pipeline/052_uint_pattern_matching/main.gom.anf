}

fn report(label/5: string, value/6: bool) -> string {
  let t15 = bool_to_string(value/6) in
  let t16 = (label/5 + t15) in
  t16
}

fn main() -> unit {
  let counter/7 = Counter { start: 4000000000, end: 900000000 } in
  let alt_counter/8 = Counter { start: 12, end: 600000000 } in
  let t17 = is_flag8(200) in
  let t18 = report("u8_hit=", t17) in
  let t19 = is_flag8(15) in
  let t20 = report(",u8_miss=", t19) in
  let t21 = (t18 + t20) in
  let t22 = is_flag16(65000) in
  let t23 = report(",u16_hit=", t22) in
  let t24 = (t21 + t23) in
