  let t38 = report(",u64_miss=", t37) in
  let t39 = (t36 + t38) in
  let t40 = match_struct(counter/7) in
  let t41 = report(",struct_first=", t40) in
  let t42 = (t39 + t41) in
  let t43 = match_struct(alt_counter/8) in
  let t44 = report(",struct_second=", t43) in
  let message/9 = (t42 + t44) in
  let mtmp2 = string_println(message/9) in
  ()
}