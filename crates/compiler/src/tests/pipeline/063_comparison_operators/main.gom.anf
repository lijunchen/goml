fn test_int_comparisons() -> unit {
  let a/0 = 10 in
  let b/1 = 20 in
  let c/2 = 10 in
  let less/3 = (a/0 < b/1) in
  let t2078 = bool_to_string(less/3) in
  let t2077 = ("10 < 20: " + t2078) in
  let mtmp511 = string_println(t2077) in
  let greater/4 = (b/1 > a/0) in
  let t2080 = bool_to_string(greater/4) in
  let t2079 = ("20 > 10: " + t2080) in
  let mtmp767 = string_println(t2079) in
  let less_eq1/5 = (a/0 <= b/1) in
  let t2082 = bool_to_string(less_eq1/5) in
  let t2081 = ("10 <= 20: " + t2082) in
  let mtmp895 = string_println(t2081) in
  let less_eq2/6 = (a/0 <= c/2) in
  let t2084 = bool_to_string(less_eq2/6) in
  let t2083 = ("10 <= 10: " + t2084) in
  let mtmp959 = string_println(t2083) in
  let greater_eq1/7 = (b/1 >= a/0) in
  let t2086 = bool_to_string(greater_eq1/7) in
  let t2085 = ("20 >= 10: " + t2086) in
  let mtmp991 = string_println(t2085) in
  let greater_eq2/8 = (c/2 >= a/0) in
  let t2088 = bool_to_string(greater_eq2/8) in
  let t2087 = ("10 >= 10: " + t2088) in
  let mtmp1007 = string_println(t2087) in
  let eq1/9 = (a/0 == c/2) in
  let t2090 = bool_to_string(eq1/9) in
  let t2089 = ("10 == 10: " + t2090) in
  let mtmp1015 = string_println(t2089) in
  let eq2/10 = (a/0 == b/1) in
  let t2092 = bool_to_string(eq2/10) in
  let t2091 = ("10 == 20: " + t2092) in
  let mtmp1019 = string_println(t2091) in
  let neq1/11 = (a/0 != b/1) in
  let t2094 = bool_to_string(neq1/11) in
  let t2093 = ("10 != 20: " + t2094) in
  let mtmp1021 = string_println(t2093) in
  let neq2/12 = (a/0 != c/2) in
  let t2096 = bool_to_string(neq2/12) in
  let t2095 = ("10 != 10: " + t2096) in
  let mtmp1022 = string_println(t2095) in
  ()
}

fn test_float_comparisons() -> unit {
  let x/13 = 3.14 in
  let y/14 = 2.71 in
  let z/15 = 3.14 in
  let less/16 = (y/14 < x/13) in
  let t2098 = bool_to_string(less/16) in
  let t2097 = ("2.71 < 3.14: " + t2098) in
  let mtmp1534 = string_println(t2097) in
  let greater/17 = (x/13 > y/14) in
  let t2100 = bool_to_string(greater/17) in
  let t2099 = ("3.14 > 2.71: " + t2100) in
  let mtmp1790 = string_println(t2099) in
  let less_eq1/18 = (y/14 <= x/13) in
  let t2102 = bool_to_string(less_eq1/18) in
  let t2101 = ("2.71 <= 3.14: " + t2102) in
  let mtmp1918 = string_println(t2101) in
  let less_eq2/19 = (x/13 <= z/15) in
  let t2104 = bool_to_string(less_eq2/19) in
  let t2103 = ("3.14 <= 3.14: " + t2104) in
  let mtmp1982 = string_println(t2103) in
  let greater_eq1/20 = (x/13 >= y/14) in
  let t2106 = bool_to_string(greater_eq1/20) in
  let t2105 = ("3.14 >= 2.71: " + t2106) in
  let mtmp2014 = string_println(t2105) in
  let greater_eq2/21 = (z/15 >= x/13) in
  let t2108 = bool_to_string(greater_eq2/21) in
  let t2107 = ("3.14 >= 3.14: " + t2108) in
  let mtmp2030 = string_println(t2107) in
  let eq1/22 = (x/13 == z/15) in
  let t2110 = bool_to_string(eq1/22) in
  let t2109 = ("3.14 == 3.14: " + t2110) in
  let mtmp2038 = string_println(t2109) in
  let eq2/23 = (x/13 == y/14) in
  let t2112 = bool_to_string(eq2/23) in
  let t2111 = ("3.14 == 2.71: " + t2112) in
  let mtmp2042 = string_println(t2111) in
  let neq1/24 = (x/13 != y/14) in
  let t2114 = bool_to_string(neq1/24) in
  let t2113 = ("3.14 != 2.71: " + t2114) in
  let mtmp2044 = string_println(t2113) in
  let neq2/25 = (x/13 != z/15) in
  let t2116 = bool_to_string(neq2/25) in
  let t2115 = ("3.14 != 3.14: " + t2116) in
  let mtmp2045 = string_println(t2115) in
  ()
}

fn main() -> unit {
  let mtmp2061 = string_println("=== Integer Comparisons ===") in
  let mtmp2069 = test_int_comparisons() in
  let mtmp2073 = string_println("") in
  let mtmp2075 = string_println("=== Float Comparisons ===") in
  let mtmp2076 = test_float_comparisons() in
  ()
}