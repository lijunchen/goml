fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let a/0: (bool, bool) = (true, true);
    match (a/0 : (bool, bool)) {
        (true, false) => (println : (string) -> unit)((int32::to_string : (int32) -> string)(123)),
        (false, true) => (println : (string) -> unit)((int32::to_string : (int32) -> string)(456)),
        _ : (bool, bool) => (println : (string) -> unit)((int32::to_string : (int32) -> string)(789)),
    }
}