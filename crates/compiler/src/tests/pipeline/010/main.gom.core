fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  let a/0 = (true, true) in
  let x0 = a/0.0 in
  let x1 = a/0.1 in
  match x1 {
    true => {
      match x0 {
        true => {
          string_print(int32_to_string(789))
        },
        false => {
          string_print(int32_to_string(456))
        },
      }
    },
    false => {
      match x0 {
        true => {
          string_print(int32_to_string(123))
        },
        false => {
          string_print(int32_to_string(789))
        },
      }
    },
  }
}