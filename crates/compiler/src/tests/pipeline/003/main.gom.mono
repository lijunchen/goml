fn main() -> unit {
  let mtmp0 = print__T_unit(()) in
  {
    let mtmp1 = print__T_bool(true) in
    {
      let mtmp2 = print__T_bool(false) in
      {
        let mtmp3 = print__T_int32(123) in
        {
          ()
        }
      }
    }
  }
}

fn print__T_unit(value/0: unit) -> unit {
  string_print(unit_to_string(value/0))
}

fn print__T_bool(value/0: bool) -> unit {
  string_print(bool_to_string(value/0))
}

fn print__T_int32(value/0: int32) -> unit {
  string_print(int32_to_string(value/0))
}