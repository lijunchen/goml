}

fn print__T_unit(value/0: unit) -> unit {
  let t4 = unit_to_string(value/0) in
  let t5 = string_print(t4) in
  t5
}

fn print__T_bool(value/0: bool) -> unit {
  let t6 = bool_to_string(value/0) in
  let t7 = string_print(t6) in
  t7
}

fn print__T_int32(value/0: int32) -> unit {
  let t8 = int32_to_string(value/0) in
  let t9 = string_print(t8) in
  t9
}