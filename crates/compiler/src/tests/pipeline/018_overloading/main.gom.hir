  trait Arith {
      fn add(Self, Self) -> int32;
      fn less(Self, Self) -> bool;
    }
    
    impl Arith for int32 {
      fn add(local/1/0: int32, local/1/1: int32) -> int32 {
        self/0 + other/1;
      }
      fn less(local/1/2: int32, local/1/3: int32) -> bool {
        self/2 < other/3;
      }
    }
    
    trait Output {
