fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

impl Arith for int32{
  fn add(self/0: int32, other/1: int32) -> int32 {
      (self/0 : int32) + (other/1 : int32)
  }
  fn less(self/2: int32, other/3: int32) -> bool {
      (self/2 : int32) < (other/3 : int32)
  }
}

impl Output for int32{
  fn output(self/4: int32) -> unit {
      (string_println : (string) -> unit)((ToString::to_string : (int32) -> string)((self/4 : int32)))
  }
}

impl Output for bool{
  fn output(self/5: bool) -> unit {
      (string_println : (string) -> unit)((ToString::to_string : (bool) -> string)((self/5 : bool)))
  }
}

fn id(x/6: T) -> T {
    (x/6 : T)
}

fn main() -> unit {
    let a/7: int32 = (id : (int32) -> int32)(1);
    let b/8: int32 = (id : (int32) -> int32)(2);
    let c/9: int32 = (Arith::add : (int32, int32) -> int32)((a/7 : int32), (b/8 : int32));
    let _ : unit = (Output::output : (int32) -> unit)((c/9 : int32));
    let a/10: int32 = (id : (int32) -> int32)(3);
    let b/11: int32 = (id : (int32) -> int32)(4);
    let c/12: bool = (Arith::less : (int32, int32) -> bool)((a/10 : int32), (b/11 : int32));
    let _ : unit = (Output::output : (bool) -> unit)((c/12 : bool));
    let _ : string = (id : (string) -> string)("abc");
    let _ : bool = (id : (bool) -> bool)(true);
    ()
}