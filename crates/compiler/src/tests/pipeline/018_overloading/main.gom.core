fn trait_impl#Arith#int32#add(self/0: int32, other/1: int32) -> int32 {
  (self/0 + other/1)
}

fn trait_impl#Arith#int32#less(self/2: int32, other/3: int32) -> bool {
  (self/2 < other/3)
}

fn trait_impl#Output#int32#output(self/4: int32) -> unit {
  string_println(trait_call[ToString::to_string](self/4))
}

fn trait_impl#Output#bool#output(self/5: bool) -> unit {
  string_println(trait_call[ToString::to_string](self/5))
}

fn id(x/6: T) -> T {
  x/6
}

fn main() -> unit {
  let a/7 = id(1) in
  let b/8 = id(2) in
  let c/9 = trait_impl#Arith#int32#add(a/7, b/8) in
  let mtmp0 = trait_impl#Output#int32#output(c/9) in
  let a/10 = id(3) in
  let b/11 = id(4) in
  let c/12 = trait_impl#Arith#int32#less(a/10, b/11) in
  let mtmp1 = trait_impl#Output#bool#output(c/12) in
  let mtmp2 = id("abc") in
  let mtmp3 = id(true) in
