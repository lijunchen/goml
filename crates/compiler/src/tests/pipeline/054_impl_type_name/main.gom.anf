fn trait_impl#TypeName#Point#type_name(self/0: Point) -> string {
  let mtmp0 = self/0 in
  let x1 = Point.x(mtmp0) in
  let x2 = Point.y(mtmp0) in
  let y/2 = x2 in
  let x/1 = x1 in
  let t11 = int32_to_string(x/1) in
  let prefix/3 = ("Point(" + t11) in
  let t13 = (prefix/3 + ", ") in
  let t14 = int32_to_string(y/2) in
  let t12 = (t13 + t14) in
  (t12 + ")")
}

fn trait_impl#TypeName#Shape#type_name(self/4: Shape) -> string {
  match self/4 {
    Tag_0 => {
