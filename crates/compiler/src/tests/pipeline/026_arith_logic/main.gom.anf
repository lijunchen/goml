fn show_int(label/0: string, value/1: int32) -> unit {
  let t290 = int32_to_string(value/1) in
  let t289 = (label/0 + t290) in
  let mtmp0 = string_println(t289) in
  ()
}

fn show_bool(label/2: string, value/3: bool) -> unit {
  let t292 = bool_to_string(value/3) in
  let t291 = (label/2 + t292) in
  let mtmp1 = string_println(t291) in
  ()
}

fn main() -> unit {
  let base/4 = 10 in
  let sum/5 = (base/4 + 5) in
  let diff/6 = (sum/5 - 3) in
  let prod/7 = (diff/6 * 2) in
  let quot/8 = (prod/7 / 4) in
  let mtmp145 = show_int("sum=", sum/5) in
  let mtmp217 = show_int("diff=", diff/6) in
  let mtmp253 = show_int("prod=", prod/7) in
  let mtmp271 = show_int("quot=", quot/8) in
  let and_result/9 = (true && false) in
  let or_result/10 = (true || false) in
  let not_result/11 = (!false) in
  let t294 = (!and_result/9) in
  let t297 = (prod/7 * base/4) in
  let t296 = (sum/5 + t297) in
  let t298 = (prod/7 / 2) in
  let mtmp287 = (t296 - t298) in
  let t295 = match mtmp287 {
    0 => {
      false
    },
    _ => true,
  } in
  let t293 = (t294 && t295) in
  let t302 = (diff/6 - quot/8) in
  let t301 = (t302 + base/4) in
  let t303 = (sum/5 / 2) in
  let mtmp288 = (t301 - t303) in
  let t300 = match mtmp288 {
    0 => {
      false
    },
    _ => true,
  } in
  let t299 = (!t300) in
  let mixed/12 = (t293 || t299) in
  let mtmp279 = show_bool("and=", and_result/9) in
  let mtmp283 = show_bool("or=", or_result/10) in
  let mtmp285 = show_bool("not=", not_result/11) in
  let mtmp286 = show_bool("mixed=", mixed/12) in
  ()
}