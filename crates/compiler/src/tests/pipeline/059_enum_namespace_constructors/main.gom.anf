fn color_is_red(color/0: Color) -> bool {
  join k1(jp2: bool) -> bool {
    jp2
  } in
  match color/0 {
    Tag_0 => {
      jump k1(true)
    },
    Tag_1 => {
      jump k1(false)
    },
  }
}

fn toggle_signal(signal/1: Signal) -> Signal {
  join k3(jp4: Signal) -> Signal {
    jp4
  } in
  match signal/1 {
    Tag_0 => {
      jump k3(Tag_1)
    },
    Tag_1 => {
      jump k3(Tag_0)
    },
  }
}

fn main() -> Signal {
  let current/2 = Tag_0 in
  let mtmp0 = color_is_red(current/2) in
  let t5 = toggle_signal(Tag_0) in
  t5
}