fn main() -> unit {
  let arr/0 = [10, 20, 30] in
  let i/1 = ref(0) in
  let _wild2 = while (ref_get(i/1) < 3) {
      {
        let _wild0 = println__T_string(uint8_to_string(array_get(arr/0, ref_get(i/1)))) in
        let _wild1 = ref_set(i/1, (ref_get(i/1) + 1)) in
      }
  } in
  let floats/2 = [1.5, 2.5] in
  let _wild3 = println__T_string(float32_to_string(array_get(floats/2, 0))) in
