fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  let arr/0 = [10, 20, 30] in
  let i/1 = ref(0) in
  let _wild2 = while (ref_get(i/1) < 3) {
      {
        let _wild0 = println(uint8_to_string(array_get(arr/0, ref_get(i/1)))) in
        let _wild1 = ref_set(i/1, (ref_get(i/1) + 1)) in
      }
  } in
  let floats/2 = [1.5, 2.5] in
  let _wild3 = println(float32_to_string(array_get(floats/2, 0))) in
  let _wild4 = println(float32_to_string(array_get(floats/2, 1))) in
  let longs/3 = [100, 200] in
  let _wild5 = println(int64_to_string(array_get(longs/3, 0))) in
  let _wild6 = println(int64_to_string(array_get(longs/3, 1))) in
}