fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let arr/0: [uint8; 3] = [10, 20, 30];
    let i/1: Ref[int32] = (ref : (int32) -> Ref[int32])(0);
    while (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) < 3 {
        {
            (println : (string) -> unit)((ToString::to_string : (uint8) -> string)((arr/0 : [uint8; 3])[(ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32]))]));
            (ref_set : (Ref[int32], int32) -> unit)((i/1 : Ref[int32]), (ref_get : (Ref[int32]) -> int32)((i/1 : Ref[int32])) + 1);
        }
    };
    let floats/2: [float32; 2] = [1.5, 2.5];
    (println : (string) -> unit)((ToString::to_string : (float32) -> string)((floats/2 : [float32; 2])[0]));
    (println : (string) -> unit)((ToString::to_string : (float32) -> string)((floats/2 : [float32; 2])[1]));
    let longs/3: [int64; 2] = [100, 200];
    (println : (string) -> unit)((ToString::to_string : (int64) -> string)((longs/3 : [int64; 2])[0]));
