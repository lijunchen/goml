fn update_array(arr/0: [int32; 3]) -> [int32; 3] {
  let t1 = array_set(arr/0, 1, 42) in
  t1
}

fn read_array(arr/1: [int32; 3]) -> int32 {
  let t2 = array_get(arr/1, 1) in
  t2
}

fn main() -> unit {
  let arr/2 = [1, 2, 3] in
  let updated/3 = update_array(arr/2) in
  let value/4 = read_array(updated/3) in
  let t3 = int32_to_string(value/4) in
  let mtmp0 = string_println(t3) in
