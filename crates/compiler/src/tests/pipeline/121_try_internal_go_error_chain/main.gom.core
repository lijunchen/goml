fn decorate(input/3: string) -> Result[string, GoError] {
  let value/4 = {
    let mtmp3 = normalize(input/3) in
    match mtmp3 {
      Result::Ok(x4) => {
        {
          let x4 = Result::Ok._0(mtmp3) in
