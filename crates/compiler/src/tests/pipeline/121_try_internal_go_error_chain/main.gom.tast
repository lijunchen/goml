fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

extern "go" "time" "Duration" type Duration

extern "go" "time" parse_duration(s: string) -> Result[Duration, GoError]

extern "go" "fmt" format_duration(format: string, value: Duration) -> string

fn parse_text(input/0: string) -> Result[Duration, GoError] {
    (parse_duration : (string) -> Result[Duration, GoError])((input/0 : string))
}

fn normalize(input/1: string) -> Result[Duration, GoError] {
    let value/2: Duration = match (parse_text : (string) -> Result[Duration, GoError])((input/1 : string)) {
        Result::Ok(try_value/7: Duration) => (try_value/7 : Duration),
        Result::Err(try_residual/7: GoError) => return Result::Err((try_residual/7 : GoError)),
    };
    Result::Ok((value/2 : Duration))
}

fn decorate(input/3: string) -> Result[string, GoError] {
    let value/4: Duration = match (normalize : (string) -> Result[Duration, GoError])((input/3 : string)) {
        Result::Ok(try_value/13: Duration) => (try_value/13 : Duration),
        Result::Err(try_residual/13: GoError) => return Result::Err((try_residual/13 : GoError)),
    };
    Result::Ok("dur=" + (format_duration : (string, Duration) -> string)("%v", (value/4 : Duration)))
}

fn show(res/5: Result[string, GoError]) -> string {
    match (res/5 : Result[string, GoError]) {
        Result::Ok(value/6: string) => (value/6 : string),
        Result::Err(err/7: GoError) => "err=" + (ToString::to_string : (GoError) -> string)((err/7 : GoError)),
    }
}

fn main() -> unit {
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((decorate : (string) -> Result[string, GoError])("3s")));
    (println : (string) -> unit)((show : (Result[string, GoError]) -> string)((decorate : (string) -> Result[string, GoError])("oops")));
}