fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn main() -> unit {
    let t/0: T = T::B(true, ());
    match (t/0 : T) {
        T::A => (println : (string) -> unit)((int32::to_string : (int32) -> string)(1)),
        T::B(true, ()) => (println : (string) -> unit)((int32::to_string : (int32) -> string)(2)),
        T::B(false, ()) => (println : (string) -> unit)((int32::to_string : (int32) -> string)(3)),
    }
}