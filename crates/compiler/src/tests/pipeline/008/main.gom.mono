fn main() -> unit {
  let t/0 = T::B(true, ()) in
  match t/0 {
    T::A => {
      println__T_string(int32_to_string(1))
    },
    T::B(x0, x1) => {
      {
        let x0 = T::B._0(t/0) in
        let x1 = T::B._1(t/0) in
        match x1 {
          () => {
            match x0 {
              true => {
                println__T_string(int32_to_string(2))
              },
              false => {
                println__T_string(int32_to_string(3))
              },
            }
          },
        }
      }
    },
  }
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}