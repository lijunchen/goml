fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn main() -> unit {
  let t/0 = T::B(true, ()) in
  match t/0 {
    T::A => {
      println(int32_to_string(1))
    },
    T::B(x0, x1) => {
      {
        let x0 = T::B._0(t/0) in
        let x1 = T::B._1(t/0) in
        match x1 {
          () => {
            match x0 {
              true => {
                println(int32_to_string(2))
              },
              false => {
                println(int32_to_string(3))
              },
            }
          },
        }
      }
    },
  }
}