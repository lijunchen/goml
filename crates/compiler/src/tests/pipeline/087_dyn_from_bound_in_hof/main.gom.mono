fn render_twice__T_int32(x/2: int32) -> string {
  let d/3 = to_dyn[Display]{int32}(x/2) in
  ((dyn_call[Display::show](d/3) + ",") + dyn_call[Display::show](d/3))
}

fn println__T_string(value/1: string) -> unit {
