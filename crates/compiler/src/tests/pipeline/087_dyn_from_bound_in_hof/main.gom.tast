fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)));
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)));
}

impl Display for int32{
  fn show(self/0: int32) -> string {
      (int32_to_string : (int32) -> string)((self/0 : int32));
  }
}

impl Display for bool{
  fn show(self/1: bool) -> string {
      (bool_to_string : (bool) -> string)((self/1 : bool));
  }
}

fn render_twice(x/2: T) -> string {
    let d/3: dyn Display = to_dyn[Display]{T}((x/2 : T));
    (dyn Display::show : (dyn Display) -> string)((d/3 : dyn Display)) + "," + (dyn Display::show : (dyn Display) -> string)((d/3 : dyn Display));
}

fn main() -> unit {
    (println : (string) -> unit)((render_twice : (int32) -> string)(42));
    (println : (string) -> unit)((render_twice : (bool) -> string)(true));
    ();
}