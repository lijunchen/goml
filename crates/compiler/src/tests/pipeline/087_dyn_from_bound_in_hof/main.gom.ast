package main;
trait Display {
  fn show(Self) -> string;
}

impl Display for int32 {
  fn show(self: int32) -> string {
      int32_to_string(self)
  }
}

fn mk_renderer(x: T) -> () -> string {
    let d: dyn Display = x;
    || Display::show(d)
}

fn main() {
    let f = mk_renderer(42);
    println(f());
}

