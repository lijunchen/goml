package main
file main.gom
  trait Display {
      fn show(Self) -> string;
    }
    
    impl Display for int32 {
      fn show(local/1/0: int32) -> string {
        int32_to_string(self/0);
      }
    }
    
    impl Display for bool {
      fn show(local/1/1: bool) -> string {
        bool_to_string(self/1);
      }
    }
    
    fn render_twice(local/1/2: T) -> string {
      let local/1/3: dyn Display = x/2;
      Display::show(d/3) + "," + Display::show(d/3);
    }
    
    fn main() {
      println(def/1/3(42));
      println(def/1/3(true));
      ();
    }