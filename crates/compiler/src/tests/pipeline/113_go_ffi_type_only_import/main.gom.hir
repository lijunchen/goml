package main
file main.gom
  extern "go" "io" "Reader" type Reader
    
    #[go_error_last]
extern "go" "os" "Open" open_reader(path: string) -> Result[Reader, GoError]
    
    extern "go" "fmt" "Sprintf" format_reader(format: string, value: Reader) -> string
    
    fn describe(local/1/0: string) -> string {
        match def/1/1(path/0) {
            Result::Ok(local/1/1) => def/1/2("type=%T", reader/1),
            Result::Err(local/1/2) => "err=" + err/2.to_string(),
