fn describe(path/0: string) -> string {
  {
    let mtmp0 = open_reader(path/0) in
    match mtmp0 {
      Result::Ok(x1) => {
        {
          let x1 = Result::Ok._0(mtmp0) in
          {
            let reader/1 = x1 in
            format_reader("type=%T", reader/1)
