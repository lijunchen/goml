extern "go" "time" "Duration" type Duration

extern "go" "time" sleep(d: Duration) -> unit
extern "go" "time" duration(nanos: int32) -> Duration

fn child_a() -> unit {
    println("child-a")
}

fn child_b() -> unit {
    println("child-b")
}

fn spawn(job: () -> unit) -> unit {
    go job;
}

fn pick(flag: bool) -> () -> unit {
    if flag { child_a } else { child_b }
}

fn wait() -> unit {
    sleep(duration(5000000))
}

fn main() -> unit {
    go child_a;
    wait();
    spawn(child_b);
    wait();
    let job = pick(true);
    go job;
    wait();
    println("main")
}
