fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn child_a() -> unit {
  println("child-a")
}

fn child_b() -> unit {
  println("child-b")
}

fn spawn(job/0: () -> unit) -> unit {
  let _wild0 = go job/0 in
}

fn pick(flag/1: bool) -> () -> unit {
  if flag/1 {
      {
        child_a
      }
  } else {
      {
        child_b
      }
  }
}

fn wait() -> unit {
  sleep(duration(5000000))
}

fn main() -> unit {
  let _wild1 = go child_a in
  let _wild2 = wait() in
  let _wild3 = spawn(child_b) in
  let _wild4 = wait() in
  let job/2 = pick(true) in
  let _wild5 = go job/2 in
  let _wild6 = wait() in
  println("main")
}