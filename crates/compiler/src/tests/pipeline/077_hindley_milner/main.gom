fn test11(st: Ref[State]) -> unit {
    let _ = reset_type_variables(st);
    let empty_env = vec_new();
    let id_exp = ref(mk_id());
    let z_app = Exp::App(ref(Exp::Var("x")), id_exp);
    let let_z = Exp::Let("z", ref(z_app), ref(Exp::Var("z")));
    let let_y = Exp::Let("y", ref(let_z), ref(Exp::Var("y")));
    let exp = Exp::Let("x", ref(mk_c1()), ref(let_y));
    let ty = typeof(st, empty_env, exp);
    match ty {
        Result::Ok(_) => println("test11: OK"),
        Result::Err(e) => println("test11: " + e),
    }
}

