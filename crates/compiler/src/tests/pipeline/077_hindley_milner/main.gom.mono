fn state_new() -> State {
  State { gensym_counter: ref(0), current_level: ref(1) }
}

fn reset_gensym(st/0: Ref[State]) -> unit {
  let s/1 = ref_get(st/0) in
  ref_set(State.gensym_counter(s/1), 0)
}

fn gensym(st/2: Ref[State]) -> string {
  let s/3 = ref_get(st/2) in
  let n/4 = ref_get(State.gensym_counter(s/3)) in
  let mtmp0 = ref_set(State.gensym_counter(s/3), (n/4 + 1)) in
  if (n/4 < 26) {
      let c/5 = string_get("abcdefghijklmnopqrstuvwxyz", n/4) in
      char_to_string(c/5)
  } else {
      ("t" + int32_to_string(n/4))
  }
}

fn reset_level(st/6: Ref[State]) -> unit {
  let s/7 = ref_get(st/6) in
  ref_set(State.current_level(s/7), 1)
}

fn reset_type_variables(st/8: Ref[State]) -> unit {
  let mtmp1 = reset_gensym(st/8) in
  reset_level(st/8)
}

fn enter_level(st/9: Ref[State]) -> unit {
  let s/10 = ref_get(st/9) in
  let lv/11 = ref_get(State.current_level(s/10)) in
  ref_set(State.current_level(s/10), (lv/11 + 1))
}

fn leave_level(st/12: Ref[State]) -> unit {
  let s/13 = ref_get(st/12) in
  let lv/14 = ref_get(State.current_level(s/13)) in
  ref_set(State.current_level(s/13), (lv/14 - 1))
}

fn newvar(st/15: Ref[State]) -> Typ {
  let s/16 = ref_get(st/15) in
  let id/17 = ref_get(State.gensym_counter(s/16)) in
  let name/18 = gensym(st/15) in
  let level/19 = ref_get(State.current_level(s/16)) in
  Typ::TVar(ref(TvContent::Unbound(id/17, name/18, level/19)))
}

fn min_int32(a/20: int32, b/21: int32) -> int32 {
  if (a/20 < b/21) {
      a/20
  } else {
      b/21
  }
}

