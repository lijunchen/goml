      let x102 = Typ::TArrow._1(ty/72) in
      let t2/81 = x102 in
      let t1/80 = x101 in
      Typ::TArrow(ref(gen(st/71, ref_get(t1/80))), ref(gen(st/71, ref_get(t2/81))))
    },
  }
}

fn inst_helper(st/82: Ref[State], ty/83: Typ, subst/84: Vec[(string, Typ)]) -> (Typ, Vec[(string, Typ)]) {
  match ty/83 {
    Typ::TVar(x107) => {
      let x107 = Typ::TVar._0(ty/83) in
      let tv/90 = x107 in
      let c/91 = ref_get(tv/90) in
      match c/91 {
        TvContent::Unbound(x111, x112, x113) => {
          let x111 = TvContent::Unbound._0(c/91) in
          let x112 = TvContent::Unbound._1(c/91) in
          let x113 = TvContent::Unbound._2(c/91) in
          (Typ::TVar(tv/90), subst/84)
        },
        TvContent::Link(x114) => {
          let x114 = TvContent::Link._0(c/91) in
          let linked_ty/92 = x114 in
          inst_helper(st/82, ref_get(linked_ty/92), subst/84)
        },
      }
    },
    Typ::QVar(x108) => {
      let x108 = Typ::QVar._0(ty/83) in
      let name/85 = x108 in
      let found/86 = vec_find_assoc(subst/84, name/85) in
      match found/86 {
        Option__Typ::None => {
          let tv/88 = newvar(st/82) in
          let new_subst/89 = vec_cons_subst((name/85, tv/88), subst/84) in
          (tv/88, new_subst/89)
        },
        Option__Typ::Some(x115) => {
          let x115 = Option__Typ::Some._0(found/86) in
          let t/87 = x115 in
          (t/87, subst/84)
        },
      }
    },
    Typ::TArrow(x109, x110) => {
      let x109 = Typ::TArrow._0(ty/83) in
      let x110 = Typ::TArrow._1(ty/83) in
      let t2/94 = x110 in
      let t1/93 = x109 in
      let pair1/95 = inst_helper(st/82, ref_get(t1/93), subst/84) in
      let mtmp116 = pair1/95 in
      let x117 = mtmp116.0 in
      let x118 = mtmp116.1 in
      let subst1/97 = x118 in
      let ty1/96 = x117 in
      let pair2/98 = inst_helper(st/82, ref_get(t2/94), subst1/97) in
      let mtmp119 = pair2/98 in
      let x120 = mtmp119.0 in
      let x121 = mtmp119.1 in
      let subst2/100 = x121 in
      let ty2/99 = x120 in
      (Typ::TArrow(ref(ty1/96), ref(ty2/99)), subst2/100)
    },
  }
}

fn inst(st/101: Ref[State], ty/102: Typ) -> Typ {
  let empty_subst/103 = vec_new() in
  let result/104 = inst_helper(st/101, ty/102, empty_subst/103) in
  let mtmp122 = result/104 in
  let x123 = mtmp122.0 in
  let x124 = mtmp122.1 in
  let ty_result/105 = x123 in
  ty_result/105
}

fn vec_cons_env(elem/106: (string, Typ), vec/107: Vec[(string, Typ)]) -> Vec[(string, Typ)] {
  let new_vec/108 = vec_new() in
  let new_vec/109 = vec_push(new_vec/108, elem/106) in
  let i/110 = ref(0) in
  let len/111 = vec_len(vec/107) in
  let new_vec_ref/112 = ref(new_vec/109) in
  let mtmp127 = while (ref_get(i/110) < len/111) {
      let nv/113 = ref_get(new_vec_ref/112) in
      let nv/114 = vec_push(nv/113, vec_get(vec/107, ref_get(i/110))) in
      let mtmp125 = ref_set(new_vec_ref/112, nv/114) in
      let mtmp126 = ref_set(i/110, (ref_get(i/110) + 1)) in
      ()
  } in
  ref_get(new_vec_ref/112)
}

fn vec_cons_subst(elem/115: (string, Typ), vec/116: Vec[(string, Typ)]) -> Vec[(string, Typ)] {
  let new_vec/117 = vec_new() in
  let new_vec/118 = vec_push(new_vec/117, elem/115) in
  let i/119 = ref(0) in
  let len/120 = vec_len(vec/116) in
  let new_vec_ref/121 = ref(new_vec/118) in
  let mtmp130 = while (ref_get(i/119) < len/120) {
      let nv/122 = ref_get(new_vec_ref/121) in
      let nv/123 = vec_push(nv/122, vec_get(vec/116, ref_get(i/119))) in
      let mtmp128 = ref_set(new_vec_ref/121, nv/123) in
      let mtmp129 = ref_set(i/119, (ref_get(i/119) + 1)) in
      ()
  } in
  ref_get(new_vec_ref/121)
}

fn vec_find_assoc(vec/124: Vec[(string, Typ)], key/125: string) -> Option__Typ {
  let i/126 = ref(0) in
  let len/127 = vec_len(vec/124) in
  let result/128 = ref(Option__Typ::None) in
  let mtmp135 = while (ref_get(i/126) < len/127) {
      let pair/129 = vec_get(vec/124, ref_get(i/126)) in
      let mtmp131 = pair/129 in
      let x132 = mtmp131.0 in
      let x133 = mtmp131.1 in
      let v/131 = x133 in
      let k/130 = x132 in
      let mtmp134 = if (k/130 == key/125) {
          ref_set(result/128, Option__Typ::Some(v/131))
      } else {
          ()
      } in
      ref_set(i/126, (ref_get(i/126) + 1))
  } in
  ref_get(result/128)
}

fn env_lookup(env/132: Vec[(string, Typ)], name/133: string) -> Option__Typ {
  vec_find_assoc(env/132, name/133)
}

fn typeof(st/134: Ref[State], env/135: Vec[(string, Typ)], exp/136: Exp) -> Result__Typ__string {
  match exp/136 {
    Exp::Var(x136) => {
      let x136 = Exp::Var._0(exp/136) in
      let x/137 = x136 in
      let mtmp144 = env_lookup(env/135, x/137) in
      match mtmp144 {
        Option__Typ::None => {
          Result__Typ__string::Err("unbound var")
        },
        Option__Typ::Some(x145) => {
          let x145 = Option__Typ::Some._0(mtmp144) in
          let ty/138 = x145 in
          Result__Typ__string::Ok(inst(st/134, ty/138))
        },
      }
    },
    Exp::App(x137, x138) => {
