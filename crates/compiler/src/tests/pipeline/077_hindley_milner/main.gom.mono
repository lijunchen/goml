          let x105 = TvContent::Unbound._2(c/76) in
          let l/78 = x105 in
          let name/77 = x104 in
          if (l/78 > curr_level/74) {
              Typ::QVar(name/77)
          } else {
              Typ::TVar(tv/75)
          }
        },
        TvContent::Link(x106) => {
          let x106 = TvContent::Link._0(c/76) in
          let linked_ty/79 = x106 in
          gen(st/71, ref_get(linked_ty/79))
        },
      }
    },
    Typ::QVar(x100) => {
      let x100 = Typ::QVar._0(ty/72) in
      ty/72
