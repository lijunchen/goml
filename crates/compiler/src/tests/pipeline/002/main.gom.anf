fn main() -> unit {
  let a/0 = (true, false) in
  let x5 = a/0.0 in
  let x6 = a/0.1 in
  let b/1 = match x6 {
    true => {
      match x5 {
        true => {
          (false, false)
        },
        false => {
          (true, false)
        },
      }
    },
    false => {
      match x5 {
        true => {
          (false, true)
        },
        false => {
          (true, true)
        },
      }
    },
  } in
  let x3 = b/1.0 in
  let x4 = b/1.1 in
  let w/2 = x4 in
  let b_1/3 = w/2 in
  let mtmp0 = (true, b_1/3) in
  let x1 = mtmp0.0 in
  let x2 = mtmp0.1 in
  let c/4 = match x2 {
    true => {
      match x1 {
        true => {
          let t7 = int32_to_string(3) in
