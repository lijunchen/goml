package main;
fn main() {
    let a = (true, false);
    let b = match a {
        (false, false) => (true, true),
        (false, true) => (true, false),
        (true, false) => (false, true),
        (true, true) => (false, false),
    };
    let b_1 = match b {
        (_, w) => w,
    };
    let c = match (true, b_1) {
        (false, false) => println(int32_to_string(0)),
        (false, true) => println(int32_to_string(1)),
        (true, false) => println(int32_to_string(2)),
        (true, true) => println(int32_to_string(3)),
    };
    println(unit_to_string(c))
}

