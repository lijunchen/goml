fn main() -> unit {
  let a/0 = (true, false) in
  let b/1 = let x5 = a/0.0 in
  let x6 = a/0.1 in
  match x6 {
    true => {
      match x5 {
        true => {
          (false, false)
        },
        false => {
          (true, false)
        },
      }
    },
    false => {
      match x5 {
        true => {
          (false, true)
        },
        false => {
          (true, true)
        },
      }
    },
  } in
  let b_1/3 = let x3 = b/1.0 in
  let x4 = b/1.1 in
  let w/2 = x4 in
  w/2 in
  let c/4 = let mtmp0 = (true, b_1/3) in
  let x1 = mtmp0.0 in
  let x2 = mtmp0.1 in
  match x2 {
    true => {
      match x1 {
        true => {
          string_print(int32_to_string(3))
        },
        false => {
          string_print(int32_to_string(1))
        },
      }
    },
    false => {
      match x1 {
        true => {
          string_print(int32_to_string(2))
        },
        false => {
          string_print(int32_to_string(0))
        },
      }
    },
  } in
  string_print(unit_to_string(c/4))
}