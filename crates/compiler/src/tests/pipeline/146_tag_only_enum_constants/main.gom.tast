fn print(value/0: T) -> unit {
    (string_print : (string) -> unit)((ToString::to_string : (T) -> string)((value/0 : T)))
}

fn println(value/1: T) -> unit {
    (string_println : (string) -> unit)((ToString::to_string : (T) -> string)((value/1 : T)))
}

fn light_code(light/0: Light) -> int32 {
    match (light/0 : Light) {
        Light::Red => 10,
        Light::Yellow => 20,
        Light::Green => 30,
    }
}

fn paint_code(paint/1: Paint) -> int32 {
    match (paint/1 : Paint) {
        Paint::Red => 1,
        Paint::Blue => 2,
    }
}

fn main() -> unit {
    let light/2: Light = Light::Red;
    let paint/3: Paint = Paint::Red;
    let _ : unit = (string_println : (string) -> unit)((int32_to_string : (int32) -> string)((light_code : (Light) -> int32)((light/2 : Light))));
    let _ : unit = (string_println : (string) -> unit)((int32_to_string : (int32) -> string)((paint_code : (Paint) -> int32)((paint/3 : Paint))));
    let _ : unit = (string_println : (string) -> unit)((int32_to_string : (int32) -> string)((light_code : (Light) -> int32)(Light::Green)));
    (string_println : (string) -> unit)((int32_to_string : (int32) -> string)((paint_code : (Paint) -> int32)(Paint::Blue)))
}