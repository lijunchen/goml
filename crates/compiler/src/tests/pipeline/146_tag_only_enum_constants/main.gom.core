fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn light_code(light/0: Light) -> int32 {
  match light/0 {
    Light::Red => {
      10
    },
    Light::Yellow => {
      20
    },
    Light::Green => {
      30
    },
  }
}

fn paint_code(paint/1: Paint) -> int32 {
  match paint/1 {
    Paint::Red => {
      1
    },
    Paint::Blue => {
      2
    },
  }
}

fn main() -> unit {
  let light/2 = Light::Red in
  let paint/3 = Paint::Red in
  let mtmp0 = println(trait_call[ToString::to_string](light_code(light/2))) in
  {
    let mtmp1 = println(trait_call[ToString::to_string](paint_code(paint/3))) in
    {
      let mtmp2 = println(trait_call[ToString::to_string](light_code(Light::Green))) in
      {
        println(trait_call[ToString::to_string](paint_code(Paint::Blue)))
      }
    }
  }
}