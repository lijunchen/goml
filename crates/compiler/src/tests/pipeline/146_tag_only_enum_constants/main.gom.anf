fn light_code(light/0: Light) -> int32 {
  join ret3(retv4: int32) -> int32 {
    retv4
  } in
  join k5(jp6: int32) -> int32 {
    jump ret3(jp6)
  } in
  match light/0 {
    Tag_0 => {
      jump k5(10)
    },
    Tag_1 => {
      jump k5(20)
    },
    Tag_2 => {
      jump k5(30)
    },
  }
}

fn paint_code(paint/1: Paint) -> int32 {
  join ret7(retv8: int32) -> int32 {
    retv8
  } in
  join k9(jp10: int32) -> int32 {
    jump ret7(jp10)
  } in
  match paint/1 {
    Tag_0 => {
      jump k9(1)
    },
    Tag_1 => {
      jump k9(2)
    },
  }
}

