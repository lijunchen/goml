package main
file main.gom
  enum Light {
        Red,
        Yellow,
        Green
    }
    
    enum Paint {
        Red,
        Blue
    }
    
    fn light_code(local/1/0: Light) -> int32 {
        match light/0 {
            ctor(def/1/0::v0) => 10,
            ctor(def/1/0::v1) => 20,
            ctor(def/1/0::v2) => 30,
        }
    }
    
    fn paint_code(local/1/1: Paint) -> int32 {
        match paint/1 {
            ctor(def/1/1::v0) => 1,
            ctor(def/1/1::v1) => 2,
        }
    }
    
    fn main() {
        let local/1/2 = ctor(def/1/0::v0);
        let local/1/3 = ctor(def/1/1::v0);
        let _ = println(int32_to_string(def/1/2(light/2)));
        let _ = println(int32_to_string(def/1/3(paint/3)));
        let _ = println(int32_to_string(def/1/2(ctor(def/1/0::v2))));
        println(int32_to_string(def/1/3(ctor(def/1/1::v1))))
    }