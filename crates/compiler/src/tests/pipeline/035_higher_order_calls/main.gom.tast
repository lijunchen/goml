fn double(x/0: int32) -> int32 {
    (x/0 : int32) * 2
}

fn increment(x/1: int32) -> int32 {
    (x/1 : int32) + 1
}

fn chooser(flag/2: bool) -> (int32) -> int32 {
    if (flag/2 : bool) {
        {
            (double : (int32) -> int32)
        }
    } else {
        {
            (increment : (int32) -> int32)
        }
    }
}

