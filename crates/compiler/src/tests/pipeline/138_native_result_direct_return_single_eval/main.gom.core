fn show(res/2: Result[int32, GoError]) -> string {
  match res/2 {
    Result::Ok(x1) => {
      {
        let x1 = Result::Ok._0(res/2) in
        {
          let value/3 = x1 in
          trait_call[ToString::to_string](value/3)
        }
      }
    },
    Result::Err(x2) => {
      {
        let x2 = Result::Err._0(res/2) in
        {
          let err/4 = x2 in
