fn take_u8(x/0: uint8) -> uint8 {
  x/0
}

fn take_f32(x/1: float32) -> float32 {
  x/1
}

fn main() -> unit {
  let a/2 = 1 in
  let b/3 = 2 in
  let c/4 = 3 in
  let d/5 = 4 in
  let e/6 = 5 in
  let f/7 = 6 in
  let g/8 = 7 in
  let h/9 = 1 in
  let _wild0 = println__T_string(uint8_to_string(a/2)) in
  let _wild1 = println__T_string(int8_to_string(b/3)) in
  let _wild2 = println__T_string(int16_to_string(c/4)) in
  let _wild3 = println__T_string(uint16_to_string(d/5)) in
  let _wild4 = println__T_string(uint32_to_string(e/6)) in
  let _wild5 = println__T_string(int64_to_string(f/7)) in
  let _wild6 = println__T_string(uint64_to_string(g/8)) in
  let _wild7 = println__T_string(float32_to_string(h/9)) in
  let _wild8 = println__T_string(uint8_to_string(take_u8(10))) in
  let _wild9 = println__T_string(float32_to_string(take_f32(2.5))) in
}

fn println__T_string(value/1: string) -> unit {
  string_println(value/1)
}