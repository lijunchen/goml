fn print(value/0: T) -> unit {
  string_print(trait_call[ToString::to_string](value/0))
}

fn println(value/1: T) -> unit {
  string_println(trait_call[ToString::to_string](value/1))
}

fn take_u8(x/0: uint8) -> uint8 {
  x/0
}

fn take_f32(x/1: float32) -> float32 {
  x/1
}

fn main() -> unit {
  let a/2 = 1 in
  let b/3 = 2 in
  let c/4 = 3 in
  let d/5 = 4 in
  let e/6 = 5 in
  let f/7 = 6 in
  let g/8 = 7 in
  let h/9 = 1 in
  let _wild0 = println(trait_call[ToString::to_string](a/2)) in
  let _wild1 = println(trait_call[ToString::to_string](b/3)) in
  let _wild2 = println(trait_call[ToString::to_string](c/4)) in
  let _wild3 = println(trait_call[ToString::to_string](d/5)) in
  let _wild4 = println(trait_call[ToString::to_string](e/6)) in
  let _wild5 = println(trait_call[ToString::to_string](f/7)) in
  let _wild6 = println(trait_call[ToString::to_string](g/8)) in
  let _wild7 = println(trait_call[ToString::to_string](h/9)) in
  let _wild8 = println(trait_call[ToString::to_string](take_u8(10))) in
  let _wild9 = println(trait_call[ToString::to_string](take_f32(2.5))) in
}