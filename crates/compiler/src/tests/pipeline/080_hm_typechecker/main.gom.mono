}

fn gensym(st/10: CheckerState) -> string {
  let n/11 = ref_get(CheckerState.gensym_counter(st/10)) in
  let mtmp5 = ref_set(CheckerState.gensym_counter(st/10), (n/11 + 1)) in
  if (n/11 < 26) {
      char_to_string(nth_letter(n/11))
  } else {
      ("t" + int32_to_string(n/11))
  }
}

fn newvar(st/12: CheckerState) -> Typ {
  let name/13 = gensym(st/12) in
  let level/14 = ref_get(CheckerState.current_level(st/12)) in
  Typ::TVar(ref(Tv::Unbound(name/13, level/14)))
}

fn typ_is_arrow(ty/15: Typ) -> bool {
  match ty/15 {
    Typ::TVar(x6) => {
      let x6 = Typ::TVar._0(ty/15) in
      let tvref/16 = x6 in
      let mtmp10 = ref_get(tvref/16) in
      match mtmp10 {
        Tv::Unbound(x11, x12) => {
          let x11 = Tv::Unbound._0(mtmp10) in
          let x12 = Tv::Unbound._1(mtmp10) in
          false
        },
        Tv::Link(x13) => {
          let x13 = Tv::Link._0(mtmp10) in
          let inner/17 = x13 in
          typ_is_arrow(inner/17)
        },
      }
    },
    Typ::QVar(x7) => {
      let x7 = Typ::QVar._0(ty/15) in
      false
    },
    Typ::TArrow(x8, x9) => {
      let x8 = Typ::TArrow._0(ty/15) in
      let x9 = Typ::TArrow._1(ty/15) in
      true
    },
  }
}

fn typ_to_string(ty/18: Typ) -> string {
  match ty/18 {
    Typ::TVar(x14) => {
      let x14 = Typ::TVar._0(ty/18) in
      let tvref/20 = x14 in
      let mtmp18 = ref_get(tvref/20) in
      match mtmp18 {
        Tv::Unbound(x19, x20) => {
          let x19 = Tv::Unbound._0(mtmp18) in
          let x20 = Tv::Unbound._1(mtmp18) in
          let name/21 = x19 in
          ("'" + name/21)
        },
        Tv::Link(x21) => {
          let x21 = Tv::Link._0(mtmp18) in
          let inner/22 = x21 in
          typ_to_string(inner/22)
        },
      }
    },
    Typ::QVar(x15) => {
      let x15 = Typ::QVar._0(ty/18) in
      let name/19 = x15 in
      ("'" + name/19)
    },
    Typ::TArrow(x16, x17) => {
      let x16 = Typ::TArrow._0(ty/18) in
      let x17 = Typ::TArrow._1(ty/18) in
      let t2/24 = x17 in
      let t1/23 = x16 in
      let s1/25 = if typ_is_arrow(t1/23) {
          (("(" + typ_to_string(t1/23)) + ")")
      } else {
          typ_to_string(t1/23)
      } in
      let s2/26 = typ_to_string(t2/24) in
      ((s1/25 + " -> ") + s2/26)
    },
  }
}

fn env_empty() -> Vec[EnvEntry] {
  let env/27 = vec_new() in
  env/27
}

fn env_lookup(env/28: Vec[EnvEntry], name/29: string) -> Option__Typ {
  let i/30 = ref((vec_len(env/28) - 1)) in
  let found/31 = ref(Option__Typ::None) in
  let done/32 = ref(false) in
  let mtmp23 = while ((!ref_get(done/32)) && (ref_get(i/30) >= 0)) {
      let entry/33 = vec_get(env/28, ref_get(i/30)) in
      if (EnvEntry.name(entry/33) == name/29) {
          let mtmp22 = ref_set(found/31, Option__Typ::Some(EnvEntry.ty(entry/33))) in
          ref_set(done/32, true)
      } else {
          ref_set(i/30, (ref_get(i/30) - 1))
      }
  } in
  ref_get(found/31)
}

fn subst_lookup(subst/34: Vec[SubstEntry], name/35: string) -> Option__Typ {
  let i/36 = ref((vec_len(subst/34) - 1)) in
  let found/37 = ref(Option__Typ::None) in
