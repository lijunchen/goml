    Exp::App(x136, x137) => {
      let x136 = Exp::App._0(e/104) in
      let x137 = Exp::App._1(e/104) in
      let e2/114 = x137 in
      let e1/113 = x136 in
      let mtmp145 = typeof(st/102, env/103, e1/113) in
      match mtmp145 {
        Result__Typ__string::Ok(x146) => {
          let x146 = Result__Typ__string::Ok._0(mtmp145) in
          let ty_fun/116 = x146 in
          let mtmp148 = typeof(st/102, env/103, e2/114) in
          match mtmp148 {
