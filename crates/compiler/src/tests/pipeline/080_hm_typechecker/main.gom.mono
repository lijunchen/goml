      let entry/39 = vec_get(subst/34, ref_get(i/36)) in
      if (SubstEntry.name(entry/39) == name/35) {
          let mtmp24 = ref_set(found/37, Option__Typ::Some(SubstEntry.ty(entry/39))) in
          ref_set(done/38, true)
      } else {
          ref_set(i/36, (ref_get(i/36) - 1))
      }
  } in
  ref_get(found/37)
}

fn occurs(st/40: CheckerState, tvr/41: Ref[Tv], ty/42: Typ) -> Result__unit__string {
  match ty/42 {
    Typ::TVar(x26) => {
      let x26 = Typ::TVar._0(ty/42) in
      let tvr2/43 = x26 in
      if ptr_eq(tvr/41, tvr2/43) {
          Result__unit__string::Err("occurs check")
      } else {
          let mtmp30 = ref_get(tvr2/43) in
          match mtmp30 {
            Tv::Unbound(x31, x32) => {
              let x31 = Tv::Unbound._0(mtmp30) in
              let x32 = Tv::Unbound._1(mtmp30) in
              let l2/45 = x32 in
              let name/44 = x31 in
              let min_level/47 = let mtmp34 = ref_get(tvr/41) in
              match mtmp34 {
                Tv::Unbound(x35, x36) => {
                  let x35 = Tv::Unbound._0(mtmp34) in
                  let x36 = Tv::Unbound._1(mtmp34) in
                  let l/46 = x36 in
                  min_i32(l/46, l2/45)
