}

fn inst_loop(st/83: CheckerState, subst/84: Vec[SubstEntry], ty/85: Typ) -> (Typ, Vec[SubstEntry]) {
  match ty/85 {
    Typ::TVar(x116) => {
      let x116 = Typ::TVar._0(ty/85) in
      let tvref/90 = x116 in
      let mtmp120 = ref_get(tvref/90) in
      match mtmp120 {
        Tv::Unbound(x121, x122) => {
          let x121 = Tv::Unbound._0(mtmp120) in
          let x122 = Tv::Unbound._1(mtmp120) in
          (Typ::TVar(tvref/90), subst/84)
