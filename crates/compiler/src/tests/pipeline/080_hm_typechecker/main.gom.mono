    },
    Typ::TArrow(x118, x119) => {
      let x118 = Typ::TArrow._0(ty/85) in
      let x119 = Typ::TArrow._1(ty/85) in
      let t2/93 = x119 in
      let t1/92 = x118 in
      let mtmp126 = inst_loop(st/83, subst/84, t1/92) in
      let x127 = mtmp126.0 in
      let x128 = mtmp126.1 in
      let subst1/95 = x128 in
      let ty1/94 = x127 in
      let mtmp129 = inst_loop(st/83, subst1/95, t2/93) in
      let x130 = mtmp129.0 in
      let x131 = mtmp129.1 in
      let subst2/97 = x131 in
      let ty2/96 = x130 in
      (Typ::TArrow(ty1/94, ty2/96), subst2/97)
    },
  }
}

fn inst(st/98: CheckerState, ty/99: Typ) -> Typ {
  let subst0/100 = vec_new() in
