      let x/105 = x135 in
      let mtmp143 = env_lookup(env/103, x/105) in
      match mtmp143 {
        Option__Typ::None => {
          Result__Typ__string::Err("unbound var")
        },
        Option__Typ::Some(x144) => {
          let x144 = Option__Typ::Some._0(mtmp143) in
          let ty/106 = x144 in
          Result__Typ__string::Ok(inst(st/102, ty/106))
