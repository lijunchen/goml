fn state_new() -> CheckerState {
  CheckerState { gensym_counter: ref(0), current_level: ref(1) }
}

fn reset_gensym(st/0: CheckerState) -> unit {
  let mtmp0 = ref_set(CheckerState.gensym_counter(st/0), 0) in
  ()
}

fn reset_level(st/1: CheckerState) -> unit {
  let mtmp1 = ref_set(CheckerState.current_level(st/1), 1) in
  ()
}

fn reset_type_variables(st/2: CheckerState) -> unit {
  let _wild2 = reset_gensym(st/2) in
  reset_level(st/2)
}

fn enter_level(st/3: CheckerState) -> unit {
  let l/4 = ref_get(CheckerState.current_level(st/3)) in
  let mtmp3 = ref_set(CheckerState.current_level(st/3), (l/4 + 1)) in
  ()
}

fn leave_level(st/5: CheckerState) -> unit {
  let l/6 = ref_get(CheckerState.current_level(st/5)) in
  let mtmp4 = ref_set(CheckerState.current_level(st/5), (l/6 - 1)) in
  ()
}

fn min_i32(a/7: int32, b/8: int32) -> int32 {
  if (a/7 < b/8) {
      a/7
  } else {
      b/8
  }
}

fn nth_letter(n/9: int32) -> char {
  match n/9 {
