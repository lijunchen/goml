                Tv::Link(x37) => {
                  let x37 = Tv::Link._0(mtmp34) in
                  l2/45
                },
              } in
              let mtmp38 = ref_set(tvr2/43, Tv::Unbound(name/44, min_level/47)) in
              Result__unit__string::Ok(())
            },
            Tv::Link(x33) => {
              let x33 = Tv::Link._0(mtmp30) in
              let inner/48 = x33 in
              occurs(st/40, tvr/41, inner/48)
            },
          }
      }
    },
    Typ::QVar(x27) => {
      let x27 = Typ::QVar._0(ty/42) in
      Result__unit__string::Ok(())
    },
    Typ::TArrow(x28, x29) => {
      let x28 = Typ::TArrow._0(ty/42) in
      let x29 = Typ::TArrow._1(ty/42) in
      let t2/50 = x29 in
      let t1/49 = x28 in
      let mtmp39 = occurs(st/40, tvr/41, t1/49) in
      match mtmp39 {
        Result__unit__string::Ok(x40) => {
          let x40 = Result__unit__string::Ok._0(mtmp39) in
          occurs(st/40, tvr/41, t2/50)
        },
        Result__unit__string::Err(x41) => {
          let x41 = Result__unit__string::Err._0(mtmp39) in
          let e/51 = x41 in
          Result__unit__string::Err(e/51)
        },
