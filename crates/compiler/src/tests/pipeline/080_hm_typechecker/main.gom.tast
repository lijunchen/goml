        Typ::TVar(tvref/16: Ref[Tv]) => match (ref_get : (Ref[Tv]) -> Tv)((tvref/16 : Ref[Tv])) {
              Tv::Link(inner/17: Typ) => (typ_is_arrow : (Typ) -> bool)((inner/17 : Typ)),
              _ : Tv => false,
