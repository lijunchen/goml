}

fn typ_to_string(ty/18: Typ) -> string {
    match (ty/18 : Typ) {
        Typ::QVar(name/19: string) => "'" + (name/19 : string),
        Typ::TVar(tvref/20: Ref[Tv]) => match (ref_get : (Ref[Tv]) -> Tv)((tvref/20 : Ref[Tv])) {
              Tv::Unbound(name/21: string, _ : int32) => "'" + (name/21 : string),
              Tv::Link(inner/22: Typ) => (typ_to_string : (Typ) -> string)((inner/22 : Typ)),
          },
        Typ::TArrow(t1/23: Typ, t2/24: Typ) => {
              let s1/25: string = if (typ_is_arrow : (Typ) -> bool)((t1/23 : Typ)) {
                  {
                      "(" + (typ_to_string : (Typ) -> string)((t1/23 : Typ)) + ")"
