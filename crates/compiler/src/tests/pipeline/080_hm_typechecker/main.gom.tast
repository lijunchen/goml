fn typeof(st/102: CheckerState, env/103: Vec[EnvEntry], e/104: Exp) -> Result[Typ, string] {
    match (e/104 : Exp) {
        Exp::Var(x/105: string) => match (env_lookup : (Vec[EnvEntry], string) -> Option[Typ])((env/103 : Vec[EnvEntry]), (x/105 : string)) {
              Option::Some(ty/106: Typ) => Result::Ok((inst : (CheckerState, Typ) -> Typ)((st/102 : CheckerState), (ty/106 : Typ))),
              Option::None => Result::Err("unbound var"),
          },
        Exp::Lam(x/107: string, body/108: Exp) => {
              let ty_x/109: Typ = (newvar : (CheckerState) -> Typ)((st/102 : CheckerState));
              let env2/110: Vec[EnvEntry] = (Vec[EnvEntry]::push : (Vec[EnvEntry], EnvEntry) -> Vec[EnvEntry])((env/103 : Vec[EnvEntry]), EnvEntry { name: (x/107 : string), ty: (ty_x/109 : Typ) });
              match (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/102 : CheckerState), (env2/110 : Vec[EnvEntry]), (body/108 : Exp)) {
                  Result::Ok(ty_e/111: Typ) => Result::Ok(Typ::TArrow((ty_x/109 : Typ), (ty_e/111 : Typ))),
                  Result::Err(e/112: string) => Result::Err((e/112 : string)),
              }
          },
        Exp::App(e1/113: Exp, e2/114: Exp) => {
              match (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/102 : CheckerState), (env/103 : Vec[EnvEntry]), (e1/113 : Exp)) {
                  Result::Err(e/115: string) => Result::Err((e/115 : string)),
                  Result::Ok(ty_fun/116: Typ) => {
                        match (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/102 : CheckerState), (env/103 : Vec[EnvEntry]), (e2/114 : Exp)) {
                            Result::Err(e/117: string) => Result::Err((e/117 : string)),
                            Result::Ok(ty_arg/118: Typ) => {
                                  let ty_res/119: Typ = (newvar : (CheckerState) -> Typ)((st/102 : CheckerState));
                                  let arrow/120: Typ = Typ::TArrow((ty_arg/118 : Typ), (ty_res/119 : Typ));
                                  match (unify : (CheckerState, Typ, Typ) -> Result[unit, string])((st/102 : CheckerState), (ty_fun/116 : Typ), (arrow/120 : Typ)) {
                                      Result::Ok(_ : unit) => Result::Ok((ty_res/119 : Typ)),
                                      Result::Err(e/121: string) => Result::Err((e/121 : string)),
                                  }
                              },
                        }
                    },
              }
          },
        Exp::Let(x/122: string, e1/123: Exp, e2/124: Exp) => {
              (enter_level : (CheckerState) -> unit)((st/102 : CheckerState));
              let ty_e/125: Result[Typ, string] = (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/102 : CheckerState), (env/103 : Vec[EnvEntry]), (e1/123 : Exp));
              (leave_level : (CheckerState) -> unit)((st/102 : CheckerState));
              match (ty_e/125 : Result[Typ, string]) {
                  Result::Err(e/126: string) => Result::Err((e/126 : string)),
                  Result::Ok(ty1/127: Typ) => {
                        let env2/128: Vec[EnvEntry] = (Vec[EnvEntry]::push : (Vec[EnvEntry], EnvEntry) -> Vec[EnvEntry])((env/103 : Vec[EnvEntry]), EnvEntry { name: (x/122 : string), ty: (gen : (CheckerState, Typ) -> Typ)((st/102 : CheckerState), (ty1/127 : Typ)) });
                        (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/102 : CheckerState), (env2/128 : Vec[EnvEntry]), (e2/124 : Exp))
                    },
              }
          },
    }
}

fn exp_var(name/129: string) -> Exp {
    Exp::Var((name/129 : string))
}

