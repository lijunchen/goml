}

fn show_result(label/137: string, res/138: Result[Typ, string]) -> unit {
    match (res/138 : Result[Typ, string]) {
        Result::Ok(ty/139: Typ) => (println : (string) -> unit)((label/137 : string) + ": " + (typ_to_string : (Typ) -> string)((ty/139 : Typ))),
        Result::Err(e/140: string) => (println : (string) -> unit)((label/137 : string) + ": " + (e/140 : string)),
    }
}

fn main() -> unit {
    let st/141: CheckerState = (state_new : () -> CheckerState)();
    let id/142: Exp = (exp_lam : (string, Exp) -> Exp)("x", (exp_var : (string) -> Exp)("x"));
    let c1/143: Exp = (exp_lam : (string, Exp) -> Exp)("x", (exp_lam : (string, Exp) -> Exp)("y", (exp_app : (Exp, Exp) -> Exp)((exp_var : (string) -> Exp)("x"), (exp_var : (string) -> Exp)("y"))));
    (reset_type_variables : (CheckerState) -> unit)((st/141 : CheckerState));
    (show_result : (string, Result[Typ, string]) -> unit)("id", (typeof : (CheckerState, Vec[EnvEntry], Exp) -> Result[Typ, string])((st/141 : CheckerState), (env_empty : () -> Vec[EnvEntry])(), (id/142 : Exp)));
    (reset_type_variables : (CheckerState) -> unit)((st/141 : CheckerState));
