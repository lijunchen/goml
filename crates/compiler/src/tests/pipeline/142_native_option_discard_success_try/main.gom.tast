extern "go" "strings" cut_pair(text: string, sep: string) -> Option[(string, string)]

fn touch(text/0: string) -> Option[string] {
    let _ : (string, string) = match (cut_pair : (string, string) -> Option[(string, string)])((text/0 : string), ":") {
        Option::Some(try_value/5: (string, string)) => (try_value/5 : (string, string)),
        Option::None => return Option::None,
    };
