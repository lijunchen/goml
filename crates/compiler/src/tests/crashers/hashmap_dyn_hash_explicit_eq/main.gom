impl Eq for dyn Hash {
    fn eq(self: dyn Hash, other: dyn Hash) -> bool {
        Hash::hash(self) == Hash::hash(other)
    }
}

fn main() {
    let h: HashMap[dyn Hash, string] = HashMap::new();
    let inner: dyn Hash = 1;
    h.set(inner, "one");
    println(bool_to_string(h.contains(inner)));
}
