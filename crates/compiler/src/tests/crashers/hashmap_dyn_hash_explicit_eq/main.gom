impl Eq for dyn Hash {
    fn eq(self: dyn Hash, other: dyn Hash) -> bool {
        Hash::hash(self) == Hash::hash(other)
    }
}

fn main() {
    let h: HashMap[dyn Hash, string] = hashmap_new();
    let inner: dyn Hash = 1;
    hashmap_set(h, inner, "one");
    string_println(bool_to_string(hashmap_contains(h, inner)));
}
