#[go_error]
extern "go" "os" "Setenv" Tuple2_int32_int32(key: string, value: string) -> Result[unit, GoError]

fn main() -> unit {
    let t = (1i32, 2i32);
    let result = Tuple2_int32_int32("GOML_EXTERN_WRAPPER_TUPLE_PREFIX", "ok");
    match result {
        Result::Ok(_) => println(t.0 + t.1),
        Result::Err(_) => println(0i32),
    };
}
