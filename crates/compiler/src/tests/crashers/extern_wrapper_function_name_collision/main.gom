#[go_option_last]
extern "go" "strings" "Cut" cut_pair(text: string, sep: string) -> Option[(string, string)]

fn cut_pair_ffi_wrap() -> unit {
    println("user-wrapper");
}

fn main() -> unit {
    match cut_pair("a:b", ":") {
        Option::Some((left, right)) => println(left + right),
        None => println("none"),
    };
    cut_pair_ffi_wrap();
}
