impl Eq for Ref[dyn Hash] {
    fn eq(self: Ref[dyn Hash], other: Ref[dyn Hash]) -> bool {
        Hash::hash(ref_get(self)) == Hash::hash(ref_get(other))
    }
}

fn main() {
    let h: HashMap[Ref[dyn Hash], string] = HashMap::new();
    let inner: dyn Hash = 1;
    let r = ref(inner);
    h.set(r, "one");
    println(h.contains(r).to_string());
}
